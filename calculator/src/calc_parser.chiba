def parse_tokens(tokens: Vec): LabeledAST = {
    match parse_rule_0(tokens, 0) {
        MatchOK(ast, pos, recovered) => {
            if recovered != 0 { Err(Some(ast), token_prefix(tokens, pos)) }
            else {
                match match_eof(tokens, pos) {
                    MatchOK(_, _, _) => OK(ast, token_prefix(tokens, pos))
