def match_token(tokens: Vec, pos: i64, want: Str): MatchResult =
    if streq(want, mk_str("Eof", 3)) != 0 {
        match_token_Eof(tokens, pos)
    }
    else if streq(want, mk_str("Semi", 4)) != 0 {
        match_token_Semi(tokens, pos)
    }
    else if streq(want, mk_str("KwVar", 5)) != 0 {
        match_token_KwVar(tokens, pos)
    }
    else if streq(want, mk_str("Ident", 5)) != 0 {
        match_token_Ident(tokens, pos)
    }
    else if streq(want, mk_str("ColonEq", 7)) != 0 {
        match_token_ColonEq(tokens, pos)
    }
    else if streq(want, mk_str("IntLit", 6)) != 0 {
        match_token_IntLit(tokens, pos)
    }
    else if streq(want, mk_str("LParen", 6)) != 0 {
        match_token_LParen(tokens, pos)
    }
    else if streq(want, mk_str("RParen", 6)) != 0 {
        match_token_RParen(tokens, pos)
    }
    else if streq(want, mk_str("Minus", 5)) != 0 {
        match_token_Minus(tokens, pos)
    }
    else if streq(want, mk_str("Star", 4)) != 0 {
        match_token_Star(tokens, pos)
    }
    else if streq(want, mk_str("Slash", 5)) != 0 {
        match_token_Slash(tokens, pos)
    }
    else if streq(want, mk_str("Percent", 7)) != 0 {
        match_token_Percent(tokens, pos)
    }
    else if streq(want, mk_str("Plus", 4)) != 0 {
        match_token_Plus(tokens, pos)
    }
    else {
        MatchFail(pos)
    }

def match_eof(tokens: Vec, pos: i64): MatchResult =
    if pos >= vec_len(tokens) { MatchOK(0 as i64, pos, 0) }
    else {
        let ts = vec_get(tokens, pos) as TokenSpan
        match ts.token {
            Eof => MatchOK(0 as i64, pos + 1, 0)
            _ => MatchFail(pos)
        }
    }

def token_name_matches_span(ts: TokenSpan, name: Str): i64 =
    if streq(name, mk_str("Eof", 3)) != 0 {
        match ts.token {
            Eof => 1
            _ => 0
        }
    }
    else if streq(name, mk_str("Semi", 4)) != 0 {
        match ts.token {
            Semi => 1
            _ => 0
        }
    }
    else if streq(name, mk_str("KwVar", 5)) != 0 {
        match ts.token {
            KwVar => 1
            _ => 0
        }
    }
    else if streq(name, mk_str("Ident", 5)) != 0 {
        match ts.token {
            Ident(_) => 1
            _ => 0
        }
    }
    else if streq(name, mk_str("ColonEq", 7)) != 0 {
        match ts.token {
            ColonEq => 1
            _ => 0
        }
    }
    else if streq(name, mk_str("IntLit", 6)) != 0 {
        match ts.token {
            IntLit(_) => 1
            _ => 0
        }
    }
    else if streq(name, mk_str("LParen", 6)) != 0 {
        match ts.token {
            LParen => 1
            _ => 0
        }
    }
    else if streq(name, mk_str("RParen", 6)) != 0 {
        match ts.token {
            RParen => 1
            _ => 0
        }
    }
    else if streq(name, mk_str("Minus", 5)) != 0 {
        match ts.token {
            Minus => 1
            _ => 0
        }
    }
    else if streq(name, mk_str("Star", 4)) != 0 {
        match ts.token {
            Star => 1
            _ => 0
        }
    }
    else if streq(name, mk_str("Slash", 5)) != 0 {
        match ts.token {
            Slash => 1
            _ => 0
        }
    }
    else if streq(name, mk_str("Percent", 7)) != 0 {
        match ts.token {
            Percent => 1
            _ => 0
        }
    }
    else if streq(name, mk_str("Plus", 4)) != 0 {
        match ts.token {
            Plus => 1
            _ => 0
        }
    }
    else {
        0
    }

def token_matches_name(tokens: Vec, pos: i64, name: Str): i64 =
    if streq(name, mk_str("Eof", 3)) != 0 {
        if pos >= vec_len(tokens) { 1 } else {
            let ts = vec_get(tokens, pos) as TokenSpan
            match ts.token { Eof => 1  _ => 0 }
        }
    }
    else if pos < vec_len(tokens) {
        let ts = vec_get(tokens, pos) as TokenSpan
        token_name_matches_span(ts, name)
    }
    else { 0 }

def find_token_position(tokens: Vec, pos: i64, name: Str): i64 =
    if pos > vec_len(tokens) { 0 - 1 }
    else if token_matches_name(tokens, pos, name) != 0 { pos }
    else { find_token_position(tokens, pos + 1, name) }

