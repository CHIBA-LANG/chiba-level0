namespace metalstd.map.test
use metalstd.mem.*
use metalstd.map.*
use metalstd.str.*
use metalstd.option.*
use metalstd.test.*
use metalstd.print.*

def test_map(ctx: i64): i64 = {
    let _ = write_fd(1, "-- StrMap tests --\n", 19)

    let m0: StrMap[i64] = strmap_new()
    let _ = assert_eq(ctx, "map empty len", strmap_len(m0), 0)

    let m1 = strmap_insert(m0, mk_str("hello", 5), 100)
    let _ = assert_eq(ctx, "map insert len", strmap_len(m1), 1)
    let _ = assert_eq(ctx, "map get", unwrap_or(strmap_get(m1, mk_str("hello", 5)), 0 - 1), 100)
    let _ = assert_eq(ctx, "map has", strmap_has(m1, mk_str("hello", 5)), 1)
    let _ = assert_eq(ctx, "map miss", is_none(strmap_get(m1, mk_str("nope", 4))), 1)

    let m2 = strmap_insert(m1, mk_str("hello", 5), 200)
    let _ = assert_eq(ctx, "map update", unwrap_or(strmap_get(m2, mk_str("hello", 5)), 0 - 1), 200)
    let _ = assert_eq(ctx, "map update len", strmap_len(m2), 1)

    let m3 = strmap_insert(m2, mk_str("world", 5), 77)
    let _ = assert_eq(ctx, "map two keys", unwrap_or(strmap_get(m3, mk_str("world", 5)), 0 - 1), 77)
    let _ = assert_eq(ctx, "map two keys 2", unwrap_or(strmap_get(m3, mk_str("hello", 5)), 0 - 1), 200)
    let _ = assert_eq(ctx, "map two len", strmap_len(m3), 2)

    let m4 = strmap_delete(m3, mk_str("hello", 5))
    let _ = assert_eq(ctx, "map delete", strmap_has(m4, mk_str("hello", 5)), 0)
    let _ = assert_eq(ctx, "map delete other", unwrap_or(strmap_get(m4, mk_str("world", 5)), 0 - 1), 77)
    let _ = assert_eq(ctx, "map delete len", strmap_len(m4), 1)

    0
}
