namespace std.regex.test
use metalstd.mem.*
use metalstd.str.*
use metalstd.option.*
use metalstd.test.*
use std.regex.ast.*
use std.regex.parse.*
use std.regex.compile.*
use std.regex.matcheng.*
use std.regex.utf8.*

def regex_is_match(pat_ptr: i64, pat_len: i64, subj_ptr: i64, subj_len: i64): i64 = {
    let ast_opt = regex_parse(pat_ptr, pat_len)
    match ast_opt {
        None => 0
        Some(ast) => {
            let re = regex_compile(ast)
            regex_match(re, subj_ptr, subj_len)
        }
    }
}

def regex_is_match_cstr(pat: i64, subj: i64): i64 = {
    let p = cstr_from_cptr(pat)
    let s = cstr_from_cptr(subj)
    regex_is_match(p.ptr, p.len, s.ptr, s.len)
}

def test_regex_parse(ctx: i64): i64 = {
    let _ = write_fd(1, "-- regex parse tests --\n", 23)

    let p1 = cstr_from_cptr("a")
    let r1 = regex_parse(p1.ptr, p1.len)
    let _ = assert_true(ctx, "regex parse single char", is_some(r1))

    let p2 = cstr_from_cptr("a|b")
    let r2 = regex_parse(p2.ptr, p2.len)
    let _ = assert_true(ctx, "regex parse alternation", is_some(r2))

    let p3 = cstr_from_cptr("a*")
    let r3 = regex_parse(p3.ptr, p3.len)
    let _ = assert_true(ctx, "regex parse star", is_some(r3))

    let p4 = cstr_from_cptr("[ab]")
    let r4 = regex_parse(p4.ptr, p4.len)
    let _ = assert_true(ctx, "regex parse class", is_some(r4))

    let p5 = cstr_from_cptr("(")
    let r5 = regex_parse(p5.ptr, p5.len)
    let _ = assert_true(ctx, "regex parse dangling lparen tolerated", is_some(r5))

    let p6 = cstr_from_cptr("(?=a)")
    let r6 = regex_parse(p6.ptr, p6.len)
    let _ = assert_true(ctx, "regex parse pos lookahead", is_some(r6))

    let p7 = cstr_from_cptr("(?!a)")
    let r7 = regex_parse(p7.ptr, p7.len)
    let _ = assert_true(ctx, "regex parse neg lookahead", is_some(r7))

    let p8 = cstr_from_cptr("a*?")
    let r8 = regex_parse(p8.ptr, p8.len)
    let _ = assert_true(ctx, "regex parse lazy star", is_some(r8))

    let p9 = cstr_from_cptr("\\d+")
    let r9 = regex_parse(p9.ptr, p9.len)
    let _ = assert_true(ctx, "regex parse escape digit", is_some(r9))

    0
}

def test_regex_match(ctx: i64): i64 = {
    let _ = write_fd(1, "-- regex match tests --\n", 23)

    let _ = assert_eq(ctx, "regex literal exact", regex_is_match_cstr("abc", "abc"), 1)
    let _ = assert_eq(ctx, "regex literal search", regex_is_match_cstr("bc", "abc"), 1)
    let _ = assert_eq(ctx, "regex literal miss", regex_is_match_cstr("ac", "abc"), 0)

    let _ = assert_eq(ctx, "regex dot", regex_is_match_cstr(".", "x"), 1)
    let _ = assert_eq(ctx, "regex plus", regex_is_match_cstr("a+", "baaac"), 1)
    let _ = assert_eq(ctx, "regex plus miss", regex_is_match_cstr("a+", "bbb"), 0)

    let _ = assert_eq(ctx, "regex class hit", regex_is_match_cstr("[abc]", "xxbxx"), 1)
    let _ = assert_eq(ctx, "regex class miss", regex_is_match_cstr("[abc]", "xyz"), 0)
    let _ = assert_eq(ctx, "regex nclass hit", regex_is_match_cstr("[^a]", "bbb"), 1)
    let _ = assert_eq(ctx, "regex nclass miss", regex_is_match_cstr("[^a]", "a"), 0)

    let _ = assert_eq(ctx, "regex alt hit", regex_is_match_cstr("a|b", "zzbzz"), 1)
    let _ = assert_eq(ctx, "regex alt miss", regex_is_match_cstr("a|b", "zzczz"), 0)

    let _ = assert_eq(ctx, "regex \\d hit", regex_is_match_cstr("\\d", "a1b"), 1)
    let _ = assert_eq(ctx, "regex \\D miss", regex_is_match_cstr("\\D", "123"), 0)
    let _ = assert_eq(ctx, "regex \\w hit", regex_is_match_cstr("\\w", "_"), 1)
    let _ = assert_eq(ctx, "regex \\W miss", regex_is_match_cstr("\\W", "_"), 0)
    let _ = assert_eq(ctx, "regex \\s hit", regex_is_match_cstr("\\s", "a b"), 1)
    let _ = assert_eq(ctx, "regex \\S miss", regex_is_match_cstr("\\S", " \t"), 0)

    0
}

def test_regex_utf8(ctx: i64): i64 = {
    let _ = write_fd(1, "-- regex utf8 tests --\n", 23)

    let _ = assert_eq(ctx, "utf8 len ascii", utf8_char_len_from_first_byte(97), 1)
    let _ = assert_eq(ctx, "utf8 len 2-byte", utf8_char_len_from_first_byte(195), 2)
    let _ = assert_eq(ctx, "utf8 len 3-byte", utf8_char_len_from_first_byte(228), 3)

    let s = cstr_from_cptr("aé中")
    let _ = assert_eq(ctx, "utf8 byte len mixed", s.len, 6)

    let _ = assert_eq(ctx, "utf8 decode ascii", utf8_decode_char(s.ptr, 0), 97)
    let _ = assert_eq(ctx, "utf8 decode e-acute", utf8_decode_char(s.ptr, 1), 233)
    let _ = assert_eq(ctx, "utf8 decode zhong", utf8_decode_char(s.ptr, 3), 20013)

    let _ = assert_eq(ctx, "utf8 next 0", utf8_next_offset(s.ptr, 0), 1)
    let _ = assert_eq(ctx, "utf8 next 1", utf8_next_offset(s.ptr, 1), 3)
    let _ = assert_eq(ctx, "utf8 next 3", utf8_next_offset(s.ptr, 3), 6)

    let _ = assert_eq(ctx, "utf8 prev 6", utf8_prev_offset(s.ptr, 6), 3)
    let _ = assert_eq(ctx, "utf8 prev 3", utf8_prev_offset(s.ptr, 3), 1)
    let _ = assert_eq(ctx, "utf8 prev 1", utf8_prev_offset(s.ptr, 1), 0)

    0
}

def test_regex_match_utf8(ctx: i64): i64 = {
    let _ = write_fd(1, "-- regex match utf8 tests --\n", 29)

    // UTF-8 literal matching
    let _ = assert_eq(ctx, "regex utf8 literal cn", regex_is_match_cstr("中", "abc中def"), 1)
    let _ = assert_eq(ctx, "regex utf8 literal miss", regex_is_match_cstr("中", "abcdef"), 0)
    let _ = assert_eq(ctx, "regex utf8 e-acute", regex_is_match_cstr("é", "café"), 1)

    // dot matches full codepoint
    let _ = assert_eq(ctx, "regex utf8 dot cn", regex_is_match_cstr(".", "中"), 1)
    let _ = assert_eq(ctx, "regex utf8 dot 2ch", regex_is_match_cstr("..", "aé"), 1)
    let _ = assert_eq(ctx, "regex utf8 dot 3ch", regex_is_match_cstr("...", "a中b"), 1)

    // char class ranges
    let _ = assert_eq(ctx, "regex range a-z hit", regex_is_match_cstr("[a-z]", "x"), 1)
    let _ = assert_eq(ctx, "regex range a-z miss", regex_is_match_cstr("[a-z]", "X"), 0)
    let _ = assert_eq(ctx, "regex range 0-9 hit", regex_is_match_cstr("[0-9]", "5"), 1)
    let _ = assert_eq(ctx, "regex range 0-9 miss", regex_is_match_cstr("[0-9]", "a"), 0)
    let _ = assert_eq(ctx, "regex range A-Z hit", regex_is_match_cstr("[A-Z]", "M"), 1)
    let _ = assert_eq(ctx, "regex range multi", regex_is_match_cstr("[a-zA-Z0-9]", "Z"), 1)

    // negated class with codepoint
    let _ = assert_eq(ctx, "regex nclass utf8 hit", regex_is_match_cstr("[^a-z]", "中"), 1)
    let _ = assert_eq(ctx, "regex nclass utf8 miss", regex_is_match_cstr("[^a-z]", "x"), 0)

    // quantifier on utf8 chars
    let _ = assert_eq(ctx, "regex utf8 plus", regex_is_match_cstr("中+", "中中中"), 1)
    let _ = assert_eq(ctx, "regex utf8 star", regex_is_match_cstr("中*x", "中中x"), 1)

    // mixed ascii and utf8
    let _ = assert_eq(ctx, "regex utf8 mixed", regex_is_match_cstr("a.b", "a中b"), 1)
    let _ = assert_eq(ctx, "regex utf8 mixed miss", regex_is_match_cstr("a.b", "ab"), 0)

    0
}

def test_regex(ctx: i64): i64 = {
    let _ = test_regex_parse(ctx)
    let _ = test_regex_match(ctx)
    let _ = test_regex_utf8(ctx)
    let _ = test_regex_match_utf8(ctx)
    0
}
