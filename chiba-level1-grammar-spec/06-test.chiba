namespace lexer.spec.operators

def operators(a: i64, b: i64, flags: i64): i64 = {
    let arithmetic = a + b - a * b / 2 % 3
    let compare = a == b || a != b && a <= b && a >= b && a < b && a > b
    let bits = (flags & 0xff) | 0b10 ^ (1 << 3) >> 1
    let unary = -a + !compare as i64
    let ptr_value = ptr.*
    cell := a := b
    return arithmetic |> step(_) |> finish()
}
