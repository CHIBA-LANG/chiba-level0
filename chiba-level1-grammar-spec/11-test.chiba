namespace lexer.spec.records

def records(base: Point): Point = {
    let x = 1
    let y = 2
    let literal = { x, y, name: "point" }
    let multi = {
        x: 1,
        y: 2,
    }
    let update = {base | y: 3, z: 4}
    let update_multi = {base |
        x: literal.x,
        y: multi.y,
    }
    return update
}
