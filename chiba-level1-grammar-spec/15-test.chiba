namespace lexer.spec.control

def control(n: i64): i64 = {
    if n == 0 {
        return 0
    } else if let Some(x) = next(n) {
        return x
    } else if n < 0 {
        return -n
    } else {
        for :outer n > 0 {
            for {
                if done() {
                    break :outer
                } else {
                    continue :outer
                }
            }
        }
    }
    return n
}
