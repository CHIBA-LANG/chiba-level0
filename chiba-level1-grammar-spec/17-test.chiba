namespace lexer.spec.defs

type UserId = i64

data Option[T] {
    Some(T)
    None
}

union Bits {
    u32v: u32,
    f32v: f32,
}

def pi: f32 = 3.1415926

private 
def 
helper(
    x: i64
): 
i64 = {
    return x +
     1
}

def Vec2.norm(self): f32 = {
    return sqrt(self.x * self.x + self.y * self.y)
}
