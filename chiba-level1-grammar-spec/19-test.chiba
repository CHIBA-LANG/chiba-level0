namespace lexer.spec.extern.asm

extern "c" def puts(msg: cstr): i32
extern "cbx" def cbx_entry(x: i64): i64

def low_level(ptr: Ptr[u8], idx: i64): i64 = unsafe {
    let loaded = ptr.*
    let v = asm (ptr: rdi, idx: rsi) : (rax) => {
        "mov rax, [rdi + rsi*8]"
        "xor rax, rax"
    }
    return v
}
