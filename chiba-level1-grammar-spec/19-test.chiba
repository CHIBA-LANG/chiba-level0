namespace lexer.spec.extern.asm

def puts(msg: cstr): i32 = extern "c"
def cbx_entry(x: i64): i64 = extern "cbx"

def low_level(ptr: Ptr[u8], idx: i64): i64 = unsafe {
    let loaded : u8 = ptr.*
    let v = asm (ptr: rdi, idx: rsi) : (rax) => {
        "mov rax, [rdi + rsi*8]"
        "xor rax, rax"
    }
    return v
}
