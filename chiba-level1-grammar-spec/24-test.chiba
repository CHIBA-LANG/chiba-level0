namespace lexer.spec.everything.smoke

#[derive(
    Debug, 
    Clone
    )
    ]
data Smoke[T] {
    Smoke(value: T, tag: 
    :ok)
}

def smoke[T](input: T): i64 = {
    let record = { input, status: :ok }
    let updated = {record | status: :done}
    let answer = reset {
        match Some(updated) {
            whole @ Some(v) if v.status == :done => shift k { k(42) }
            None => 0
            _ => 1
        }
    }
    return answer |> finish(_)
}
