/// Pattern elaboration pass.
namespace compiler.semantic.pattern

use compiler.semantic.alpha.*

/// Elaborated pattern identifier.
type PatternId {
    index: usize,
}

/// Pattern facts needed by type inference.
type PatternFacts {
    patterns: Array[PatternId],
}

/// Elaborate parameter, `let`, and match patterns after alpha conversion.
def elaborate_patterns(module: AlphaModule): PatternFacts =
    PatternFacts(Vec[PatternId].new().freeze())
