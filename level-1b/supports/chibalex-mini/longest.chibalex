#![CHIBALEX]

{
    namespace level1b.chibalexmini.longest
    use metalstd.str.*
}

@ws = $WS+
@ident = $XID_START $XID_CONTINUE*

tokens :-
    @ws       ;
    "=="      { EqEq }
    "="       { Eq }
    "if"      { KwIf }
    @ident    { Ident(s) }

{
    data Token {
        Ident(Str),
        KwIf,
        EqEq,
        Eq,
        LexError(i64),
        Eof,
    }
}
