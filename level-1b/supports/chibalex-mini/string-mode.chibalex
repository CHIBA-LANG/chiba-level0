#![CHIBALEX]

{
    namespace level1b.chibalexmini.stringmode
    use metalstd.str.*
}

mode CODE
mode STRING

@ws = $WS+
@chunk = [^"]+

tokens CODE :-
    @ws       ;
    "\""      { StringStart } -> STRING

tokens STRING :-
    @chunk    { StringChunk(s) }
    "\""      { StringEnd } -> CODE

{
    data Token {
        StringChunk(Str),
        StringStart,
        StringEnd,
        LexError(i64),
        Eof,
    }
}
