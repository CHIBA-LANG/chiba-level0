/// C11 fixture for tailcall backend lowering.
namespace pre_c11.tailcall_core

/// Tail-recursive countdown should lower to a tailcall site.
def countdown(n: i64): i64 = {
    if n == 0 {
        return 0
    } else {
        return countdown(n - 1)
    }
}

/// Entry point for the tailcall smoke.
def run_tailcall(): i64 = countdown(4)
