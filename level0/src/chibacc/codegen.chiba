namespace chibacc.codegen
use metalstd.mem.*
use metalstd.str.*
use metalstd.vec.*
use chibacc.ast.*
use chibacc.ir.*

// M2 executable source generator for ordinary rules.

def emit_indent(out: Str, level: i64): i64 =
    if level <= 0 { 0 }
    else {
        let _ = str_push_cstr(out, "    ")
        emit_indent(out, level - 1)
    }

def emit_line_cstr(out: Str, level: i64, text: cstr): i64 = {
    let _ = emit_indent(out, level)
    let _ = str_push_cstr(out, text.ptr)
    let _ = str_push(out, 10)
    0
}

def emit_i64(out: Str, n: i64): i64 = str_append_i64(out, n)

def emit_escaped_str_lit(out: Str, s: Str, i: i64): i64 =
    if i >= s.len { 0 }
    else {
        let b = load8(s.ptr, i)
        let _ = if b == 34 { str_push_cstr(out, "\\\"") }
                else if b == 92 { str_push_cstr(out, "\\\\") }
                else if b == 10 { str_push_cstr(out, "\\n") }
                else if b == 9 { str_push_cstr(out, "\\t") }
                else if b == 13 { str_push_cstr(out, "\\r") }
                else { str_push(out, b) }
        emit_escaped_str_lit(out, s, i + 1)
    }

def emit_str_expr(out: Str, s: Str): i64 = {
    if s.len == 0 { str_push_cstr(out, "str_empty()") }
    else {
        let _ = str_push_cstr(out, "mk_str(\"")
        let _ = emit_escaped_str_lit(out, s, 0)
        let _ = str_push_cstr(out, "\", ")
        let _ = emit_i64(out, s.len)
        let _ = str_push(out, 41)
        0
    }
}

def ensure_block_trailing_nl(out: Str): i64 = {
    if out.len == 0 { 0 }
    else if load8(out.ptr, out.len - 1) == 10 { 0 }
    else { str_push(out, 10) }
}

def emit_raw_block(out: Str, block: Str): i64 = {
    let _ = if block.len > 0 { str_append(out, block) } else { 0 }
    ensure_block_trailing_nl(out)
}

def is_token_name(name: Str): i64 =
    if name.len <= 0 { 0 }
    else {
        let ch = load8(name.ptr, 0)
        if ch >= 65 && ch <= 90 { 1 } else { 0 }
    }

// ── Token name collection & lexer namespace derivation ──

def collect_token_names(ir: GrammarIr): Vec = {
    let names = vec_new()
    let _ = vec_push(names, mk_str("Eof", 3) as i64)
    collect_token_names_rules(ir_rules(ir), names)
    names
}

// Collect token names that appear with a label binding (e.g. n:IntLit).
// These tokens carry a payload that needs to be extracted in match_token.
def collect_bound_token_names(ir: GrammarIr): Vec = {
    let names = vec_new()
    collect_bound_token_names_rules(ir_rules(ir), names)
    names
}

def collect_bound_token_names_rules(rules: Vec, names: Vec): i64 =
    collect_bound_token_names_rules_loop(rules, 0, names)

def collect_bound_token_names_rules_loop(rules: Vec, i: i64, names: Vec): i64 =
    if i >= vec_len(rules) { 0 }
    else {
        let rule = vec_get(rules, i) as IrRule
        let _ = collect_bound_token_names_body(ir_rule_body(rule), names)
        collect_bound_token_names_rules_loop(rules, i + 1, names)
    }

def collect_bound_token_names_body(body: IrRuleBody, names: Vec): i64 =
    match body {
        IrBodyAlts(alts) => collect_bound_token_names_alts(alts, names)
        IrBodyPratt(pr) => collect_bound_token_names_pratt(pr, names)
    }

def collect_bound_token_names_alts(alts: Vec, names: Vec): i64 =
    collect_bound_token_names_alts_loop(alts, 0, names)

def collect_bound_token_names_alts_loop(alts: Vec, i: i64, names: Vec): i64 =
    if i >= vec_len(alts) { 0 }
    else {
        let alt = vec_get(alts, i) as IrAlt
        match alt {
            IrAlt(items, _) => {
                let _ = collect_bound_token_names_items(items, names)
                0
            }
        }
        collect_bound_token_names_alts_loop(alts, i + 1, names)
    }

def collect_bound_token_names_pratt(pr: IrPrattRule, names: Vec): i64 =
    match pr {
        IrPrattRule(prefixes, infixes, postfixes) => {
            let _ = collect_bound_token_names_alts(pratt_prefix_alts(prefixes), names)
            let _ = collect_bound_token_names_alts(pratt_infix_alts(infixes), names)
            collect_bound_token_names_alts(pratt_postfix_alts(postfixes), names)
        }
    }

def collect_bound_token_names_items(items: Vec, names: Vec): i64 =
    collect_bound_token_names_items_loop(items, 0, names)

def collect_bound_token_names_items_loop(items: Vec, i: i64, names: Vec): i64 =
    if i >= vec_len(items) { 0 }
    else {
        let item = vec_get(items, i) as IrItem
        match item {
            IrItem(label, atom, _) => {
                if label.len > 0 {
                    let _ = collect_token_names_atom(atom, names)
                    0
                } else { 0 }
            }
        }
        collect_bound_token_names_items_loop(items, i + 1, names)
    }

def collect_token_names_rules(rules: Vec, names: Vec): i64 =
    collect_token_names_rules_loop(rules, 0, names)

def collect_token_names_rules_loop(rules: Vec, i: i64, names: Vec): i64 =
    if i >= vec_len(rules) { 0 }
    else {
        let rule = vec_get(rules, i) as IrRule
        let _ = collect_token_names_body(ir_rule_body(rule), names)
        collect_token_names_rules_loop(rules, i + 1, names)
    }

def collect_token_names_body(body: IrRuleBody, names: Vec): i64 =
    match body {
        IrBodyAlts(alts) => collect_token_names_alts(alts, names)
        IrBodyPratt(pr) => collect_token_names_pratt(pr, names)
    }

def collect_token_names_alts(alts: Vec, names: Vec): i64 =
    collect_token_names_alts_loop(alts, 0, names)

def collect_token_names_alts_loop(alts: Vec, i: i64, names: Vec): i64 =
    if i >= vec_len(alts) { 0 }
    else {
        let alt = vec_get(alts, i) as IrAlt
        match alt {
            IrAlt(items, _) => {
                let _ = collect_token_names_items(items, names)
                0
            }
        }
        collect_token_names_alts_loop(alts, i + 1, names)
    }

def collect_token_names_pratt(pr: IrPrattRule, names: Vec): i64 =
    match pr {
        IrPrattRule(prefixes, infixes, postfixes) => {
            let _ = collect_token_names_alts(pratt_prefix_alts(prefixes), names)
            let _ = collect_token_names_alts(pratt_infix_alts(infixes), names)
            collect_token_names_alts(pratt_postfix_alts(postfixes), names)
        }
    }

def pratt_prefix_alts(blocks: Vec): Vec = pratt_prefix_alts_loop(blocks, 0, vec_new())

def pratt_prefix_alts_loop(blocks: Vec, i: i64, acc: Vec): Vec =
    if i >= vec_len(blocks) { acc }
    else {
        let blk = vec_get(blocks, i) as IrPrefixBlock
        match blk {
            IrPrefixBlock(_, arms) => { let _ = vec_append(acc, arms); pratt_prefix_alts_loop(blocks, i + 1, acc) }
        }
    }

def pratt_infix_alts(blocks: Vec): Vec = pratt_infix_alts_loop(blocks, 0, vec_new())

def pratt_infix_alts_loop(blocks: Vec, i: i64, acc: Vec): Vec =
    if i >= vec_len(blocks) { acc }
    else {
        let blk = vec_get(blocks, i) as IrInfixBlock
        match blk {
            IrInfixBlock(_, _, arms) => { let _ = vec_append(acc, arms); pratt_infix_alts_loop(blocks, i + 1, acc) }
        }
    }

def pratt_postfix_alts(blocks: Vec): Vec = pratt_postfix_alts_loop(blocks, 0, vec_new())

def pratt_postfix_alts_loop(blocks: Vec, i: i64, acc: Vec): Vec =
    if i >= vec_len(blocks) { acc }
    else {
        let blk = vec_get(blocks, i) as IrPostfixBlock
        match blk {
            IrPostfixBlock(_, arms) => { let _ = vec_append(acc, arms); pratt_postfix_alts_loop(blocks, i + 1, acc) }
        }
    }

def collect_token_names_items(items: Vec, names: Vec): i64 =
    collect_token_names_items_loop(items, 0, names)

def collect_token_names_items_loop(items: Vec, i: i64, names: Vec): i64 =
    if i >= vec_len(items) { 0 }
    else {
        let item = vec_get(items, i) as IrItem
        match item {
            IrItem(_, atom, _) => { let _ = collect_token_names_atom(atom, names); 0 }
        }
        collect_token_names_items_loop(items, i + 1, names)
    }

def collect_token_names_atom(atom: IrAtom, names: Vec): i64 =
    match atom {
        IrAtomRef(name) => {
            if is_token_name(name) != 0 { add_token_name_if_new(names, name) }
            else { 0 }
        }
        _ => 0
    }

def add_token_name_if_new(names: Vec, name: Str): i64 =
    if token_name_in_vec(names, name, 0) != 0 { 0 }
    else { vec_push(names, name as i64) }

def token_name_in_vec(names: Vec, name: Str, i: i64): i64 =
    if i >= vec_len(names) { 0 }
    else {
        let existing = vec_get(names, i) as Str
        if (existing as i64) != 0 && streq(existing, name) != 0 { 1 }
        else { token_name_in_vec(names, name, i + 1) }
    }

def derive_lexer_use_from_header(header: Str): Str = {
    let ns = find_namespace_in_header(header, 0)
    if ns.len == 0 { str_empty() }
    else { make_lexer_use(ns) }
}

def str_starts_with_at(s: Str, offset: i64, prefix: Str): i64 =
    str_starts_with_at_loop(s, offset, prefix, 0)

def str_starts_with_at_loop(s: Str, offset: i64, prefix: Str, j: i64): i64 =
    if j >= prefix.len { 1 }
    else if offset + j >= s.len { 0 }
    else if load8(s.ptr, offset + j) != load8(prefix.ptr, j) { 0 }
    else { str_starts_with_at_loop(s, offset, prefix, j + 1) }

def find_namespace_in_header(header: Str, i: i64): Str =
    if i >= header.len { str_empty() }
    else if str_starts_with_at(header, i, mk_str("namespace ", 10)) != 0 {
        extract_namespace_name(header, i + 10)
    }
    else { find_namespace_in_header(header, i + 1) }

def extract_namespace_name(header: Str, start: i64): Str =
    extract_namespace_name_len(header, start, start)

def extract_namespace_name_len(header: Str, start: i64, pos: i64): Str =
    if pos >= header.len { mk_str(header.ptr + start, pos - start) }
    else {
        let ch = load8(header.ptr, pos)
        if ch == 10 || ch == 32 || ch == 13 || ch == 9 || ch == 123 {
            mk_str(header.ptr + start, pos - start)
        }
        else { extract_namespace_name_len(header, start, pos + 1) }
    }

def make_lexer_use(parser_ns: Str): Str = {
    let out = str_new()
    let _ = str_push_cstr(out, "use ")
    let _ = replace_parser_with_lexer(out, parser_ns)
    let _ = str_push_cstr(out, ".*")
    out
}

def replace_parser_with_lexer(out: Str, ns: Str): i64 =
    replace_parser_with_lexer_loop(out, ns, 0, 0)

def replace_parser_with_lexer_loop(out: Str, ns: Str, i: i64, matched: i64): i64 =
    if i >= ns.len {
        if matched == 0 { str_append(out, ns) }
        else { 0 }
    }
    else if str_starts_with_at(ns, i, mk_str("parser", 6)) != 0 && matched == 0 {
        let _ = str_push_cstr(out, "lexer")
        replace_parser_with_lexer_loop(out, ns, i + 6, 1)
    }
    else {
        let _ = str_push(out, load8(ns.ptr, i))
        replace_parser_with_lexer_loop(out, ns, i + 1, matched)
    }

def find_rule_index(rules: Vec, name: Str): i64 =
    find_rule_index_loop(rules, name, 0)

def find_rule_index_loop(rules: Vec, name: Str, i: i64): i64 =
    if (name as i64) == 0 { 0 - 1 }
    else if i >= vec_len(rules) { 0 - 1 }
    else {
        let rule = vec_get(rules, i) as IrRule
        let rule_name = ir_rule_name(rule)
        if (rule_name as i64) != 0 && streq(rule_name, name) != 0 { i }
        else { find_rule_index_loop(rules, name, i + 1) }
    }

def is_repeat_quant(q: IrQuantifier): i64 =
    match q {
        IrQZeroOrMore => 1
        IrQOneOrMore => 1
        IrQRange(_, _) => 1
        _ => 0
    }

def item_is_required_rule_ref(item: IrItem): i64 =
    match item {
        IrItem(_, IrAtomRef(name), IrQOne) => {
            if streq(name, mk_str("Eof", 3)) != 0 { 0 }
            else if is_token_name(name) != 0 { 0 }
            else { 1 }
        }
        _ => 0
    }

def item_sync_token_name(item: IrItem): Str =
    match item {
        IrItem(_, IrAtomRef(name), _) => {
            if streq(name, mk_str("Eof", 3)) != 0 { name }
            else if is_token_name(name) != 0 { name }
            else { str_empty() }
        }
        _ => str_empty()
    }

def find_sync_token_name(items: Vec, i: i64): Str =
    if i >= vec_len(items) { str_empty() }
    else {
        let item = vec_get(items, i) as IrItem
        let name = item_sync_token_name(item)
        if name.len > 0 { name }
        else { find_sync_token_name(items, i + 1) }
    }

def emit_value_params(out: Str, count: i64, i: i64): i64 =
    if i >= count { 0 }
    else {
        let _ = str_push_cstr(out, ", __v")
        let _ = emit_i64(out, i)
        let _ = str_push_cstr(out, ": i64")
        emit_value_params(out, count, i + 1)
    }

def emit_value_args(out: Str, count: i64, i: i64): i64 =
    if i >= count { 0 }
    else {
        let _ = str_push_cstr(out, ", __v")
        let _ = emit_i64(out, i)
        emit_value_args(out, count, i + 1)
    }

def emit_rule_fn_name(out: Str, rule_i: i64): i64 = {
    let _ = str_push_cstr(out, "parse_rule_")
    emit_i64(out, rule_i)
}

def emit_alt_fn_name(out: Str, rule_i: i64, alt_i: i64): i64 = {
    let _ = emit_rule_fn_name(out, rule_i)
    let _ = str_push_cstr(out, "_alt_")
    emit_i64(out, alt_i)
}

def emit_step_fn_name(out: Str, rule_i: i64, alt_i: i64, step_i: i64): i64 = {
    let _ = emit_alt_fn_name(out, rule_i, alt_i)
    let _ = str_push_cstr(out, "_step_")
    emit_i64(out, step_i)
}

def emit_item_fn_name(out: Str, rule_i: i64, alt_i: i64, item_i: i64): i64 = {
    let _ = emit_alt_fn_name(out, rule_i, alt_i)
    let _ = str_push_cstr(out, "_item_")
    emit_i64(out, item_i)
}

def emit_many_fn_name(out: Str, rule_i: i64, alt_i: i64, item_i: i64): i64 = {
    let _ = emit_item_fn_name(out, rule_i, alt_i, item_i)
    let _ = str_push_cstr(out, "_many")
    0
}

def emit_rule_bp_fn_name(out: Str, rule_i: i64): i64 = {
    let _ = emit_rule_fn_name(out, rule_i)
    let _ = str_push_cstr(out, "_bp")
    0
}

def emit_pratt_block_fn_name(out: Str, rule_i: i64, kind: cstr, block_i: i64): i64 = {
    let _ = emit_rule_fn_name(out, rule_i)
    let _ = str_push(out, 95)
    let _ = str_push_cstr(out, kind.ptr)
    let _ = str_push_cstr(out, "_block_")
    emit_i64(out, block_i)
}

def emit_pratt_arm_fn_name(out: Str, rule_i: i64, kind: cstr, block_i: i64, arm_i: i64): i64 = {
    let _ = emit_pratt_block_fn_name(out, rule_i, kind, block_i)
    let _ = str_push_cstr(out, "_arm_")
    emit_i64(out, arm_i)
}

def emit_pratt_block_case_fn_name(out: Str, rule_i: i64, kind: cstr, block_i: i64, arm_i: i64): i64 = {
    let _ = emit_pratt_block_fn_name(out, rule_i, kind, block_i)
    let _ = str_push_cstr(out, "_case_")
    emit_i64(out, arm_i)
}

def emit_pratt_arm_step_fn_name(out: Str, rule_i: i64, kind: cstr, block_i: i64, arm_i: i64, step_i: i64): i64 = {
    let _ = emit_pratt_arm_fn_name(out, rule_i, kind, block_i, arm_i)
    let _ = str_push_cstr(out, "_step_")
    emit_i64(out, step_i)
}

def emit_pratt_arm_item_fn_name(out: Str, rule_i: i64, kind: cstr, block_i: i64, arm_i: i64, item_i: i64): i64 = {
    let _ = emit_pratt_arm_fn_name(out, rule_i, kind, block_i, arm_i)
    let _ = str_push_cstr(out, "_item_")
    emit_i64(out, item_i)
}

def emit_pratt_many_fn_name(out: Str, rule_i: i64, kind: cstr, block_i: i64, arm_i: i64, item_i: i64): i64 = {
    let _ = emit_pratt_arm_item_fn_name(out, rule_i, kind, block_i, arm_i, item_i)
    let _ = str_push_cstr(out, "_many")
    0
}

def emit_pratt_prefix_dispatch_fn_name(out: Str, rule_i: i64): i64 = {
    let _ = emit_rule_fn_name(out, rule_i)
    let _ = str_push_cstr(out, "_prefix")
    0
}

def emit_pratt_prefix_dispatch_case_fn_name(out: Str, rule_i: i64, block_i: i64): i64 = {
    let _ = emit_pratt_prefix_dispatch_fn_name(out, rule_i)
    let _ = str_push_cstr(out, "_case_")
    emit_i64(out, block_i)
}

def emit_pratt_postfix_dispatch_fn_name(out: Str, rule_i: i64): i64 = {
    let _ = emit_rule_fn_name(out, rule_i)
    let _ = str_push_cstr(out, "_postfix")
    0
}

def emit_pratt_postfix_dispatch_case_fn_name(out: Str, rule_i: i64, block_i: i64): i64 = {
    let _ = emit_pratt_postfix_dispatch_fn_name(out, rule_i)
    let _ = str_push_cstr(out, "_case_")
    emit_i64(out, block_i)
}

def emit_pratt_infix_dispatch_fn_name(out: Str, rule_i: i64): i64 = {
    let _ = emit_rule_fn_name(out, rule_i)
    let _ = str_push_cstr(out, "_infix")
    0
}

def emit_pratt_infix_dispatch_case_fn_name(out: Str, rule_i: i64, block_i: i64): i64 = {
    let _ = emit_pratt_infix_dispatch_fn_name(out, rule_i)
    let _ = str_push_cstr(out, "_case_")
    emit_i64(out, block_i)
}

def emit_pratt_suffix_fn_name(out: Str, rule_i: i64): i64 = {
    let _ = emit_rule_fn_name(out, rule_i)
    let _ = str_push_cstr(out, "_suffix")
    0
}

def emit_rule_dispatch_fn_name(out: Str, rule_i: i64, alt_i: i64): i64 = {
    let _ = emit_rule_fn_name(out, rule_i)
    let _ = str_push_cstr(out, "_dispatch_")
    emit_i64(out, alt_i)
}

def emit_rule_parse_call(out: Str, rules: Vec, name: Str): i64 = {
    let idx = find_rule_index(rules, name)
    if idx < 0 { str_push_cstr(out, "MatchFail(pos)") }
    else {
        let _ = emit_rule_fn_name(out, idx)
        let _ = str_push_cstr(out, "(tokens, pos)")
        0
    }
}

def emit_atom_parse_expr(out: Str, rules: Vec, atom: IrAtom): i64 =
    match atom {
        IrAtomRef(name) => {
            if (name as i64) == 0 { str_push_cstr(out, "MatchFail(pos)") }
            else if streq(name, mk_str("Eof", 3)) != 0 {
                str_push_cstr(out, "match_eof(tokens, pos)")
            }
            else if is_token_name(name) != 0 {
                let _ = str_push_cstr(out, "match_token_")
                let _ = str_append(out, name)
                let _ = str_push_cstr(out, "(tokens, pos)")
                0
            }
            else {
                emit_rule_parse_call(out, rules, name)
            }
        }
        IrAtomPredicate(_) => str_push_cstr(out, "MatchFail(pos)")
        IrAtomLookAnd(_) => str_push_cstr(out, "MatchFail(pos)")
        IrAtomLookNot(_) => str_push_cstr(out, "MatchFail(pos)")
    }

def emit_action_piece(out: Str, action: Str, i: i64): i64 =
    if i >= action.len { 0 }
    else if i + 3 < action.len && load8(action.ptr, i) == 36 && load8(action.ptr, i + 1) == 108 && load8(action.ptr, i + 2) == 104 && load8(action.ptr, i + 3) == 115 {
        let _ = str_push_cstr(out, "__lhs_ast")
        emit_action_piece(out, action, i + 4)
    }
    else {
        let _ = str_push(out, load8(action.ptr, i))
        emit_action_piece(out, action, i + 1)
    }

def emit_pratt_atom_parse_expr(out: Str, rules: Vec, rule_i: i64, rule_name: Str, self_bp: i64, atom: IrAtom): i64 =
    match atom {
        IrAtomRef(name) => {
            if (name as i64) == 0 { str_push_cstr(out, "MatchFail(pos)") }
            else if (rule_name as i64) != 0 && streq(name, rule_name) != 0 {
                let _ = emit_rule_bp_fn_name(out, rule_i)
                let _ = str_push_cstr(out, "(tokens, pos, ")
                let _ = emit_i64(out, self_bp)
                let _ = str_push(out, 41)
                0
            }
            else {
                emit_atom_parse_expr(out, rules, atom)
            }
        }
        _ => emit_atom_parse_expr(out, rules, atom)
    }

def emit_label_binding(out: Str, item: IrItem, item_i: i64): i64 =
    match item {
        IrItem(label, atom, q) => {
            if label.len == 0 { 0 }
            else {
                let _ = emit_indent(out, 1)
                let _ = str_push_cstr(out, "let ")
                let _ = str_append(out, label)
                let _ = if q == IrQOptional { str_push_cstr(out, ": Option[i64] = __v") }
                        else if is_repeat_quant(q) != 0 { str_push_cstr(out, ": Vec = __v") }
                        else {
                            match atom {
                                IrAtomRef(name) => {
                                    if is_token_name(name) != 0 { str_push_cstr(out, ": Str = __v") }
                                    else { str_push_cstr(out, ": AST = __v") }
                                }
                                _ => str_push_cstr(out, " = __v")
                            }
                        }
                let _ = emit_i64(out, item_i)
                let _ = if q == IrQOptional { str_push_cstr(out, " as Option[i64]") }
                        else if is_repeat_quant(q) != 0 { str_push_cstr(out, " as Vec") }
                        else {
                            match atom {
                                IrAtomRef(name) => {
                                    if is_token_name(name) != 0 { str_push_cstr(out, " as Str") }
                                    else { str_push_cstr(out, " as AST") }
                                }
                                _ => 0
                            }
                        }
                let _ = str_push(out, 10)
                0
            }
        }
    }

def emit_label_bindings(out: Str, items: Vec, i: i64): i64 =
    if i >= vec_len(items) { 0 }
    else {
        let item = vec_get(items, i) as IrItem
        let _ = emit_label_binding(out, item, i)
        emit_label_bindings(out, items, i + 1)
    }

def emit_label_bindings_prefix(out: Str, items: Vec, i: i64, stop: i64): i64 =
    if i >= stop || i >= vec_len(items) { 0 }
    else {
        let item = vec_get(items, i) as IrItem
        let _ = emit_label_binding(out, item, i)
        emit_label_bindings_prefix(out, items, i + 1, stop)
    }

def predicate_expr_start(raw: Str): i64 =
    if raw.len > 0 && load8(raw.ptr, 0) == 63 { 1 } else { 0 }

def emit_predicate_expr(out: Str, raw: Str): i64 =
    emit_action_piece(out, raw, predicate_expr_start(raw))

def emit_lhs_param(out: Str, has_lhs: i64): i64 =
    if has_lhs != 0 { str_push_cstr(out, ", __lhs: i64") } else { 0 }

def emit_lhs_arg(out: Str, has_lhs: i64): i64 =
    if has_lhs != 0 { str_push_cstr(out, ", __lhs") } else { 0 }

def emit_pratt_done_fn(out: Str, rule_i: i64, kind: cstr, block_i: i64, arm_i: i64, alt: IrAlt, has_lhs: i64): i64 =
    match alt {
        IrAlt(items, action) => {
            let _ = emit_indent(out, 0)
            let _ = str_push_cstr(out, "def ")
            let _ = emit_pratt_arm_step_fn_name(out, rule_i, kind, block_i, arm_i, vec_len(items))
            let _ = str_push_cstr(out, "(tokens: Vec, pos: i64, recovered: i64")
            let _ = emit_lhs_param(out, has_lhs)
            let _ = emit_value_params(out, vec_len(items), 0)
            let _ = str_push_cstr(out, "): MatchResult = {\n")
            let _ = if has_lhs != 0 {
                let _ = emit_line_cstr(out, 1, c"let __lhs_ast: AST = __lhs as AST")
                0
            } else { 0 }
            let _ = emit_label_bindings(out, items, 0)
            let _ = emit_indent(out, 1)
            let _ = str_push_cstr(out, "MatchOK((")
            let _ = emit_action_piece(out, action, 0)
            let _ = str_push_cstr(out, ") as i64, pos, recovered)\n")
            let _ = emit_line_cstr(out, 0, c"}")
            let _ = str_push(out, 10)
            0
        }
    }

def emit_pratt_step_fn(out: Str, rules: Vec, rule_i: i64, rule_name: Str, kind: cstr, block_i: i64, arm_i: i64, alt: IrAlt, step_i: i64, self_bp: i64, has_lhs: i64): i64 =
    match alt {
        IrAlt(items, _) => {
            if step_i >= vec_len(items) { emit_pratt_done_fn(out, rule_i, kind, block_i, arm_i, alt, has_lhs) }
            else {
                let item = vec_get(items, step_i) as IrItem
                match item {
                    IrItem(_, IrAtomPredicate(raw), IrQOne) => {
                        let _ = emit_indent(out, 0)
                        let _ = str_push_cstr(out, "def ")
                        let _ = emit_pratt_arm_step_fn_name(out, rule_i, kind, block_i, arm_i, step_i)
                        let _ = str_push_cstr(out, "(tokens: Vec, pos: i64, recovered: i64")
                        let _ = emit_lhs_param(out, has_lhs)
                        let _ = emit_value_params(out, step_i, 0)
                        let _ = str_push_cstr(out, "): MatchResult = {\n")
                        let _ = if has_lhs != 0 {
                            let _ = emit_line_cstr(out, 1, c"let __lhs_ast: AST = __lhs as AST")
                            0
                        } else { 0 }
                        let _ = emit_label_bindings_prefix(out, items, 0, step_i)
                        let _ = emit_indent(out, 1)
                        let _ = str_push_cstr(out, "if ")
                        let _ = emit_predicate_expr(out, raw)
                        let _ = str_push_cstr(out, " != 0 { ")
                        let _ = emit_pratt_arm_step_fn_name(out, rule_i, kind, block_i, arm_i, step_i + 1)
                        let _ = str_push_cstr(out, "(tokens, pos, recovered")
                        let _ = emit_lhs_arg(out, has_lhs)
                        let _ = emit_value_args(out, step_i, 0)
                        let _ = str_push_cstr(out, ", 1) } else { MatchFail(pos) }\n")
                        let _ = emit_line_cstr(out, 0, c"}")
                        let _ = str_push(out, 10)
                        emit_pratt_step_fn(out, rules, rule_i, rule_name, kind, block_i, arm_i, alt, step_i + 1, self_bp, has_lhs)
                    }
                    _ => {
                        let sync_name = if item_is_required_rule_ref(item) != 0 { find_sync_token_name(items, step_i + 1) } else { str_empty() }
                        let _ = emit_indent(out, 0)
                        let _ = str_push_cstr(out, "def ")
                        let _ = emit_pratt_arm_step_fn_name(out, rule_i, kind, block_i, arm_i, step_i)
                        let _ = str_push_cstr(out, "(tokens: Vec, pos: i64, recovered: i64")
                        let _ = emit_lhs_param(out, has_lhs)
                        let _ = emit_value_params(out, step_i, 0)
                        let _ = str_push_cstr(out, "): MatchResult =\n")
                        let _ = emit_indent(out, 1)
                        let _ = str_push_cstr(out, "match ")
                        let _ = emit_pratt_arm_item_fn_name(out, rule_i, kind, block_i, arm_i, step_i)
                        let _ = str_push_cstr(out, "(tokens, pos) {\n")
                        let _ = emit_indent(out, 2)
                        let _ = str_push_cstr(out, "MatchOK(__v")
                        let _ = emit_i64(out, step_i)
                        let _ = str_push_cstr(out, ", pos1, recovered1) => ")
                        let _ = emit_pratt_arm_step_fn_name(out, rule_i, kind, block_i, arm_i, step_i + 1)
                        let _ = str_push_cstr(out, "(tokens, pos1, recover_or(recovered, recovered1)")
                        let _ = emit_lhs_arg(out, has_lhs)
                        let _ = emit_value_args(out, step_i, 0)
                        let _ = str_push_cstr(out, ", __v")
                        let _ = emit_i64(out, step_i)
                        let _ = str_push_cstr(out, ")\n")
                        let _ = if sync_name.len > 0 {
                            let _ = emit_line_cstr(out, 2, c"MatchFail(fail_pos) => {")
                            let _ = emit_indent(out, 3)
                            let _ = str_push_cstr(out, "let recover_pos = find_token_position(tokens, fail_pos, ")
                            let _ = emit_str_expr(out, sync_name)
                            let _ = str_push_cstr(out, ")\n")
                            let _ = emit_line_cstr(out, 3, c"if recover_pos >= 0 {")
                            let _ = emit_indent(out, 4)
                            let _ = str_push_cstr(out, "match ")
                            let _ = emit_pratt_arm_step_fn_name(out, rule_i, kind, block_i, arm_i, step_i + 1)
                            let _ = str_push_cstr(out, "(tokens, recover_pos, recover_or(recovered, 1)")
                            let _ = emit_lhs_arg(out, has_lhs)
                            let _ = emit_value_args(out, step_i, 0)
                            let _ = str_push_cstr(out, ", 0")
                            let _ = str_push_cstr(out, ") {\n")
                            let _ = emit_line_cstr(out, 5, c"MatchOK(ast, pos2, recovered2) => MatchOK(ast, pos2, recovered2)")
                            let _ = emit_line_cstr(out, 5, c"MatchFail(fail_pos1) => MatchFail(fail_pos1)")
                            let _ = emit_line_cstr(out, 4, c"}")
                            let _ = emit_line_cstr(out, 3, c"}")
                            let _ = emit_line_cstr(out, 3, c"else { MatchFail(fail_pos) }")
                            let _ = emit_line_cstr(out, 2, c"}")
                            0
                        } else {
                            emit_line_cstr(out, 2, c"MatchFail(fail_pos) => MatchFail(fail_pos)")
                        }
                        let _ = emit_line_cstr(out, 1, c"}")
                        let _ = str_push(out, 10)
                        emit_pratt_step_fn(out, rules, rule_i, rule_name, kind, block_i, arm_i, alt, step_i + 1, self_bp, has_lhs)
                    }
                }
            }
        }
    }

def emit_pratt_optional_item_fn(out: Str, rules: Vec, rule_i: i64, rule_name: Str, kind: cstr, block_i: i64, arm_i: i64, item_i: i64, atom: IrAtom, self_bp: i64): i64 = {
    let _ = emit_indent(out, 0)
    let _ = str_push_cstr(out, "def ")
    let _ = emit_pratt_arm_item_fn_name(out, rule_i, kind, block_i, arm_i, item_i)
    let _ = str_push_cstr(out, "(tokens: Vec, pos: i64): MatchResult =\n")
    let _ = emit_indent(out, 1)
    let _ = str_push_cstr(out, "match ")
    let _ = emit_pratt_atom_parse_expr(out, rules, rule_i, rule_name, self_bp, atom)
    let _ = str_push_cstr(out, " {\n")
    let _ = emit_line_cstr(out, 2, c"MatchOK(v, pos1) => {")
    let _ = emit_line_cstr(out, 3, c"let some_v: Option[i64] = Some(v)")
    let _ = emit_line_cstr(out, 3, c"MatchOK(some_v as i64, pos1, recovered)")
    let _ = emit_line_cstr(out, 2, c"}")
    let _ = emit_line_cstr(out, 2, c"MatchFail(fail_pos) => {")
    let _ = emit_line_cstr(out, 3, c"if fail_pos > pos { MatchFail(fail_pos) }")
    let _ = emit_line_cstr(out, 3, c"else {")
    let _ = emit_line_cstr(out, 4, c"let none_v: Option[i64] = None")
    let _ = emit_line_cstr(out, 4, c"MatchOK(none_v as i64, pos, 0)")
    let _ = emit_line_cstr(out, 3, c"}")
    let _ = emit_line_cstr(out, 2, c"}")
    let _ = emit_line_cstr(out, 1, c"}")
    let _ = str_push(out, 10)
    0
}

def emit_pratt_many_helper_fn(out: Str, rules: Vec, rule_i: i64, rule_name: Str, kind: cstr, block_i: i64, arm_i: i64, item_i: i64, atom: IrAtom, min_count: i64, max_count: i64, self_bp: i64): i64 = {
    let _ = emit_indent(out, 0)
    let _ = str_push_cstr(out, "def ")
    let _ = emit_pratt_many_fn_name(out, rule_i, kind, block_i, arm_i, item_i)
    let _ = str_push_cstr(out, "(tokens: Vec, pos: i64, acc: Vec, count: i64, recovered: i64): MatchResult = {\n")
    let _ = if max_count >= 0 {
        let _ = emit_indent(out, 1)
        let _ = str_push_cstr(out, "if count >= ")
        let _ = emit_i64(out, max_count)
        let _ = str_push_cstr(out, " { MatchOK(acc as i64, pos, recovered) }\n")
        let _ = emit_indent(out, 1)
        let _ = str_push_cstr(out, "else {\n")
        let _ = emit_indent(out, 2)
        let _ = str_push_cstr(out, "match ")
        let _ = emit_pratt_atom_parse_expr(out, rules, rule_i, rule_name, self_bp, atom)
        let _ = str_push_cstr(out, " {\n")
        let _ = emit_line_cstr(out, 3, c"MatchOK(v, pos1, recovered1) => {")
        let _ = emit_line_cstr(out, 4, c"if pos1 == pos { MatchOK(acc as i64, pos, recover_or(recovered, recovered1)) }")
        let _ = emit_line_cstr(out, 4, c"else {")
        let _ = emit_line_cstr(out, 5, c"let _ = vec_push(acc, v)")
        let _ = emit_indent(out, 5)
        let _ = emit_pratt_many_fn_name(out, rule_i, kind, block_i, arm_i, item_i)
        let _ = str_push_cstr(out, "(tokens, pos1, acc, count + 1, recover_or(recovered, recovered1))\n")
        let _ = emit_line_cstr(out, 4, c"}")
        let _ = emit_line_cstr(out, 3, c"}")
        let _ = if min_count <= 0 {
                    let _ = emit_line_cstr(out, 3, c"MatchFail(fail_pos) => if fail_pos > pos { MatchFail(fail_pos) } else { MatchOK(acc as i64, pos, recovered) }")
                    0
                }
                else {
                    let _ = emit_indent(out, 3)
                    let _ = str_push_cstr(out, "MatchFail(fail_pos) => if fail_pos > pos { MatchFail(fail_pos) } else if count >= ")
                    let _ = emit_i64(out, min_count)
                    let _ = str_push_cstr(out, " { MatchOK(acc as i64, pos, recovered) } else { MatchFail(pos) }\n")
                    0
                }
        let _ = emit_line_cstr(out, 2, c"}")
        let _ = emit_line_cstr(out, 1, c"}")
        0
    } else {
        let _ = emit_indent(out, 1)
        let _ = str_push_cstr(out, "match ")
        let _ = emit_pratt_atom_parse_expr(out, rules, rule_i, rule_name, self_bp, atom)
        let _ = str_push_cstr(out, " {\n")
        let _ = emit_line_cstr(out, 2, c"MatchOK(v, pos1, recovered1) => {")
        let _ = emit_line_cstr(out, 3, c"if pos1 == pos { MatchOK(acc as i64, pos, recover_or(recovered, recovered1)) }")
        let _ = emit_line_cstr(out, 3, c"else {")
        let _ = emit_line_cstr(out, 4, c"let _ = vec_push(acc, v)")
        let _ = emit_indent(out, 4)
        let _ = emit_pratt_many_fn_name(out, rule_i, kind, block_i, arm_i, item_i)
        let _ = str_push_cstr(out, "(tokens, pos1, acc, count + 1, recover_or(recovered, recovered1))\n")
        let _ = emit_line_cstr(out, 3, c"}")
        let _ = emit_line_cstr(out, 2, c"}")
        let _ = if min_count <= 0 {
                    let _ = emit_line_cstr(out, 2, c"MatchFail(fail_pos) => if fail_pos > pos { MatchFail(fail_pos) } else { MatchOK(acc as i64, pos, recovered) }")
                    0
                }
                else {
                    let _ = emit_indent(out, 2)
                    let _ = str_push_cstr(out, "MatchFail(fail_pos) => if fail_pos > pos { MatchFail(fail_pos) } else if count >= ")
                    let _ = emit_i64(out, min_count)
                    let _ = str_push_cstr(out, " { MatchOK(acc as i64, pos, recovered) } else { MatchFail(pos) }\n")
                    0
                }
        let _ = emit_line_cstr(out, 1, c"}")
        0
    }
    let _ = emit_line_cstr(out, 0, c"}")
    let _ = str_push(out, 10)
    0
}

def emit_pratt_repeat_item_fn(out: Str, rules: Vec, rule_i: i64, rule_name: Str, kind: cstr, block_i: i64, arm_i: i64, item_i: i64, atom: IrAtom, min_count: i64, max_count: i64, self_bp: i64): i64 = {
    let _ = emit_pratt_many_helper_fn(out, rules, rule_i, rule_name, kind, block_i, arm_i, item_i, atom, min_count, max_count, self_bp)
    let _ = emit_indent(out, 0)
    let _ = str_push_cstr(out, "def ")
    let _ = emit_pratt_arm_item_fn_name(out, rule_i, kind, block_i, arm_i, item_i)
    let _ = str_push_cstr(out, "(tokens: Vec, pos: i64): MatchResult = ")
    let _ = emit_pratt_many_fn_name(out, rule_i, kind, block_i, arm_i, item_i)
    let _ = str_push_cstr(out, "(tokens, pos, vec_new(), 0, 0)\n\n")
    0
}

def emit_pratt_one_item_fn(out: Str, rules: Vec, rule_i: i64, rule_name: Str, kind: cstr, block_i: i64, arm_i: i64, item_i: i64, atom: IrAtom, self_bp: i64): i64 = {
    let _ = emit_indent(out, 0)
    let _ = str_push_cstr(out, "def ")
    let _ = emit_pratt_arm_item_fn_name(out, rule_i, kind, block_i, arm_i, item_i)
    let _ = str_push_cstr(out, "(tokens: Vec, pos: i64): MatchResult = ")
    let _ = emit_pratt_atom_parse_expr(out, rules, rule_i, rule_name, self_bp, atom)
    let _ = str_push_cstr(out, "\n\n")
    0
}

def pratt_item_self_bp(items: Vec, item_i: i64, item: IrItem, rule_name: Str, self_bp: i64, has_lhs: i64): i64 =
    if has_lhs != 0 { self_bp }
    else {
        match item {
            IrItem(_, IrAtomRef(name), IrQOne) => {
                let next_sync = find_sync_token_name(items, item_i + 1)
                if streq(name, rule_name) == 0 { self_bp }
                else if (next_sync as i64) != 0 && next_sync.len > 0 { 0 }
                else { self_bp }
            }
            _ => self_bp
        }
    }

def emit_pratt_item_fn(out: Str, rules: Vec, rule_i: i64, rule_name: Str, kind: cstr, block_i: i64, arm_i: i64, items: Vec, item_i: i64, item: IrItem, self_bp: i64, has_lhs: i64): i64 =
    match item {
        IrItem(_, atom, q) => {
            let item_self_bp = pratt_item_self_bp(items, item_i, item, rule_name, self_bp, has_lhs)
            match q {
                IrQOne => emit_pratt_one_item_fn(out, rules, rule_i, rule_name, kind, block_i, arm_i, item_i, atom, item_self_bp)
                IrQOptional => emit_pratt_optional_item_fn(out, rules, rule_i, rule_name, kind, block_i, arm_i, item_i, atom, item_self_bp)
                IrQZeroOrMore => emit_pratt_repeat_item_fn(out, rules, rule_i, rule_name, kind, block_i, arm_i, item_i, atom, 0, 0 - 1, item_self_bp)
                IrQOneOrMore => emit_pratt_repeat_item_fn(out, rules, rule_i, rule_name, kind, block_i, arm_i, item_i, atom, 1, 0 - 1, item_self_bp)
                IrQRange(lo, hi) => emit_pratt_repeat_item_fn(out, rules, rule_i, rule_name, kind, block_i, arm_i, item_i, atom, lo, hi, item_self_bp)
            }
        }
    }

def emit_pratt_item_fns(out: Str, rules: Vec, rule_i: i64, rule_name: Str, kind: cstr, block_i: i64, arm_i: i64, items: Vec, i: i64, self_bp: i64, has_lhs: i64): i64 =
    if i >= vec_len(items) { 0 }
    else {
        let item = vec_get(items, i) as IrItem
        let _ = emit_pratt_item_fn(out, rules, rule_i, rule_name, kind, block_i, arm_i, items, i, item, self_bp, has_lhs)
        emit_pratt_item_fns(out, rules, rule_i, rule_name, kind, block_i, arm_i, items, i + 1, self_bp, has_lhs)
    }

def emit_pratt_arm_fn(out: Str, rules: Vec, rule_i: i64, rule_name: Str, kind: cstr, block_i: i64, arm_i: i64, alt: IrAlt, self_bp: i64, has_lhs: i64): i64 =
    match alt {
        IrAlt(items, _) => {
            let _ = emit_pratt_item_fns(out, rules, rule_i, rule_name, kind, block_i, arm_i, items, 0, self_bp, has_lhs)
            let _ = emit_indent(out, 0)
            let _ = str_push_cstr(out, "def ")
            let _ = emit_pratt_arm_fn_name(out, rule_i, kind, block_i, arm_i)
            let _ = str_push_cstr(out, "(tokens: Vec, pos: i64")
            let _ = emit_lhs_param(out, has_lhs)
            let _ = str_push_cstr(out, "): MatchResult = ")
            let _ = emit_pratt_arm_step_fn_name(out, rule_i, kind, block_i, arm_i, 0)
            let _ = str_push_cstr(out, "(tokens, pos, 0")
            let _ = emit_lhs_arg(out, has_lhs)
            let _ = str_push_cstr(out, ")\n\n")
            emit_pratt_step_fn(out, rules, rule_i, rule_name, kind, block_i, arm_i, alt, 0, self_bp, has_lhs)
        }
    }

def emit_pratt_arm_fns(out: Str, rules: Vec, rule_i: i64, rule_name: Str, kind: cstr, block_i: i64, arms: Vec, arm_i: i64, self_bp: i64, has_lhs: i64): i64 =
    if arm_i >= vec_len(arms) { 0 }
    else {
        let alt = vec_get(arms, arm_i) as IrAlt
        let _ = emit_pratt_arm_fn(out, rules, rule_i, rule_name, kind, block_i, arm_i, alt, self_bp, has_lhs)
        emit_pratt_arm_fns(out, rules, rule_i, rule_name, kind, block_i, arms, arm_i + 1, self_bp, has_lhs)
    }

def emit_pratt_arm_dispatch_case_fns(out: Str, rule_i: i64, kind: cstr, block_i: i64, arms: Vec, arm_i: i64, has_lhs: i64): i64 =
    if arm_i >= vec_len(arms) { 0 }
    else {
        let _ = emit_indent(out, 0)
        let _ = str_push_cstr(out, "def ")
        let _ = emit_pratt_block_case_fn_name(out, rule_i, kind, block_i, arm_i)
        let _ = str_push_cstr(out, "(tokens: Vec, pos: i64")
        let _ = emit_lhs_param(out, has_lhs)
        let _ = str_push_cstr(out, "): MatchResult =\n")
        let _ = emit_indent(out, 1)
        let _ = str_push_cstr(out, "match ")
        let _ = emit_pratt_arm_fn_name(out, rule_i, kind, block_i, arm_i)
        let _ = str_push_cstr(out, "(tokens, pos")
        let _ = emit_lhs_arg(out, has_lhs)
        let _ = str_push_cstr(out, ") {\n")
        let _ = emit_line_cstr(out, 2, c"MatchOK(ast, pos1, recovered) => MatchOK(ast, pos1, recovered)")
        if arm_i + 1 >= vec_len(arms) {
            let _ = emit_line_cstr(out, 2, c"MatchFail(fail_pos) => MatchFail(fail_pos)")
        } else {
            let _ = emit_line_cstr(out, 2, c"MatchFail(fail_pos) =>")
            let _ = emit_line_cstr(out, 3, c"if fail_pos > pos { MatchFail(fail_pos) }")
            let _ = emit_line_cstr(out, 3, c"else {")
            let _ = emit_indent(out, 4)
            let _ = emit_pratt_block_case_fn_name(out, rule_i, kind, block_i, arm_i + 1)
            let _ = str_push_cstr(out, "(tokens, pos")
            let _ = emit_lhs_arg(out, has_lhs)
            let _ = str_push_cstr(out, ")\n")
            let _ = emit_line_cstr(out, 3, c"}")
        }
        let _ = emit_line_cstr(out, 1, c"}")
        let _ = str_push(out, 10)
        emit_pratt_arm_dispatch_case_fns(out, rule_i, kind, block_i, arms, arm_i + 1, has_lhs)
    }

def emit_pratt_prefix_block_fn(out: Str, rules: Vec, rule_i: i64, rule_name: Str, block_i: i64, blk: IrPrefixBlock): i64 =
    match blk {
        IrPrefixBlock(bp, arms) => {
            let _ = emit_pratt_arm_fns(out, rules, rule_i, rule_name, c"prefix", block_i, arms, 0, bp, 0)
            let _ = emit_pratt_arm_dispatch_case_fns(out, rule_i, c"prefix", block_i, arms, 0, 0)
            let _ = emit_indent(out, 0)
            let _ = str_push_cstr(out, "def ")
            let _ = emit_pratt_block_fn_name(out, rule_i, c"prefix", block_i)
            let _ = str_push_cstr(out, "(tokens: Vec, pos: i64): MatchResult = ")
            let _ = emit_pratt_block_case_fn_name(out, rule_i, c"prefix", block_i, 0)
            let _ = str_push_cstr(out, "(tokens, pos)\n\n")
            0
        }
    }

def emit_pratt_postfix_block_fn(out: Str, rules: Vec, rule_i: i64, rule_name: Str, block_i: i64, blk: IrPostfixBlock): i64 =
    match blk {
