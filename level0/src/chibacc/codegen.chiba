    }

def emit_pratt_prefix_dispatch_case_fn(out: Str, rule_i: i64, prefixes: Vec, block_i: i64): i64 =
    if block_i >= vec_len(prefixes) { 0 }
    else {
        let _ = emit_indent(out, 0)
        let _ = str_push_cstr(out, "def ")
        let _ = emit_pratt_prefix_dispatch_case_fn_name(out, rule_i, block_i)
        let _ = str_push_cstr(out, "(tokens: Vec, pos: i64): MatchResult =\n")
        let _ = emit_indent(out, 1)
        let _ = str_push_cstr(out, "match ")
        let _ = emit_pratt_block_fn_name(out, rule_i, c"prefix", block_i)
        let _ = str_push_cstr(out, "(tokens, pos) {\n")
        let _ = emit_line_cstr(out, 2, c"MatchOK(ast, pos1, recovered) => MatchOK(ast, pos1, recovered)")
        let _ = if block_i + 1 >= vec_len(prefixes) {
            emit_line_cstr(out, 2, c"MatchFail(fail_pos) => MatchFail(fail_pos)")
        } else {
            let _ = emit_line_cstr(out, 2, c"MatchFail(fail_pos) => {")
            let _ = emit_line_cstr(out, 3, c"if fail_pos > pos { MatchFail(fail_pos) }")
            let _ = emit_indent(out, 3)
            let _ = str_push_cstr(out, "else { ")
            let _ = emit_pratt_prefix_dispatch_case_fn_name(out, rule_i, block_i + 1)
            let _ = str_push_cstr(out, "(tokens, pos) }\n")
            emit_line_cstr(out, 2, c"}")
        }
        let _ = emit_line_cstr(out, 1, c"}")
        let _ = str_push(out, 10)
        emit_pratt_prefix_dispatch_case_fn(out, rule_i, prefixes, block_i + 1)
    }

def emit_pratt_postfix_dispatch_case_fn(out: Str, rule_i: i64, postfixes: Vec, block_i: i64): i64 =
    if block_i >= vec_len(postfixes) { 0 }
    else {
        let blk = vec_get(postfixes, block_i) as IrPostfixBlock
        match blk {
            IrPostfixBlock(bp, _) => {
                let _ = emit_indent(out, 0)
                let _ = str_push_cstr(out, "def ")
                let _ = emit_pratt_postfix_dispatch_case_fn_name(out, rule_i, block_i)
                let _ = str_push_cstr(out, "(tokens: Vec, pos: i64, __lhs: i64, min_bp: i64): MatchResult = {\n")
                let _ = emit_indent(out, 1)
                let _ = str_push_cstr(out, "if min_bp <= ")
                let _ = emit_i64(out, bp)
                let _ = str_push_cstr(out, " {\n")
                let _ = emit_indent(out, 2)
                let _ = str_push_cstr(out, "match ")
                let _ = emit_pratt_block_fn_name(out, rule_i, c"postfix", block_i)
                let _ = str_push_cstr(out, "(tokens, pos, __lhs) {\n")
                let _ = emit_line_cstr(out, 3, c"MatchOK(ast, pos1, recovered) => MatchOK(ast, pos1, recovered)")
                let _ = if block_i + 1 >= vec_len(postfixes) {
                    emit_line_cstr(out, 3, c"MatchFail(fail_pos) => MatchFail(fail_pos)")
                } else {
                    let _ = emit_line_cstr(out, 3, c"MatchFail(fail_pos) => {")
                    let _ = emit_line_cstr(out, 4, c"if fail_pos > pos { MatchFail(fail_pos) }")
                    let _ = emit_indent(out, 4)
                    let _ = str_push_cstr(out, "else { ")
                    let _ = emit_pratt_postfix_dispatch_case_fn_name(out, rule_i, block_i + 1)
                    let _ = str_push_cstr(out, "(tokens, pos, __lhs, min_bp) }\n")
                    emit_line_cstr(out, 3, c"}")
                }
                let _ = emit_line_cstr(out, 2, c"}")
                let _ = emit_line_cstr(out, 1, c"}")
                let _ = if block_i + 1 >= vec_len(postfixes) {
                    emit_line_cstr(out, 1, c"else { MatchFail(pos) }")
                } else {
                    let _ = emit_indent(out, 1)
                    let _ = str_push_cstr(out, "else { ")
                    let _ = emit_pratt_postfix_dispatch_case_fn_name(out, rule_i, block_i + 1)
                    let _ = str_push_cstr(out, "(tokens, pos, __lhs, min_bp) }\n")
                    0
                }
                let _ = emit_line_cstr(out, 0, c"}")
                let _ = str_push(out, 10)
                emit_pratt_postfix_dispatch_case_fn(out, rule_i, postfixes, block_i + 1)
            }
        }
    }

def emit_pratt_infix_dispatch_case_fn(out: Str, rule_i: i64, infixes: Vec, block_i: i64): i64 =
    if block_i >= vec_len(infixes) { 0 }
    else {
        let blk = vec_get(infixes, block_i) as IrInfixBlock
