    }

def emit_pratt_prefix_block_fns(out: Str, rules: Vec, rule_i: i64, rule_name: Str, prefixes: Vec, block_i: i64): i64 =
    if block_i >= vec_len(prefixes) { 0 }
    else {
        let blk = vec_get(prefixes, block_i) as IrPrefixBlock
        let _ = emit_pratt_prefix_block_fn(out, rules, rule_i, rule_name, block_i, blk)
        emit_pratt_prefix_block_fns(out, rules, rule_i, rule_name, prefixes, block_i + 1)
    }

def emit_pratt_postfix_block_fns(out: Str, rules: Vec, rule_i: i64, rule_name: Str, postfixes: Vec, block_i: i64): i64 =
