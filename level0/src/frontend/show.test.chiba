namespace frontend.show.test
use metalstd.mem.*
use metalstd.list.*
use metalstd.str.*
use metalstd.test.*
use metalstd.print.*
use frontend.ast.*
use frontend.lexer.*
use frontend.parser.*
use frontend.show.*

def test_to_string(ctx: i64): i64 = {
    let _ = write_fd(1, "-- to_string tests --\n", 22)

    // BinOp
    let s1 = binop_to_string(OpAdd)
    let _ = assert_true(ctx, "binop +", streq(s1, mk_str("+", 1)))
    let s2 = binop_to_string(OpEq)
    let _ = assert_true(ctx, "binop ==", streq(s2, mk_str("==", 2)))

    // UnOp
    let s3 = unop_to_string(OpNeg)
    let _ = assert_true(ctx, "unop -", streq(s3, mk_str("-", 1)))

    // Ty
    let s4 = ty_to_string(TyI64)
    let _ = assert_true(ctx, "ty i64", streq(s4, mk_str("i64", 3)))
    let s4b = ty_to_string(TyStr)
    let _ = assert_true(ctx, "ty str", streq(s4b, mk_str("str", 3)))
    let s4c = ty_to_string(TyCStr)
    let _ = assert_true(ctx, "ty cstr", streq(s4c, mk_str("cstr", 4)))
    let s5 = ty_to_string(TyNamed(mk_str("List", 4), Cons(TyI64, Nil)))
    let _ = assert_true(ctx, "ty List[i64]", streq(s5, mk_str("List[i64]", 9)))

    // Pat
    let s6 = pat_to_string(PWild)
    let _ = assert_true(ctx, "pat _", streq(s6, mk_str("_", 1)))
    let s7 = pat_to_string(PVar(mk_str("x", 1)))
    let _ = assert_true(ctx, "pat x", streq(s7, mk_str("x", 1)))

    // Expr
    let s8 = expr_to_string(EInt(42))
    let _ = assert_true(ctx, "expr 42", streq(s8, mk_str("42", 2)))
    let s9 = expr_to_string(EVar(mk_str("foo", 3)))
    let _ = assert_true(ctx, "expr foo", streq(s9, mk_str("foo", 3)))
    let s10 = expr_to_string(EBinOp(OpAdd, EInt(1), EInt(2)))
    let _ = assert_true(ctx, "expr 1+2", streq(s10, mk_str("(1 + 2)", 7)))
    let s10b = expr_to_string(ECStr(mk_str("hello", 5)))
    let _ = assert_true(ctx, "expr cstr", streq(s10b, mk_str("c\"hello\"", 8)))
    let s10c = expr_to_string(ESliceLit(Cons(EInt(1), Cons(EInt(2), Cons(EInt(3), Nil)))))
    let _ = assert_true(ctx, "expr slice lit", streq(s10c, mk_str("[1, 2, 3]", 9)))
    let s10d = expr_to_string(ESliceLit(Nil))
    let _ = assert_true(ctx, "expr empty slice lit", streq(s10d, mk_str("[]", 2)))

    // Token
    let s11 = tok_to_string(TokKwDef)
    let _ = assert_true(ctx, "tok def", streq(s11, mk_str("def", 3)))
    let s12 = tok_to_string(TokInt(123))
    let _ = assert_true(ctx, "tok int", streq(s12, mk_str("TokInt(123)", 11)))
    let s12b = tok_to_string(TokCStr(mk_str("hello", 5)))
    let _ = assert_true(ctx, "tok cstr", streq(s12b, mk_str("TokCStr(c\"hello\")", 17)))

    // Item (roundtrip: parse then to_string)
    let items = parse_program_items("data Color { Red, Green }", 25)
    let item_s = item_to_string(head(items))
    let _ = str_println(item_s)

    0
}
