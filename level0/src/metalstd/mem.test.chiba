namespace metalstd.mem.test
use metalstd.mem.*
use metalstd.test.*
use metalstd.print.*

def test_mem(ctx: i64): i64 = {
    let _ = write_fd(1, "-- Memory tests --\n", 19)

    let p = heap_alloc(32)
    let _ = store64(p, 0, 12345)
    let _ = assert_eq(ctx, "store/load64", load64(p, 0), 12345)

    let _ = store8(p, 0, 65)
    let _ = assert_eq(ctx, "store/load8", load8(p, 0), 65)

    let _ = store64(p, 1, 99)
    let _ = assert_eq(ctx, "multi slot", load64(p, 1), 99)

    let dst = heap_alloc(16)
    let _ = store64(p, 0, 111)
    let _ = store64(p, 1, 222)
    let _ = memcpy(dst, p, 16)
    let _ = assert_eq(ctx, "memcpy word0", load64(dst, 0), 111)
    let _ = assert_eq(ctx, "memcpy word1", load64(dst, 1), 222)

    0
}
