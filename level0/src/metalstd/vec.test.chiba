namespace metalstd.vec.test
use metalstd.mem.*
use metalstd.list.*
use metalstd.str.*
use metalstd.test.*
use metalstd.vec.*

def test_vec(ctx: i64): i64 = {
    let _ = write_fd(1, "-- Vec tests --\n", 16)

    // new + push + len
    let v1 = vec_new()
    let _ = assert_eq(ctx, "vec new len", vec_len(v1), 0)
    let _ = vec_push(v1, 10)
    let _ = vec_push(v1, 20)
    let _ = vec_push(v1, 30)
    let _ = assert_eq(ctx, "vec push len", vec_len(v1), 3)

    // get
    let _ = assert_eq(ctx, "vec get 0", vec_get(v1, 0), 10)
    let _ = assert_eq(ctx, "vec get 1", vec_get(v1, 1), 20)
    let _ = assert_eq(ctx, "vec get 2", vec_get(v1, 2), 30)

    // set
    let _ = vec_set(v1, 1, 99)
    let _ = assert_eq(ctx, "vec set", vec_get(v1, 1), 99)

    // last
    let _ = assert_eq(ctx, "vec last", vec_last(v1), 30)

    // pop
    let popped = vec_pop(v1)
    let _ = assert_eq(ctx, "vec pop val", popped, 30)
    let _ = assert_eq(ctx, "vec pop len", vec_len(v1), 2)

    // with_cap
    let v2 = vec_with_cap(16)
    let _ = assert_eq(ctx, "vec cap len", vec_len(v2), 0)
    let _ = assert_eq(ctx, "vec cap cap", vec_cap(v2), 16)

    // grow past initial capacity
    let v3 = vec_new()
    let _ = vec_push(v3, 1)
    let _ = vec_push(v3, 2)
    let _ = vec_push(v3, 3)
    let _ = vec_push(v3, 4)
    let _ = vec_push(v3, 5)
    let _ = vec_push(v3, 6)
    let _ = vec_push(v3, 7)
    let _ = vec_push(v3, 8)
    let _ = vec_push(v3, 9)   // triggers grow (8 -> 16)
    let _ = assert_eq(ctx, "vec grow len", vec_len(v3), 9)
    let _ = assert_eq(ctx, "vec grow 0", vec_get(v3, 0), 1)
    let _ = assert_eq(ctx, "vec grow 8", vec_get(v3, 8), 9)

    // reverse
    let v4 = vec_new()
    let _ = vec_push(v4, 1)
    let _ = vec_push(v4, 2)
    let _ = vec_push(v4, 3)
    let _ = vec_reverse(v4)
    let _ = assert_eq(ctx, "vec rev 0", vec_get(v4, 0), 3)
    let _ = assert_eq(ctx, "vec rev 1", vec_get(v4, 1), 2)
    let _ = assert_eq(ctx, "vec rev 2", vec_get(v4, 2), 1)

    // clear
    let _ = vec_clear(v4)
    let _ = assert_eq(ctx, "vec clear len", vec_len(v4), 0)

    // index_of / contains
    let v5 = vec_new()
    let _ = vec_push(v5, 100)
    let _ = vec_push(v5, 200)
    let _ = vec_push(v5, 300)
    let _ = assert_eq(ctx, "vec idx 200", vec_index_of(v5, 200), 1)
    let _ = assert_eq(ctx, "vec idx miss", vec_index_of(v5, 999), 0 - 1)
    let _ = assert_eq(ctx, "vec has 100", vec_contains(v5, 100), 1)
    let _ = assert_eq(ctx, "vec has miss", vec_contains(v5, 42), 0)

    // from_list
    let xs = Cons(10, Cons(20, Cons(30, Nil)))
    let v6 = vec_from_list(xs as i64)
    let _ = assert_eq(ctx, "vec from list len", vec_len(v6), 3)
    let _ = assert_eq(ctx, "vec from list 0", vec_get(v6, 0), 10)
    let _ = assert_eq(ctx, "vec from list 1", vec_get(v6, 1), 20)
    let _ = assert_eq(ctx, "vec from list 2", vec_get(v6, 2), 30)

    0
}
