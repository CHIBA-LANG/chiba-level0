namespace backend.bir.codegen.amd64.test
use metalstd.file.*
use metalstd.list.*
use metalstd.mem.*
use metalstd.option.*
use metalstd.process.*
use metalstd.str.*
use metalstd.test.*
use backend.bir.ir.*
use backend.bir.codegen.amd64.*

// ── BIR → asm → gcc → run helpers ────────────────────────────────────────

def codegen_run_bir(prog: BirProgram, test_name: i64): ProcResult = {
    let asm_text = codegen_amd64(prog)
    let s_path = build_runtime_path(test_name, ".S")
    let out_path = build_runtime_path(test_name, ".out")
    let rt_path = "chiba-level0/src/backend/bir/chiba_rt.s"
    let _ = file_write_file_all(s_path.ptr, asm_text)
    let cmd = str_new()
    let _ = str_push_cstr(cmd, "PATH=/usr/bin:/bin /usr/bin/gcc -nostdlib -static -o ")
    let _ = str_append(cmd, out_path)
    let _ = str_push_cstr(cmd, " ")
    let _ = str_append(cmd, s_path)
    let _ = str_push_cstr(cmd, " -x assembler-with-cpp ")
    let _ = str_push_cstr(cmd, rt_path)
    let _ = str_push_cstr(cmd, " -no-pie -g 2>&1 && ")
    let _ = str_append(cmd, out_path)
    let _ = str_push_cstr(cmd, " 2>&1")
    let _ = str_null_terminate(cmd)
    proc_run_capture("/bin/sh", Cons("sh", Cons("-c", Cons(cmd.ptr, Nil))))
}

def build_runtime_path(test_name: i64, suffix: i64): Str = {
    let s = str_new()
    let _ = str_push_cstr(s, "runtime/")
    let _ = append_path_name(s, test_name, 0)
    let _ = str_append_cstr(s, suffix)
    let _ = str_null_terminate(s)
    s
}

def append_path_name(s: Str, p: i64, i: i64): i64 = {
    let ch = load8(p, i)
    if ch == 0 { 0 }
    else {
        let _ = str_push(s, if ch == 32 { 95 } else { ch })
        append_path_name(s, p, i + 1)
    }
}

def expect_run(ctx: i64, label: i64, prog: BirProgram, expected: i64): i64 = {
    let res = codegen_run_bir(prog, label)
    let _ = assert_eq(ctx, label, proc_result_status(res), 0)
    let out_label = str_new()
    let _ = str_append_cstr(out_label, label)
    let _ = str_push_cstr(out_label, " stdout")
    let _ = str_null_terminate(out_label)
    let _ = assert_true(ctx, out_label.ptr, streq(proc_result_stdout(res), mk_str(expected, strlen(expected))))
    0
}

def test_str_contains(hay: Str, needle: Str): i64 =
    if needle.len == 0 { 1 } else { test_str_contains_loop(hay, needle, 0) }

def test_str_contains_loop(hay: Str, needle: Str, i: i64): i64 =
    if i + needle.len > hay.len { 0 }
    else {
        if test_str_slice_eq(hay, needle, i, 0, needle.len) != 0 { 1 }
        else { test_str_contains_loop(hay, needle, i + 1) }
    }

def test_str_slice_eq(a: Str, b: Str, ai: i64, bi: i64, n: i64): i64 =
    if n <= 0 { 1 }
    else {
        if load8(a.ptr, ai) != load8(b.ptr, bi) { 0 }
        else { test_str_slice_eq(a, b, ai + 1, bi + 1, n - 1) }
    }

// ── Small BIR program builders ────────────────────────────────────────────

def prog_single(fun: BirFun, strings: List[Str], frames: List[FrameDesc]): BirProgram =
    BirProgram { funs: Cons(fun, Nil), entry_fun: fun.id, frame_descs: frames, strings: strings }

def block0(base_vreg: i64, insts: List[Inst], term: Terminator): BirFun =
    BirFun {
        id: 1,
        name: bir_ir_mk_str_cstr("main"),
        params: Nil,
        blocks: Cons(Block { id: 0, params: Nil, insts: insts, term: term }, Nil),
        base_vreg: base_vreg,
        num_vregs: 16
    }

// ── Tests ─────────────────────────────────────────────────────────────────

def test_bir_codegen_amd64(ctx: i64): i64 = {
    let _ = write_fd(1, "-- BIR AMD64 codegen tests --\n", 30)

    let prog_imm = prog_single(
        block0(0,
            Cons(ILoadImm(0, 42), Nil),
            THalt(0)),
        Nil,
        Nil)
    let _ = expect_run(ctx, "codegen imm", prog_imm, "42\n")

    let prog_arith = prog_single(
        block0(0,
            Cons(ILoadImm(0, 10),
            Cons(ILoadImm(1, 5),
            Cons(IIAdd(2, 0, 1),
            Cons(ILoadImm(3, 2),
            Cons(IIMul(4, 2, 3),
            Cons(ILoadImm(5, 3),
            Cons(IISub(6, 4, 5), Nil))))))),
            THalt(6)),
        Nil,
        Nil)
    let _ = expect_run(ctx, "codegen arithmetic", prog_arith, "27\n")

    let prog_tagged = prog_single(
        block0(0,
            Cons(ILoadImm(0, 10),
            Cons(ILoadImm(1, 20),
            Cons(IMakeTagged(2, 7, Cons(0, Cons(1, Nil))),
            Cons(ITagOf(3, 2),
            Cons(IGetField(4, 2, 0),
            Cons(IGetField(5, 2, 1),
            Cons(IIAdd(6, 4, 5), Nil))))))),
            THalt(6)),
        Nil,
        Nil)
    let _ = expect_run(ctx, "codegen tagged", prog_tagged, "30\n")

    let prog_heap = prog_single(
        block0(0,
            Cons(ILoadImm(0, 16),
            Cons(IBumpAlloc(1, 0),
            Cons(ILoadImm(2, 42),
            Cons(IHeapStore(1, 0, 2),
            Cons(IHeapLoad(3, 1, 0), Nil))))),
            THalt(3)),
        Nil,
        Nil)
    let _ = expect_run(ctx, "codegen heap", prog_heap, "42\n")

    let prog_switch = BirProgram {
        funs: Cons(BirFun {
            id: 1,
            name: bir_ir_mk_str_cstr("main"),
            params: Nil,
            blocks: Cons(Block { id: 0, params: Nil, insts: Cons(ILoadImm(0, 2), Nil), term: TSwitch(0, Cons((1, 1, Nil), Cons((2, 2, Nil), Nil)), Some((3, Nil))) },
                    Cons(Block { id: 1, params: Nil, insts: Cons(ILoadImm(1, 11), Nil), term: THalt(1) },
                    Cons(Block { id: 2, params: Nil, insts: Cons(ILoadImm(2, 22), Nil), term: THalt(2) },
                    Cons(Block { id: 3, params: Nil, insts: Cons(ILoadImm(3, 33), Nil), term: THalt(3) }, Nil)))),
            base_vreg: 0,
            num_vregs: 8
        }, Nil),
        entry_fun: 1,
        frame_descs: Nil,
        strings: Nil
    }
    let _ = expect_run(ctx, "codegen switch", prog_switch, "22\n")

    let tail_target = BirFun {
        id: 2,
        name: bir_ir_mk_str_cstr("tail_target"),
        params: Cons(0, Nil),
        blocks: Cons(Block { id: 0, params: Cons(0, Nil), insts: Nil, term: THalt(0) }, Nil),
        base_vreg: 0,
        num_vregs: 4
    }
    let tail_main = BirFun {
        id: 1,
        name: bir_ir_mk_str_cstr("main"),
        params: Nil,
        blocks: Cons(Block {
            id: 0,
            params: Nil,
            insts: Cons(ILoadFunPtr(0, 2), Cons(ILoadImm(1, 42), Nil)),
            term: TTailCall(0, Cons(1, Nil))
        }, Nil),
        base_vreg: 0,
        num_vregs: 4
    }
    let prog_tail = BirProgram {
        funs: Cons(tail_main, Cons(tail_target, Nil)),
        entry_fun: 1,
        frame_descs: Nil,
        strings: Nil
    }
    let _ = expect_run(ctx, "codegen tailcall", prog_tail, "42\n")

    let prog_bitwise = prog_single(
        block0(0,
            Cons(ILoadImm(0, 6),
            Cons(ILoadImm(1, 3),
            Cons(IBitAnd(2, 0, 1),
            Cons(IBitOr(3, 0, 1),
            Cons(IBitXor(4, 0, 1),
            Cons(IIAdd(5, 2, 3),
            Cons(IIAdd(6, 5, 4), Nil))))))),
            THalt(6)),
        Nil,
        Nil)
    let _ = expect_run(ctx, "codegen bitwise", prog_bitwise, "14\n")

    let prog_shift = prog_single(
        block0(0,
            Cons(ILoadImm(0, 3),
            Cons(ILoadImm(1, 2),
            Cons(IShl(2, 0, 1),
            Cons(ILoadImm(3, 16),
            Cons(ILoadImm(4, 1),
            Cons(IShr(5, 3, 4),
            Cons(IIAdd(6, 2, 5), Nil))))))),
            THalt(6)),
        Nil,
        Nil)
    let _ = expect_run(ctx, "codegen shift", prog_shift, "20\n")

    0
}
