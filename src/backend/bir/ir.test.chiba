namespace backend.bir.ir.test
use metalstd.mem.*
use metalstd.list.*
use metalstd.str.*
use metalstd.print.*
use metalstd.test.*
use metalstd.option.*
use backend.bir.ir.*

// ── BIR IR construction tests ───────────────────────────────────────────────

def test_bir_ir(ctx: i64): i64 = {
    let _ = write_fd(1, "-- BIR IR tests --\n", 19)

    let op = CmpLt
    let _ = assert_true(ctx, "CmpOp CmpLt",
        match op { CmpLt => 1  _ => 0 })

    let inst1 = ILoadImm(1, 42)
    let _ = assert_true(ctx, "ILoadImm shape",
        match inst1 { ILoadImm(dst, val) => dst == 1 && val == 42  _ => 0 })

    let inst2 = IMakeTagged(2, 7, Cons(10, Cons(11, Nil)))
    let _ = assert_true(ctx, "IMakeTagged shape",
        match inst2 { IMakeTagged(dst, tag, fields) => dst == 2 && tag == 7 && length(fields) == 2  _ => 0 })

    let term1 = TJump(5, Cons(9, Nil))
    let _ = assert_true(ctx, "TJump shape",
        match term1 { TJump(target, args) => target == 5 && length(args) == 1  _ => 0 })

    let block = Block {
        id: 3,
        params: Cons(1, Nil),
        insts: Cons(inst1, Cons(inst2, Nil)),
        term: term1
    }
    let _ = assert_eq(ctx, "Block id", block.id, 3)
    let _ = assert_eq(ctx, "Block insts len", length(block.insts), 2)

    let fun = BirFun {
        id: 8,
        name: "demo",
        params: Cons(1, Cons(2, Nil)),
        blocks: Cons(block, Nil),
        base_vreg: 10,
        num_vregs: 4
    }
    let _ = assert_eq(ctx, "BirFun id", fun.id, 8)
    let _ = assert_eq(ctx, "BirFun params len", length(fun.params), 2)
    let _ = assert_true(ctx, "bir_fun_block finds block",
        match bir_fun_block(fun, 3) { Some(_) => 1  None => 0 })

    let desc = FrameDesc {
        kind: 2,
        name: "resume_main",
        resume_block: 9,
        resume_fun: 8
    }
    let prog = BirProgram {
        funs: Cons(fun, Nil),
        entry_fun: 8,
        frame_descs: Cons(desc, Nil),
        strings: Cons("hello", Nil)
    }
    let _ = assert_eq(ctx, "BirProgram entry_fun", prog.entry_fun, 8)
    let _ = assert_true(ctx, "bir_program_fun finds fun",
        match bir_program_fun(prog, 8) { Some(_) => 1  None => 0 })

    0
}
