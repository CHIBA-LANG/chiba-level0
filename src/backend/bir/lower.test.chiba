namespace backend.bir.lower.test
use metalstd.mem.*
use metalstd.list.*
use metalstd.str.*
use metalstd.print.*
use metalstd.test.*
use metalstd.option.*
use backend.cir.ir.*
use backend.bir.ir.*
use backend.bir.lower.*

// ── CPS → BIR lowering smoke tests ─────────────────────────────────────────


def test_bir_lower(ctx: i64): i64 = {
    let _ = write_fd(1, "-- BIR lowering tests --\n", 24)
    let _ = write_fd(1, "[bir-lower] case1\n", 18)

    let prog1 = CpsProgram {
        funs: Nil,
        entry: XHalt(VInt(7)),
        strings: Nil
    }
    let bir1 = lower_cps_to_bir(prog1)
    let _ = write_fd(1, "[bir-lower] case1 done\n", 23)
    let _ = assert_eq(ctx, "entry-only bir fun count", length(bir1.funs), 1)
    let main1 = bir_program_fun_unwrap(bir1, bir1.entry_fun)
    let _ = assert_eq(ctx, "entry main params", length(main1.params), 0)
    let first_block1 = bir_fun_block_unwrap(main1, first_block_id(main1.blocks))
    let _ = assert_true(ctx, "entry halt lowered",
        match first_block1.term { THalt(_) => 1  _ => 0 })

    let _ = write_fd(1, "[bir-lower] case2\n", 18)
    let prog2 = CpsProgram {
        funs: Nil,
        entry: XLetPrim(0, PIAdd(VInt(1), VInt(2)), XHalt(VVar(0))),
        strings: Nil
    }
    let bir2 = lower_cps_to_bir(prog2)
    let _ = write_fd(1, "[bir-lower] case2 done\n", 23)
    let main2 = bir_program_fun_unwrap(bir2, bir2.entry_fun)
    let block2 = bir_fun_block_unwrap(main2, first_block_id(main2.blocks))
    let _ = assert_true(ctx, "arith prim lowered",
        inst_list_has_iadd(block2.insts) != 0)

    let _ = write_fd(1, "[bir-lower] case3\n", 18)
    let fid = 1
    let retk = 99
    let top = FunDef {
        id: fid,
        name: "id",
        params: Cons(0, Nil),
        ret: retk,
        body: XAppCont(retk, Cons(VVar(0), Nil))
    }
    let prog3 = CpsProgram {
        funs: Cons(top, Nil),
        entry: XHalt(VUnit),
        strings: Nil
    }
    let bir3 = lower_cps_to_bir(prog3)
    let _ = write_fd(1, "[bir-lower] case3 done\n", 23)
    let _ = assert_eq(ctx, "top-fun + main count", length(bir3.funs), 2)
    let lowered_fun = bir_program_fun_unwrap(bir3, first_non_entry_fun_id(bir3))
    let _ = assert_eq(ctx, "lowered top fun params", length(lowered_fun.params), 1)

    0
}

def inst_list_has_iadd(insts: List[Inst]): i64 =
    match insts {
        Nil => 0
        Cons(inst, rest) =>
            match inst {
                IIAdd(_, _, _) => 1
                _ => inst_list_has_iadd(rest)
            }
    }

def first_block_id(blocks: List[Block]): i64 =
    match blocks {
        Cons(block, _) => block.id
        Nil => 0 - 1
    }

def first_non_entry_fun_id(prog: BirProgram): i64 =
    first_non_entry_fun_id_loop(prog.funs, prog.entry_fun)

def first_non_entry_fun_id_loop(funs: List[BirFun], entry_fun: i64): i64 =
    match funs {
        Nil => 0 - 1
        Cons(fun, rest) => if fun.id != entry_fun { fun.id } else { first_non_entry_fun_id_loop(rest, entry_fun) }
    }
