namespace backend.cir.ir.test
use metalstd.mem.*
use metalstd.list.*
use metalstd.str.*
use metalstd.print.*
use metalstd.test.*
use metalstd.option.*
use backend.cir.ir.*

// ── CPS IR construction tests ────────────────────────────────────────────────

def test_ir(ctx: i64): i64 = {
    let _ = write_fd(1, "-- CPS IR tests --\n", 19)

    // ── Val constructors ──────────────────────────────────────────────────
    let v1 = VVar(42)
    let _ = assert_true(ctx, "VVar is VVar",
        match v1 { VVar(_) => 1  _ => 0 })
    let _ = assert_eq(ctx, "VVar value",
        match v1 { VVar(x) => x  _ => 0 - 1 }, 42)

    let v2 = VInt(99)
    let _ = assert_eq(ctx, "VInt value",
        match v2 { VInt(x) => x  _ => 0 - 1 }, 99)

    let v3 = VUnit
    let _ = assert_true(ctx, "VUnit is VUnit",
        match v3 { VUnit => 1  _ => 0 })

    let v4 = VFun(7)
    let _ = assert_eq(ctx, "VFun id",
        match v4 { VFun(x) => x  _ => 0 - 1 }, 7)

    let v5 = VInt(1)
    let _ = assert_eq(ctx, "VInt(1) value",
        match v5 { VInt(x) => x  _ => 0 - 1 }, 1)

    // ── PrimOp constructors ───────────────────────────────────────────────
    let op1 = PIAdd(VInt(3), VInt(4))
    let _ = assert_true(ctx, "PIAdd is PIAdd",
        match op1 { PIAdd(_, _) => 1  _ => 0 })

    let op2 = PGetField(VVar(1), 2)
    let _ = assert_true(ctx, "PGetField",
        match op2 { PGetField(_, idx) => idx == 2  _ => 0 })

    let op3 = PTagOf(VVar(5))
    let _ = assert_true(ctx, "PTagOf",
        match op3 { PTagOf(_) => 1  _ => 0 })

    let op4 = PMakeTagged(42, Cons(VInt(1), Cons(VInt(2), Nil)))
    let _ = assert_true(ctx, "PMakeTagged tag",
        match op4 { PMakeTagged(t, _) => t == 42  _ => 0 })
    let _ = assert_eq(ctx, "PMakeTagged fields len",
        match op4 { PMakeTagged(_, fs) => length(fs)  _ => 0 - 1 }, 2)

    // ── CpsExpr constructors ──────────────────────────────────────────────
    let e1 = mk_halt(VInt(0))
    let _ = assert_true(ctx, "XHalt",
        match e1 { XHalt(_) => 1  _ => 0 })

    let e2 = XLetVal(1, VInt(10), mk_halt(VVar(1)))
    let _ = assert_true(ctx, "XLetVal",
        match e2 { XLetVal(_, _, _) => 1  _ => 0 })

    let e3 = mk_app_cont(5, Cons(VVar(1), Nil))
    let _ = assert_true(ctx, "XAppCont",
        match e3 { XAppCont(_, _) => 1  _ => 0 })
    let _ = assert_eq(ctx, "XAppCont cont_id",
        match e3 { XAppCont(c, _) => c  _ => 0 - 1 }, 5)

    // ── ContDef ───────────────────────────────────────────────────────────
    let cd = ContDef { params: Cons(10, Nil), body: mk_halt(VVar(10)) }
    let _ = assert_eq(ctx, "ContDef params",
        length(cd.params), 1)

    // ── FunDef ────────────────────────────────────────────────────────────
    let fd = FunDef {
        id: 1,
        name: "f",
        params: Cons(10, Cons(11, Nil)),
        ret: 100,
        body: mk_halt(VVar(10))
    }
    let _ = assert_eq(ctx, "FunDef id", fd.id, 1)
    let _ = assert_eq(ctx, "FunDef params", length(fd.params), 2)
    let _ = assert_eq(ctx, "FunDef ret", fd.ret, 100)

    // ── CpsProgram ────────────────────────────────────────────────────────
    let prog = CpsProgram {
        funs: Cons(fd, Nil),
        entry: mk_halt(VUnit)
    }
    let _ = assert_eq(ctx, "CpsProgram funs", length(prog.funs), 1)

    // ── mk_switch ─────────────────────────────────────────────────────────
    let sw = mk_switch(VVar(1), Cons((0, 10), Cons((1, 11), Nil)), Some(12))
    let _ = assert_true(ctx, "mk_switch",
        match sw { XSwitch(_, _, _) => 1  _ => 0 })

    // ── LetPrim ───────────────────────────────────────────────────────────
    let ep = XLetPrim(5, PIAdd(VInt(1), VInt(2)), mk_halt(VVar(5)))
    let _ = assert_true(ctx, "XLetPrim",
        match ep { XLetPrim(_, _, _) => 1  _ => 0 })

    // ── LetCont ───────────────────────────────────────────────────────────
    let ec = mk_let_cont(
        Cons((100, ContDef { params: Cons(5, Nil), body: mk_halt(VVar(5)) }), Nil),
        mk_app_cont(100, Cons(VInt(42), Nil)))
    let _ = assert_true(ctx, "XLetCont",
        match ec { XLetCont(_, _) => 1  _ => 0 })

    // ── LetFun ────────────────────────────────────────────────────────────
    let ef = XLetFun(Cons(fd, Nil), mk_halt(VUnit))
    let _ = assert_true(ctx, "XLetFun",
        match ef { XLetFun(_, _) => 1  _ => 0 })

    // ── AppFun ────────────────────────────────────────────────────────────
    let af = XAppFun(VFun(1), 100, Cons(VInt(42), Nil))
    let _ = assert_true(ctx, "XAppFun",
        match af { XAppFun(_, _, _) => 1  _ => 0 })

    0
}
