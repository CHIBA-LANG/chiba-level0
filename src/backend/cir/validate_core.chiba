        cir_l8_env(CirCoreSymbolCons(cir_core_symbol(mk_str("present_symbol", 14)), CirCoreSymbolEnd)),
        L7CoreOp(L1OpRef(L1RefUnresolved(mk_str("present_symbol", 14))), L7CoreFunc)
    ) {
        L8ValidatedCoreOp(_, result) => result
        _ => L8ValidatedCoreErr(mk_str("valid symbol smoke did not validate", 35))
    }

