namespace backend.pass.closure.test
use metalstd.mem.*
use metalstd.list.*
use metalstd.str.*
use metalstd.print.*
use metalstd.test.*
use metalstd.option.*
use backend.cir.ir.*
use backend.pass.closure.*

def test_cc_prog_funs(program: CpsProgram): List[FunDef] = program.funs

// ── Closure conversion tests ─────────────────────────────────────────────────
// Ports src/tests/passes_closure_conv_tests.rs

// Helper: check if a var is in a list
def var_in_list(xs: List[i64], v: i64): i64 =
    match xs {
        Nil => 0
        Cons(x, rest) =>
            if x == v { 1 }
            else { var_in_list(rest, v) }
    }

def test_closure(ctx: i64): i64 = {
    let _ = write_fd(1, "-- Closure conversion tests --\n", 31)

    // ── set operations ────────────────────────────────────────────────────
    let s0: List[i64] = Nil
    let s1 = set_add(s0, 1)
    let _ = assert_eq(ctx, "set_add len", length(s1), 1)
    let _ = assert_true(ctx, "set_has 1", set_has(s1, 1) != 0)
    let _ = assert_true(ctx, "set_has miss", set_has(s1, 2) == 0)

    let s2 = set_add(s1, 2)
    let s3 = set_add(s2, 1)     // duplicate, should not grow
    let _ = assert_eq(ctx, "set no dup", length(s3), 2)

    let s4 = set_remove(s2, 1)
    let _ = assert_eq(ctx, "set_remove len", length(s4), 1)
    let _ = assert_true(ctx, "set_remove val", set_has(s4, 2) != 0)
    let _ = assert_true(ctx, "set_remove gone", set_has(s4, 1) == 0)

    let sa = set_add(set_add(Nil, 1), 2)
    let sb = set_add(set_add(Nil, 3), 4)
    let su = set_union(sa, sb)
    let _ = assert_eq(ctx, "set_union len", length(su), 4)

    // ── free_vars_of_fundef: no free vars ─────────────────────────────────
    // fun f(x, k) = k(x)   →  free vars = {}
    let fdef1 = FunDef {
        id: 1,
        name: "f",
        params: Cons(10, Nil),
        ret: 100,
        body: mk_app_cont(100, Cons(VVar(10), Nil))
    }
    let fv1 = free_vars_of_fundef(fdef1)
    let _ = assert_eq(ctx, "fv no free", length(fv1), 0)

    // ── free_vars_of_fundef: one free var ─────────────────────────────────
    // fun f(x, k) = let r = add(x, y) in k(r)
    //   y (var 20) is free
    let fdef2 = FunDef {
        id: 1,
        name: "f",
        params: Cons(10, Nil),
        ret: 100,
        body: XLetPrim(30, PIAdd(VVar(10), VVar(20)),
                       mk_app_cont(100, Cons(VVar(30), Nil)))
    }
    let fv2 = free_vars_of_fundef(fdef2)
    let _ = assert_eq(ctx, "fv one free", length(fv2), 1)
    let _ = assert_true(ctx, "fv has 20", var_in_list(fv2, 20) != 0)

    // ── free_vars_of_fundef: multiple free vars ──────────────────────────
    // fun f(x, k) = let r = add(y, z) in k(r)
    //   y=20, z=21, both free
    let fdef3 = FunDef {
        id: 1,
        name: "f",
        params: Cons(10, Nil),
        ret: 100,
        body: XLetPrim(30, PIAdd(VVar(20), VVar(21)),
                       mk_app_cont(100, Cons(VVar(30), Nil)))
    }
    let fv3 = free_vars_of_fundef(fdef3)
    let _ = assert_eq(ctx, "fv multi len", length(fv3), 2)
    let _ = assert_true(ctx, "fv has y", var_in_list(fv3, 20) != 0)
    let _ = assert_true(ctx, "fv has z", var_in_list(fv3, 21) != 0)

    // ── collect_free_vars on XHalt ────────────────────────────────────────
    let cv1 = collect_free_vars(mk_halt(VVar(5)))
    let _ = assert_eq(ctx, "cfv halt len", length(cv1), 1)
    let _ = assert_true(ctx, "cfv halt v5", var_in_list(cv1, 5) != 0)

    // ── collect_free_vars on XHalt(VInt) → empty ──────────────────────────
    let cv2 = collect_free_vars(mk_halt(VInt(0)))
    let _ = assert_eq(ctx, "cfv int empty", length(cv2), 0)

    // ── collect_free_vars on XLetVal binds remove ─────────────────────────
    // let v1 = 42 in halt(v1)  →  free = {} (v1 bound by let)
    let cv3 = collect_free_vars(XLetVal(1, VInt(42), mk_halt(VVar(1))))
    let _ = assert_eq(ctx, "cfv letval", length(cv3), 0)

    // ── collect_free_vars on XLetVal with free in value ───────────────────
    // let v1 = VVar(v0) in halt(v1)  →  free = {v0}
    let cv4 = collect_free_vars(XLetVal(1, VVar(0), mk_halt(VVar(1))))
    let _ = assert_eq(ctx, "cfv letval free", length(cv4), 1)
    let _ = assert_true(ctx, "cfv has v0", var_in_list(cv4, 0) != 0)

    // ── collect_free_vars on XLetPrim ─────────────────────────────────────
    // let v5 = add(v3, v4) in halt(v5)  →  free = {v3, v4}
    let cv5 = collect_free_vars(XLetPrim(5, PIAdd(VVar(3), VVar(4)),
                                         mk_halt(VVar(5))))
    let _ = assert_eq(ctx, "cfv prim", length(cv5), 2)

    // ── collect_free_vars on XLetCont ─────────────────────────────────────
    // let cont c0(v7) = halt(v7) in app_cont c0 v6
    //   free = {v6} (v7 is bound by cont param)
    let cv6 = collect_free_vars(
        XLetCont(
            Cons((100, ContDef { params: Cons(7, Nil), body: mk_halt(VVar(7)) }), Nil),
            mk_app_cont(100, Cons(VVar(6), Nil))))
    let _ = assert_eq(ctx, "cfv cont", length(cv6), 1)
    let _ = assert_true(ctx, "cfv has v6", var_in_list(cv6, 6) != 0)

    // ── closure_convert: identity function (no closures) ─────────────────
    // fun f0(x, k) = k(x)
    // entry: f0(42, halt)
    let prog1 = CpsProgram {
        funs: Cons(FunDef {
            id: 1, name: "f", params: Cons(10, Nil), ret: 100,
            body: mk_app_cont(100, Cons(VVar(10), Nil))
        }, Nil),
        entry: XAppFun(VFun(1), 200, Cons(VInt(42), Nil))
    }
    let cc1 = closure_convert(prog1)
    // After CC, no closures needed — identity has no free vars
    // Should still produce valid program
    let _ = assert_true(ctx, "cc ident funs",
        length(test_cc_prog_funs(cc1)) > 0)

    // ── CLOSURE_TAG constant ─────────────────────────────────────────────
    let _ = assert_eq(ctx, "CLOSURE_TAG", CLOSURE_TAG(), 3242885381)

    // ── merge_sort ───────────────────────────────────────────────────────
    let sorted = merge_sort(Cons(3, Cons(1, Cons(4, Cons(1, Cons(5, Nil))))))
    let _ = assert_eq(ctx, "sort len", length(sorted), 5)
    let _ = assert_eq(ctx, "sort 0", nth(sorted, 0), 1)
    let _ = assert_eq(ctx, "sort 1", nth(sorted, 1), 1)
    let _ = assert_eq(ctx, "sort 2", nth(sorted, 2), 3)
    let _ = assert_eq(ctx, "sort 3", nth(sorted, 3), 4)
    let _ = assert_eq(ctx, "sort 4", nth(sorted, 4), 5)

    0
}
