namespace backend.pass.escape.test
use metalstd.mem.*
use metalstd.list.*
use metalstd.str.*
use metalstd.print.*
use metalstd.test.*
use metalstd.option.*
use backend.cir.ir.*
use backend.pass.escape.*

def test_escape_var_id(rec: EscapeRecord): i64 = rec.var_id
def test_escape_reason(rec: EscapeRecord): i64 = rec.reason

// ── Escape analysis tests ────────────────────────────────────────────────────
// Ports src/tests/passes_escape_tests.rs

// Helper: check if var has a specific escape reason in the report
def has_escape(report: List[EscapeRecord], v: i64, reason: i64): i64 =
    match report {
        Nil => 0
        Cons(rec, rest) =>
            if test_escape_var_id(rec) == v {
                if test_escape_reason(rec) == reason { 1 }
                else { has_escape(rest, v, reason) }
            } else {
                has_escape(rest, v, reason)
            }
    }

// Helper: count how many escape records exist for a variable
def count_escapes(report: List[EscapeRecord], v: i64): i64 =
    match report {
        Nil => 0
        Cons(rec, rest) =>
            if test_escape_var_id(rec) == v { 1 + count_escapes(rest, v) }
            else { count_escapes(rest, v) }
    }

def test_escape(ctx: i64): i64 = {
    let _ = write_fd(1, "-- Escape analysis tests --\n", 28)

    // ── Pure arithmetic: no escapes ───────────────────────────────────────
    // fun add(a, b, k) = let r = a+b in k(r)
    // entry: add(1, 2, halt)
    let f_body = XLetPrim(20, PIAdd(VVar(10), VVar(11)),
                          mk_app_cont(200, Cons(VVar(20), Nil)))
    let f_def = FunDef { id: 1, name: "f", params: Cons(10, Cons(11, Nil)),
                         ret: 200, body: f_body }
    let prog1 = CpsProgram {
        funs: Cons(f_def, Nil),
        entry: XAppFun(VFun(1), 300, Cons(VInt(1), Cons(VInt(2), Nil)))
    }
    let report1 = escape_analysis(prog1)
    // a and b not escaped — they're used in primops, not stored
    let _ = assert_eq(ctx, "arith no esc a", count_escapes(report1, 10), 0)
    let _ = assert_eq(ctx, "arith no esc b", count_escapes(report1, 11), 0)

    // ── StoredInTagged: var in MakeTagged field ──────────────────────────
    // let v0 = 42 in let v1 = MakeTagged(0, [v0]) in halt(v1)
    let e2 = XLetVal(0, VInt(42),
             XLetPrim(1, PMakeTagged(0, Cons(VVar(0), Nil)),
             mk_halt(VVar(1))))
    let prog2 = CpsProgram { funs: Nil, entry: e2 }
    let report2 = escape_analysis(prog2)
    let _ = assert_true(ctx, "tagged esc",
        has_escape(report2, 0, ESCAPE_STORED_IN_TAGGED()))

    // ── PassedToFun: var passed as arg to function call ──────────────────
    // fun f(x, k) = k(x)
    // entry: let v=42 in f(v, halt)
    let f_body3 = mk_app_cont(200, Cons(VVar(10), Nil))
    let f_def3 = FunDef { id: 1, name: "f", params: Cons(10, Nil),
                          ret: 200, body: f_body3 }
    let e3 = XLetVal(0, VInt(42),
             XAppFun(VFun(1), 300, Cons(VVar(0), Nil)))
    let prog3 = CpsProgram { funs: Cons(f_def3, Nil), entry: e3 }
    let report3 = escape_analysis(prog3)
    let _ = assert_true(ctx, "passed esc",
        has_escape(report3, 0, ESCAPE_PASSED_TO_FUN()))

    // ── CapturedByClosure: var captured in Closure ───────────────────────
    // let v0 = 42 in let v1 = Closure(f1, [v0]) in halt(v1)
    let e4 = XLetVal(0, VInt(42),
             XLetVal(1, VClosure(1, Cons(0, Nil)),
             mk_halt(VVar(1))))
    let prog4 = CpsProgram { funs: Nil, entry: e4 }
    let report4 = escape_analysis(prog4)
    let _ = assert_true(ctx, "closure esc",
        has_escape(report4, 0, ESCAPE_CAPTURED_BY_CLOSURE()))

    // ── No escapes for VInt (not a Var) ──────────────────────────────────
    // MakeTagged(tag, [VInt(42)]) — VInt is not a Var, no escape recorded
    let e5 = XLetPrim(1, PMakeTagged(0, Cons(VInt(42), Nil)),
             mk_halt(VVar(1)))
    let prog5 = CpsProgram { funs: Nil, entry: e5 }
    let report5 = escape_analysis(prog5)
    let _ = assert_eq(ctx, "int no esc", length(report5), 0)

    // ── StoredInMemory via PStore ─────────────────────────────────────────
    // let v0 = 42 in let _ = store(ptr, 0, v0) in halt(unit)
    let e6 = XLetVal(0, VInt(42),
             XLetPrim(2, PStore(VVar(99), VInt(0), VVar(0)),
             mk_halt(VUnit)))
    let prog6 = CpsProgram { funs: Nil, entry: e6 }
    let report6 = escape_analysis(prog6)
    let _ = assert_true(ctx, "store esc",
        has_escape(report6, 0, ESCAPE_STORED_IN_MEMORY()))

    0
}
