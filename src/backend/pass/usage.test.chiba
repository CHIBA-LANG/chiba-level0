namespace backend.pass.usage.test
use metalstd.mem.*
use metalstd.list.*
use metalstd.str.*
use metalstd.print.*
use metalstd.test.*
use metalstd.option.*
use backend.cir.ir.*
use backend.pass.usage.*

// ── Usage analysis tests ─────────────────────────────────────────────────────
// Ports src/tests/passes_usage_tests.rs

def test_usage(ctx: i64): i64 = {
    let _ = write_fd(1, "-- Usage analysis tests --\n", 27)

    // ── count_var_usage on XHalt(VVar(7)) ─────────────────────────────────
    // Halt{Var(7)} → 0 calls, 1 value_use
    let e1 = mk_halt(VVar(7))
    let u1 = count_var_usage(e1, 7)
    let _ = assert_eq(ctx, "halt dc", u1.direct_calls, 0)
    let _ = assert_eq(ctx, "halt vu", u1.value_uses, 1)

    // ── count_var_usage on XHalt(VInt(0)) for var 7 → zeroed ──────────────
    let e2 = mk_halt(VInt(0))
    let u2 = count_var_usage(e2, 7)
    let _ = assert_eq(ctx, "halt miss dc", u2.direct_calls, 0)
    let _ = assert_eq(ctx, "halt miss vu", u2.value_uses, 0)

    // ── Direct call: AppFun(VVar(42), ...) ────────────────────────────────
    let e3 = XAppFun(VVar(42), 100, Cons(VInt(10), Nil))
    let u3 = count_var_usage(e3, 42)
    let _ = assert_eq(ctx, "appfun dc", u3.direct_calls, 1)
    let _ = assert_eq(ctx, "appfun vu", u3.value_uses, 0)

    // ── Passed as arg: AppFun(VFun(1), 100, [VVar(7)]) ───────────────────
    // Var 7 appears as an argument → value_use, not direct call
    let e4 = XAppFun(VFun(1), 100, Cons(VVar(7), Nil))
    let u4 = count_var_usage(e4, 7)
    let _ = assert_eq(ctx, "arg dc", u4.direct_calls, 0)
    let _ = assert_eq(ctx, "arg vu", u4.value_uses, 1)

    // ── Multishot: same var called twice ──────────────────────────────────
    // let_cont c0 = [v] -> AppFun(VVar(9), c1, [v])
    //               in AppFun(VVar(9), c0, [VInt(1)])
    let inner = XAppFun(VVar(9), 201, Cons(VVar(50), Nil))
    let cdef = ContDef { params: Cons(50, Nil), body: inner }
    let e5 = XLetCont(
        Cons((200, cdef), Nil),
        XAppFun(VVar(9), 200, Cons(VInt(1), Nil)))
    let u5 = count_var_usage(e5, 9)
    let _ = assert_eq(ctx, "multi dc", u5.direct_calls, 2)
    let _ = assert_eq(ctx, "multi vu", u5.value_uses, 0)

    // ── LetVal: value of VVar is counted ──────────────────────────────────
    // let v1 = VVar(3) in halt(VVar(1))
    let e6 = XLetVal(1, VVar(3), mk_halt(VVar(1)))
    let u6 = count_var_usage(e6, 3)
    let _ = assert_eq(ctx, "letval dc", u6.direct_calls, 0)
    let _ = assert_eq(ctx, "letval vu", u6.value_uses, 1)

    // ── LetPrim tallies values ────────────────────────────────────────────
    // let v2 = add(VVar(3), VVar(3)) in halt(VVar(2))
    let e7 = XLetPrim(2, PIAdd(VVar(3), VVar(3)), mk_halt(VVar(2)))
    let u7 = count_var_usage(e7, 3)
    let _ = assert_eq(ctx, "letprim dc", u7.direct_calls, 0)
    let _ = assert_eq(ctx, "letprim vu", u7.value_uses, 2)

    // ── AppCont tallies args ──────────────────────────────────────────────
    let e8 = mk_app_cont(100, Cons(VVar(4), Cons(VVar(4), Cons(VVar(4), Nil))))
    let u8 = count_var_usage(e8, 4)
    let _ = assert_eq(ctx, "appcont dc", u8.direct_calls, 0)
    let _ = assert_eq(ctx, "appcont vu", u8.value_uses, 3)

    // ── Switch tallies scrutinee ──────────────────────────────────────────
    let e9 = mk_switch(VVar(5), Cons((0, 10), Nil), None)
    let u9 = count_var_usage(e9, 5)
    let _ = assert_eq(ctx, "switch dc", u9.direct_calls, 0)
    let _ = assert_eq(ctx, "switch vu", u9.value_uses, 1)

    // ── MakeTagged fields ─────────────────────────────────────────────────
    let e10 = XLetPrim(10, PMakeTagged(0, Cons(VVar(6), Cons(VVar(6), Nil))),
                        mk_halt(VVar(10)))
    let u10 = count_var_usage(e10, 6)
    let _ = assert_eq(ctx, "tagged dc", u10.direct_calls, 0)
    let _ = assert_eq(ctx, "tagged vu", u10.value_uses, 2)

    // ── usage_analysis on a full program ──────────────────────────────────
    // Program: fun f0(x, k) = k(x+1)
    //          entry: f0(42, halt_k)
    let f_body = XLetPrim(20, PIAdd(VVar(10), VInt(1)),
                          mk_app_cont(200, Cons(VVar(20), Nil)))
    let f_def = FunDef { id: 1, name: "f", params: Cons(10, Nil), ret: 200, body: f_body }
    let prog = CpsProgram {
        funs: Cons(f_def, Nil),
        entry: XAppFun(VFun(1), 300, Cons(VInt(42), Nil))
    }
    let report = usage_analysis(prog)
    let u_10 = usage_find(report, 10)
    let _ = assert_eq(ctx, "prog x dc", u_10.direct_calls, 0)
    let _ = assert_eq(ctx, "prog x vu", u_10.value_uses, 1)
    let u_20 = usage_find(report, 20)
    let _ = assert_eq(ctx, "prog res dc", u_20.direct_calls, 0)
    let _ = assert_eq(ctx, "prog res vu", u_20.value_uses, 1)

    0
}
