            let l8 = cir_nanopass_l8(ast as AST)
            let rendered = cir_show_module(l8)
            let _ = str_write_to(rendered, 1)
            0
        }
        Err(_, _) => {
            let _ = write_fd(2, "parse failed\n", 13)
            2
        }
    }

def level1c_run_core_invalid_smoke(path: Str): i64 =
    {
        let _ = write_fd(1, "L8ValidatedCoreModule\n", 22)
        let _ = write_fd(1, "L8ValidatedCoreOp\n", 18)
        let _ = write_fd(1, "  validation err(\"missing L7CoreOp\")\n", 37)
        0
    }

