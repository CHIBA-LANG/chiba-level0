def level1c_dispatch_unknown(): i64 = {
    let _ = level1c_usage()
    1
}

def level1c_dispatch_wat(cmd: Str, path: Str): i64 =
    if streq(cmd, mk_str("wat", 3)) != 0 { level1c_run_wat(path) } else { level1c_dispatch_unknown() }

def level1c_dispatch_cont_usage(cmd: Str, path: Str): i64 =
    if streq(cmd, mk_str("cont-usage", 10)) != 0 { level1c_run_cont_usage(path) } else { level1c_dispatch_wat(cmd, path) }

def level1c_dispatch_core_invalid_smoke(cmd: Str, path: Str): i64 =
    if streq(cmd, mk_str("core-invalid-smoke", 18)) != 0 { level1c_run_core_invalid_smoke(path) } else { level1c_dispatch_cont_usage(cmd, path) }

def level1c_dispatch_nanopass(cmd: Str, path: Str): i64 =
    if streq(cmd, mk_str("nanopass", 8)) != 0 { level1c_run_nanopass(path) } else { level1c_dispatch_core_invalid_smoke(cmd, path) }

def level1c_dispatch_cps(cmd: Str, path: Str): i64 =
    if streq(cmd, mk_str("cps", 3)) != 0 { level1c_run_cps(path) } else { level1c_dispatch_nanopass(cmd, path) }

def level1c_dispatch_type_smoke(cmd: Str, path: Str): i64 =
    if streq(cmd, mk_str("type-smoke", 10)) != 0 { level1c_run_type_smoke(path) } else { level1c_dispatch_cps(cmd, path) }

def level1c_dispatch_type_unify_smoke(cmd: Str, path: Str): i64 =
    if streq(cmd, mk_str("type-unify-smoke", 16)) != 0 { level1c_run_type_unify_smoke(path) } else { level1c_dispatch_type_smoke(cmd, path) }

def level1c_dispatch_type_kind_smoke(cmd: Str, path: Str): i64 =
    if streq(cmd, mk_str("type-kind-smoke", 15)) != 0 { level1c_run_type_kind_smoke(path) } else { level1c_dispatch_type_unify_smoke(cmd, path) }

def level1c_dispatch_type_row_smoke(cmd: Str, path: Str): i64 =
    if streq(cmd, mk_str("type-row-smoke", 14)) != 0 { level1c_run_type_row_smoke(path) } else { level1c_dispatch_type_kind_smoke(cmd, path) }

def level1c_dispatch_typed(cmd: Str, path: Str): i64 =
    if streq(cmd, mk_str("typed", 5)) != 0 { level1c_run_typed(path) } else { level1c_dispatch_type_row_smoke(cmd, path) }

def level1c_dispatch_cir(cmd: Str, path: Str): i64 =
    if streq(cmd, mk_str("cir", 3)) != 0 { level1c_run_cir(path) } else { level1c_dispatch_typed(cmd, path) }

def level1c_dispatch_check(cmd: Str, path: Str): i64 =
    if streq(cmd, mk_str("check", 5)) != 0 { level1c_run_check(path) }
    else if streq(cmd, mk_str("check-project", 13)) != 0 { level1c_run_check_project(path) }
    else { level1c_dispatch_cir(cmd, path) }

def level1c_dispatch_parse(cmd: Str, path: Str): i64 =
    if streq(cmd, mk_str("parse", 5)) != 0 { level1c_run_parse(path) } else { level1c_dispatch_check(cmd, path) }

def level1c_dispatch(cmd: Str, path: Str): i64 =
    if streq(cmd, mk_str("lex", 3)) != 0 { level1c_run_lex(path) } else { level1c_dispatch_parse(cmd, path) }

#[entry]
def main(argc: i64, argv: i64): i64 =
    if argc == 2 && streq(argv_str(argv, 1), mk_str("--help", 6)) != 0 {
        level1c_usage()
    } else if argc < 3 {
        let _ = level1c_usage()
        1
    } else {
        level1c_dispatch(argv_str(argv, 1), argv_str(argv, 2))
    }
