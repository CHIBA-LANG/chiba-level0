def argv_cstr(argv: i64, i: i64): i64 = load64(argv, i)

def argv_str(argv: i64, i: i64): Str = str_from_cptr(argv_cstr(argv, i))

def level1c_usage(): i64 = {
    let _ = write_fd(1, "Usage: level1c <command> <file>\n", 32)
    let _ = write_fd(1, "Commands: lex parse check check-project cir typed type-smoke type-kind-smoke type-row-smoke type-unify-smoke cps nanopass core-invalid-smoke cont-usage wat\n", 156)
    0
}

def level1c_print_token_spans(tokens: Vec, i: i64): i64 =
    if i >= vec_len(tokens) { 0 }
    else {
        let ts = vec_get(tokens, i) as TokenSpan
        let line = tokenspan_to_string(ts)
        let _ = str_write_to(line, 1)
        let _ = write_fd(1, "\n", 1)
        level1c_print_token_spans(tokens, i + 1)
    }

def level1c_run_lex(path: Str): i64 = {
    let src = file_read_file_all_sized(str_to_cstr(path))
    let tokens = lex_all(src.ptr, src.len, 0)
    let _ = level1c_print_token_spans(tokens, 0)
    0
}

def level1c_parse_file(path: Str): LabeledAST = {
    let src = file_read_file_all_sized(str_to_cstr(path))
    let tokens = lex_all(src.ptr, src.len, 0)
    let filtered = striptrivia(tokens)
    if parserprecheck(tokens) != 0 { Err(None, vec_new()) } else { parse_tokens(filtered) }
}

def level1c_run_parse(path: Str): i64 = {
    let src = file_read_file_all_sized(str_to_cstr(path))
    let tokens = lex_all(src.ptr, src.len, 0)
    let filtered = striptrivia(tokens)
    let parsed = if parserprecheck(tokens) != 0 { Err(None, vec_new()) } else { parse_tokens(filtered) }
    let rendered = parseresulttostringwithtokens(parsed, filtered)
    let _ = str_write_to(rendered, 1)
    let _ = write_fd(1, "\n", 1)
    0
}

def level1c_run_check(path: Str): i64 =
    match level1c_parse_file(path) {
        OK(ast, _) => {
            let l1 = alpha_module(cir_lower_module(ast as AST))
            let l2 = cir_typed_module(l1)
            match cir_cont_check_module(l1) {
                CirContCheckOk => {
                    match cir_cont_boundary_check_module(l1) {
                        CirContBoundaryCheckOk =>
                            match cir_typed_semantic_check(ast as AST, l2) {
                                CirTypedSemanticCheckOk => {
                                    let _ = write_fd(1, "check ok\n", 9)
                                    0
                                }
                                CirTypedSemanticCheckErr(message) => {
                                    let _ = str_write_to(message, 2)
                                    let _ = write_fd(2, "\n", 1)
                                    3
                                }
                            }
                        CirContBoundaryCheckErr(message) => {
                            let _ = str_write_to(message, 2)
                            let _ = write_fd(2, "\n", 1)
                            3
                        }
                    }
                }
                CirContCheckErr(message) => {
                    let _ = str_write_to(message, 2)
                    let _ = write_fd(2, "\n", 1)
                    3
                }
            }
        }
        Err(_, _) => {
            let _ = write_fd(2, "parse failed\n", 13)
            2
        }
    }

def level1c_path_join_src(root: Str, file: i64): Str = {
    let out = str_new()
    let _ = str_append(out, root)
    let _ = if root.len == 0 { str_push_cstr(out, "/") }
        else if load8(root.ptr, root.len - 1) == 47 { 0 }
        else { str_push_cstr(out, "/") }
    let _ = str_push_cstr(out, "src/")
    let _ = str_push_cstr(out, file)
    out
}

def level1c_project_src_dir(root: Str): Str = {
    let out = str_new()
    let _ = str_append(out, root)
    let _ = if root.len == 0 { str_push_cstr(out, "/") }
        else if load8(root.ptr, root.len - 1) == 47 { 0 }
        else { str_push_cstr(out, "/") }
    let _ = str_push_cstr(out, "src")
    out
}

def level1c_project_has_entry(src_dir: Str, name: i64): i64 =
    dir_has_entry_cstr(str_to_cstr(src_dir), mk_cstr_view(name, strlen(name)))

def level1c_project_parse_required(path: Str): LabeledAST =
    level1c_parse_file(path)

def level1c_run_check_project(root: Str): i64 = {
    let src_dir = level1c_project_src_dir(root)
    if level1c_project_has_entry(src_dir, "part_a.chiba") == 0 {
        let _ = write_fd(2, "project missing src/part_a.chiba\n", 33)
        3
    } else if level1c_project_has_entry(src_dir, "part_b.chiba") == 0 {
        let _ = write_fd(2, "project missing src/part_b.chiba\n", 33)
        3
    } else if level1c_project_has_entry(src_dir, "use_both.chiba") == 0 {
        let _ = write_fd(2, "project missing src/use_both.chiba\n", 35)
        3
    } else {
        let part_a_path = level1c_path_join_src(root, "part_a.chiba")
        let part_b_path = level1c_path_join_src(root, "part_b.chiba")
        let consumer_path = level1c_path_join_src(root, "use_both.chiba")
        match level1c_project_parse_required(part_a_path) {
            OK(part_a, _) =>
                match level1c_project_parse_required(part_b_path) {
                    OK(part_b, _) =>
                        match level1c_project_parse_required(consumer_path) {
                            OK(consumer, _) =>
                                match namespace_project_check(part_a as AST, part_b as AST, consumer as AST) {
                                    NamespaceProjectCheckOk => {
                                        let _ = write_fd(1, "check project ok\n", 17)
                                        0
                                    }
                                    NamespaceProjectCheckErr(message) => {
                                        let _ = str_write_to(message, 2)
                                        let _ = write_fd(2, "\n", 1)
                                        3
                                    }
                                }
                            Err(_, _) => {
                                let _ = write_fd(2, "parse failed: use_both.chiba\n", 29)
                                2
                            }
                        }
                    Err(_, _) => {
                        let _ = write_fd(2, "parse failed: part_b.chiba\n", 27)
                        2
                    }
                }
            Err(_, _) => {
                let _ = write_fd(2, "parse failed: part_a.chiba\n", 27)
                2
            }
        }
    }
}

def level1c_run_cir(path: Str): i64 =
    match level1c_parse_file(path) {
        OK(ast, _) => {
            let l1 = alpha_module(cir_lower_module(ast as AST))
            let rendered = cir_show_module(l1)
            let _ = str_write_to(rendered, 1)
            0
        }
        Err(_, _) => {
            let _ = write_fd(2, "parse failed\n", 13)
            2
        }
    }

