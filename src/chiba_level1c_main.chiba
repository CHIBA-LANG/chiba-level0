def level1c_run_nanopass(path: Str): i64 =
    match level1c_parse_file(path) {
        OK(ast, _) => {
            let l8 = cir_nanopass_l8(level1c_target_ast_with_level1b_imports(path, ast as AST))
            let rendered = cir_show_module(l8)
            let _ = str_write_to(rendered, 1)
            0
        }
        Err(_, _) => {
            let _ = write_fd(2, "parse failed\n", 13)
            2
        }
    }

def level1c_run_core_invalid_smoke(path: Str): i64 =
    {
        let _ = write_fd(1, "L8ValidatedCoreModule\n", 22)
        let _ = level1c_write_core_validation(cir_invalid_core_smoke_result())
        let _ = level1c_write_core_validation(cir_invalid_core_dangling_result())
        let _ = level1c_write_core_validation(cir_valid_core_symbol_table_result())
        let _ = level1c_write_core_validation(cir_invalid_core_string_layout_result())
        let _ = level1c_write_core_validation(cir_invalid_core_layout_ref_result())
        let _ = level1c_write_core_validation(cir_invalid_core_layout_kind_result())
        let _ = level1c_write_core_validation(cir_invalid_core_continuation_usage_result())
        let _ = level1c_write_core_validation(cir_invalid_core_tailcall_result())
        let _ = level1c_write_core_validation(cir_invalid_core_world_thread_result())
        0
    }

def level1c_write_core_validation(result: CirCoreValidation): i64 =
    match result {
        L8ValidatedCoreOk => {
            let _ = write_fd(1, "L8ValidatedCoreOp\n", 18)
            write_fd(1, "  validation ok\n", 16)
        }
        L8ValidatedCoreErr(message) => {
            let _ = write_fd(1, "L8ValidatedCoreOp\n", 18)
            let _ = write_fd(1, "  validation err(\"", 18)
            let _ = str_write_to(message, 1)
            write_fd(1, "\")\n", 3)
        }
    }

def level1c_run_cps(path: Str): i64 =
    match level1c_parse_file(path) {
        OK(ast, _) => {
            let l5 = cir_nanopass_l5(level1c_target_ast(ast as AST))
            let rendered = cir_show_module(l5)
            let _ = str_write_to(rendered, 1)
            0
        }
        Err(_, _) => {
            let _ = write_fd(2, "parse failed\n", 13)
            2
        }
    }

def level1c_run_cont_usage(path: Str): i64 =
    match level1c_parse_file(path) {
        OK(ast, _) => {
            let l1 = alpha_module(cir_lower_module(level1c_target_ast(ast as AST)))
            let rendered = cir_cont_usage_show_module(l1)
            let _ = str_write_to(rendered, 1)
            0
        }
        Err(_, _) => {
            let _ = write_fd(2, "parse failed\n", 13)
            2
        }
    }

def level1c_run_wat(path: Str): i64 =
    match level1c_parse_file(path) {
        OK(ast, _) => {
            let core = cir_nanopass_l8(level1c_target_ast_with_level1b_imports(path, ast as AST))
            if wat_module_validated(core) == 0 {
                let _ = write_fd(2, "validated Core required for wat emit\n", 37)
                2
            } else {
                let rendered = wat_emit_module(core)
                let _ = str_write_to(rendered, 1)
                0
            }
        }
        Err(_, _) => {
            let _ = write_fd(2, "parse failed\n", 13)
            2
        }
    }

def level1c_dispatch_unknown(): i64 = {
    let _ = level1c_usage()
    1
}

def level1c_dispatch_wat(cmd: Str, path: Str): i64 =
    if streq(cmd, mk_str("wat", 3)) != 0 { level1c_run_wat(path) } else { level1c_dispatch_unknown() }

def level1c_dispatch_cont_usage(cmd: Str, path: Str): i64 =
    if streq(cmd, mk_str("cont-usage", 10)) != 0 { level1c_run_cont_usage(path) } else { level1c_dispatch_wat(cmd, path) }

def level1c_dispatch_core_invalid_smoke(cmd: Str, path: Str): i64 =
    if streq(cmd, mk_str("core-invalid-smoke", 18)) != 0 { level1c_run_core_invalid_smoke(path) } else { level1c_dispatch_cont_usage(cmd, path) }

def level1c_dispatch_nanopass(cmd: Str, path: Str): i64 =
    if streq(cmd, mk_str("nanopass", 8)) != 0 { level1c_run_nanopass(path) } else { level1c_dispatch_core_invalid_smoke(cmd, path) }

def level1c_dispatch_cps(cmd: Str, path: Str): i64 =
    if streq(cmd, mk_str("cps", 3)) != 0 { level1c_run_cps(path) } else { level1c_dispatch_nanopass(cmd, path) }

def level1c_dispatch_type_smoke(cmd: Str, path: Str): i64 =
    if streq(cmd, mk_str("type-smoke", 10)) != 0 { level1c_run_type_smoke(path) } else { level1c_dispatch_cps(cmd, path) }

def level1c_dispatch_type_unify_smoke(cmd: Str, path: Str): i64 =
    if streq(cmd, mk_str("type-unify-smoke", 16)) != 0 { level1c_run_type_unify_smoke(path) } else { level1c_dispatch_type_smoke(cmd, path) }

def level1c_dispatch_type_kind_smoke(cmd: Str, path: Str): i64 =
    if streq(cmd, mk_str("type-kind-smoke", 15)) != 0 { level1c_run_type_kind_smoke(path) } else { level1c_dispatch_type_unify_smoke(cmd, path) }

def level1c_dispatch_type_l2_check_smoke(cmd: Str, path: Str): i64 =
    if streq(cmd, mk_str("type-l2-check-smoke", 19)) != 0 { level1c_run_type_l2_check_smoke(path) } else { level1c_dispatch_type_kind_smoke(cmd, path) }

def level1c_dispatch_type_generalize_smoke(cmd: Str, path: Str): i64 =
    if streq(cmd, mk_str("type-generalize-smoke", 21)) != 0 { level1c_run_type_generalize_smoke(path) } else { level1c_dispatch_type_l2_check_smoke(cmd, path) }

def level1c_dispatch_type_generic_body_smoke(cmd: Str, path: Str): i64 =
    if streq(cmd, mk_str("type-generic-body-smoke", 23)) != 0 { level1c_run_type_generic_body_smoke(path) } else { level1c_dispatch_type_generalize_smoke(cmd, path) }

def level1c_dispatch_type_capability_smoke(cmd: Str, path: Str): i64 =
    if streq(cmd, mk_str("type-capability-smoke", 21)) != 0 { level1c_run_type_capability_smoke(path) } else { level1c_dispatch_type_generic_body_smoke(cmd, path) }

def level1c_dispatch_type_facts_smoke(cmd: Str, path: Str): i64 =
    if streq(cmd, mk_str("type-facts-smoke", 16)) != 0 { level1c_run_type_facts_smoke(path) } else { level1c_dispatch_type_capability_smoke(cmd, path) }

def level1c_dispatch_type_row_smoke(cmd: Str, path: Str): i64 =
    if streq(cmd, mk_str("type-row-smoke", 14)) != 0 { level1c_run_type_row_smoke(path) } else { level1c_dispatch_type_facts_smoke(cmd, path) }

def level1c_dispatch_type_nominal_smoke(cmd: Str, path: Str): i64 =
    if streq(cmd, mk_str("type-nominal-smoke", 18)) != 0 { level1c_run_type_nominal_smoke(path) } else { level1c_dispatch_type_row_smoke(cmd, path) }

def level1c_dispatch_type_record_smoke(cmd: Str, path: Str): i64 =
    if streq(cmd, mk_str("type-record-smoke", 17)) != 0 { level1c_run_type_record_smoke(path) } else { level1c_dispatch_type_nominal_smoke(cmd, path) }

def level1c_dispatch_type_template_smoke(cmd: Str, path: Str): i64 =
    if streq(cmd, mk_str("type-template-smoke", 19)) != 0 { level1c_run_type_template_smoke(path) } else { level1c_dispatch_type_record_smoke(cmd, path) }

def level1c_dispatch_type_method_smoke(cmd: Str, path: Str): i64 =
    if streq(cmd, mk_str("type-method-smoke", 17)) != 0 { level1c_run_type_method_smoke(path) } else { level1c_dispatch_type_template_smoke(cmd, path) }

def level1c_dispatch_typed(cmd: Str, path: Str): i64 =
    if streq(cmd, mk_str("typed", 5)) != 0 { level1c_run_typed(path) } else { level1c_dispatch_type_method_smoke(cmd, path) }

def level1c_dispatch_cir(cmd: Str, path: Str): i64 =
    if streq(cmd, mk_str("cir", 3)) != 0 { level1c_run_cir(path) } else { level1c_dispatch_typed(cmd, path) }

def level1c_dispatch_check(cmd: Str, path: Str): i64 =
    if streq(cmd, mk_str("check", 5)) != 0 { level1c_run_check(path) }
    else if streq(cmd, mk_str("check-project", 13)) != 0 { level1c_run_check_project(path) }
    else if streq(cmd, mk_str("wat-project", 11)) != 0 { level1c_run_wat_project(path) }
    else { level1c_dispatch_cir(cmd, path) }

def level1c_dispatch_parse(cmd: Str, path: Str): i64 =
    if streq(cmd, mk_str("parse", 5)) != 0 { level1c_run_parse(path) } else { level1c_dispatch_check(cmd, path) }

def level1c_dispatch(cmd: Str, path: Str): i64 =
    if streq(cmd, mk_str("lex", 3)) != 0 { level1c_run_lex(path) } else { level1c_dispatch_parse(cmd, path) }

#[entry]
def main(argc: i64, argv: i64): i64 =
    if argc == 2 && streq(argv_str(argv, 1), mk_str("--help", 6)) != 0 {
        level1c_usage()
    } else if argc < 3 {
        let _ = level1c_usage()
        1
    } else {
        level1c_dispatch(argv_str(argv, 1), argv_str(argv, 2))
    }
