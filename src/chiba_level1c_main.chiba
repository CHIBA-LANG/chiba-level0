def argv_cstr(argv: i64, i: i64): i64 = load64(argv, i)

def argv_str(argv: i64, i: i64): Str = str_from_cptr(argv_cstr(argv, i))

def level1c_usage(): i64 = {
    let _ = write_fd(1, "Usage: level1c <command> <file>\n", 32)
    let _ = write_fd(1, "Commands: lex parse check check-project wat-project cir typed type-smoke type-capability-smoke type-facts-smoke type-generalize-smoke type-generic-body-smoke type-kind-smoke type-l2-check-smoke type-method-smoke type-nominal-smoke type-record-smoke type-row-smoke type-template-smoke type-unify-smoke cps nanopass core-invalid-smoke cont-usage wat\n", 348)
    0
}

def level1c_print_token_spans(tokens: Vec, i: i64): i64 =
    if i >= vec_len(tokens) { 0 }
    else {
        let ts = vec_get(tokens, i) as TokenSpan
        let line = tokenspan_to_string(ts)
        let _ = str_write_to(line, 1)
        let _ = write_fd(1, "\n", 1)
        level1c_print_token_spans(tokens, i + 1)
    }

def level1c_run_lex(path: Str): i64 = {
    let src = file_read_file_all_sized(str_to_cstr(path))
    let tokens = lex_all(src.ptr, src.len, 0)
    let _ = level1c_print_token_spans(tokens, 0)
    0
}

def level1c_parse_file(path: Str): LabeledAST = {
    let src = file_read_file_all_sized(str_to_cstr(path))
    let tokens = lex_all(src.ptr, src.len, 0)
    let filtered = striptrivia(tokens)
    if parserprecheck(tokens) != 0 { Err(None, vec_new()) } else { parse_tokens(filtered) }
}

def level1c_run_parse(path: Str): i64 = {
    let src = file_read_file_all_sized(str_to_cstr(path))
    let tokens = lex_all(src.ptr, src.len, 0)
    let filtered = striptrivia(tokens)
    let parsed = if parserprecheck(tokens) != 0 { Err(None, vec_new()) } else { parse_tokens(filtered) }
    let rendered = parseresulttostringwithtokens(parsed, filtered)
    let _ = str_write_to(rendered, 1)
    let _ = write_fd(1, "\n", 1)
    0
}

def level1c_compile_target(): CirCompileIfTarget =
    cir_compile_if_default_target()

def level1c_target_ast(ast: AST): AST =
    cir_compile_if_filter_source(ast, level1c_compile_target())

def level1c_run_check(path: Str): i64 =
    match level1c_parse_file(path) {
        OK(ast, _) => {
            match cir_compile_if_check_source(ast as AST, level1c_compile_target()) {
                CirCompileIfCheckErr(message) => {
                    let _ = str_write_to(message, 2)
                    let _ = write_fd(2, "\n", 1)
                    3
                }
                CirCompileIfCheckOk => {
                    let target_ast = level1c_target_ast(ast as AST)
                    let l1 = alpha_module(cir_lower_module(target_ast))
                    let l2 = cir_typed_module(l1)
                    match cir_cont_check_module(l1) {
                        CirContCheckOk => {
                            match cir_cont_boundary_check_module(l1) {
                                CirContBoundaryCheckOk =>
                                    match cir_typed_semantic_check(target_ast, l2) {
                                        CirTypedSemanticCheckOk => {
                                            let _ = write_fd(1, "check ok\n", 9)
                                            0
                                        }
                                        CirTypedSemanticCheckErr(message) => {
                                            let _ = str_write_to(message, 2)
                                            let _ = write_fd(2, "\n", 1)
                                            3
                                        }
                                    }
                                CirContBoundaryCheckErr(message) => {
                                    let _ = str_write_to(message, 2)
                                    let _ = write_fd(2, "\n", 1)
                                    3
                                }
                            }
                        }
                        CirContCheckErr(message) => {
                            let _ = str_write_to(message, 2)
                            let _ = write_fd(2, "\n", 1)
                            3
                        }
                    }
                }
            }
        }
        Err(_, _) => {
            let _ = write_fd(2, "parse failed\n", 13)
            2
        }
    }

def level1c_path_join_src(root: Str, file: i64): Str = {
    let out = str_new()
    let _ = str_append(out, root)
    let _ = if root.len == 0 { str_push_cstr(out, "/") }
        else if load8(root.ptr, root.len - 1) == 47 { 0 }
        else { str_push_cstr(out, "/") }
    let _ = str_push_cstr(out, "src/")
    let _ = str_push_cstr(out, file)
    out
}

def level1c_project_src_dir(root: Str): Str = {
    let out = str_new()
    let _ = str_append(out, root)
    let _ = if root.len == 0 { str_push_cstr(out, "/") }
        else if load8(root.ptr, root.len - 1) == 47 { 0 }
        else { str_push_cstr(out, "/") }
    let _ = str_push_cstr(out, "src")
    out
}

def level1c_project_has_entry(src_dir: Str, name: i64): i64 =
    dir_has_entry_cstr(str_to_cstr(src_dir), mk_cstr_view(name, strlen(name)))

def level1c_project_parse_required(path: Str): LabeledAST =
    level1c_parse_file(path)

def level1c_ast_item_append(a: AST, b: AST): AST =
    match a {
        Item_End => b
        Item_Cons(head, tail) => Item_Cons(head, level1c_ast_item_append(tail, b))
        _ => b
    }

def level1c_str_vec_contains(paths: Vec, want: Str, i: i64): i64 =
    if i >= vec_len(paths) { 0 }
    else {
        let got = vec_get(paths, i) as Str
        if streq(got, want) != 0 { 1 }
        else { level1c_str_vec_contains(paths, want, i + 1) }
    }

def level1c_is_inline_space(byte: i64): i64 =
    if byte == 32 { 1 }
    else if byte == 9 { 1 }
    else { 0 }

def level1c_skip_inline_space(src: Str, i: i64, line_end: i64): i64 =
    if i >= line_end { i }
    else if level1c_is_inline_space(load8(src.ptr, i)) != 0 { level1c_skip_inline_space(src, i + 1, line_end) }
    else { i }

def level1c_find_line_end(src: Str, i: i64): i64 =
    if i >= src.len { i }
    else {
        let byte = load8(src.ptr, i)
        if byte == 10 { i }
        else if byte == 13 { i }
        else { level1c_find_line_end(src, i + 1) }
    }

def level1c_skip_line_breaks(src: Str, i: i64): i64 =
    if i >= src.len { i }
    else {
        let byte = load8(src.ptr, i)
        if byte == 10 { level1c_skip_line_breaks(src, i + 1) }
        else if byte == 13 { level1c_skip_line_breaks(src, i + 1) }
        else { i }
    }

def level1c_trim_right_inline_space(src: Str, start: i64, line_end: i64): i64 =
    if line_end <= start { line_end }
    else if level1c_is_inline_space(load8(src.ptr, line_end - 1)) != 0 { level1c_trim_right_inline_space(src, start, line_end - 1) }
    else { line_end }

def level1c_append_level1b_use_module_path(out: Str, src: Str, i: i64, end: i64): i64 =
    if i >= end { 0 }
    else {
        let byte = load8(src.ptr, i)
        let _ = if byte == 46 { str_push(out, 47) } else { str_push(out, byte) }
        level1c_append_level1b_use_module_path(out, src, i + 1, end)
    }

def level1c_collect_level1b_use_line(src: Str, line_start: i64, line_end: i64, out: Vec): i64 = {
    let left = level1c_skip_inline_space(src, line_start, line_end)
    let right = level1c_trim_right_inline_space(src, left, line_end)
    let line_len = right - left
    if line_len < 7 { 0 }
    else if load8(src.ptr, left) != 117 { 0 }
    else if load8(src.ptr, left + 1) != 115 { 0 }
    else if load8(src.ptr, left + 2) != 101 { 0 }
    else if level1c_is_inline_space(load8(src.ptr, left + 3)) == 0 { 0 }
    else {
        let path_start = level1c_skip_inline_space(src, left + 4, right)
        let path_end = level1c_trim_right_inline_space(src, path_start, right)
        let path_len = path_end - path_start
        if path_len < 3 { 0 }
        else if load8(src.ptr, path_end - 1) != 42 { 0 }
        else if load8(src.ptr, path_end - 2) != 46 { 0 }
        else {
            let resolved = str_new()
            let _ = str_push_cstr(resolved, "level-1b/")
            let _ = level1c_append_level1b_use_module_path(resolved, src, path_start, path_end - 2)
            let _ = str_push_cstr(resolved, ".chiba")
            if level1c_str_vec_contains(out, resolved, 0) != 0 { 0 }
            else { vec_push(out, resolved as i64) }
        }
    }
}

def level1c_collect_level1b_use_paths(src: Str, i: i64, out: Vec): i64 =
    if i >= src.len { 0 }
    else {
        let line_end = level1c_find_line_end(src, i)
        let _ = level1c_collect_level1b_use_line(src, i, line_end, out)
        let next = level1c_skip_line_breaks(src, line_end)
        level1c_collect_level1b_use_paths(src, next, out)
    }

def level1c_collect_level1b_items_once(path: Str, seen: Vec): AST =
    if level1c_str_vec_contains(seen, path, 0) != 0 { Item_End }
    else {
        let _ = vec_push(seen, path as i64)
        match level1c_parse_file(path) {
            OK(ast, _) => {
                let src = file_read_file_all_sized(str_to_cstr(path))
                let imports = vec_new()
                let _ = level1c_collect_level1b_use_paths(src, 0, imports)
                let imported_items = level1c_collect_level1b_import_items(imports, 0, seen)
                level1c_ast_item_append(np_source_items(level1c_target_ast(ast as AST)), imported_items)
            }
            Err(_, _) => Item_End
        }
    }

def level1c_collect_level1b_import_items(paths: Vec, i: i64, seen: Vec): AST =
    if i >= vec_len(paths) { Item_End }
    else {
        let path = vec_get(paths, i) as Str
        level1c_ast_item_append(level1c_collect_level1b_items_once(path, seen), level1c_collect_level1b_import_items(paths, i + 1, seen))
    }

def level1c_target_ast_with_level1b_imports(path: Str, ast: AST): AST = {
    let src = file_read_file_all_sized(str_to_cstr(path))
    let imports = vec_new()
    let seen = vec_new()
    let _ = vec_push(seen, path as i64)
    let _ = level1c_collect_level1b_use_paths(src, 0, imports)
    let imported_items = level1c_collect_level1b_import_items(imports, 0, seen)
    match level1c_target_ast(ast) {
        SourceFile(attrs, ns, items) => SourceFile(attrs, ns, level1c_ast_item_append(items, imported_items))
        other => other
    }
}

def level1c_project_merged_ast(part_a: AST, part_b: AST, consumer: AST): AST =
    SourceFile(
        Attr_End,
        Namespace(Path_End),
        level1c_ast_item_append(
            np_source_items(level1c_target_ast(consumer)),
            level1c_ast_item_append(np_source_items(level1c_target_ast(part_a)), np_source_items(level1c_target_ast(part_b)))
        )
    )

def level1c_run_check_project(root: Str): i64 = {
    let src_dir = level1c_project_src_dir(root)
    if level1c_project_has_entry(src_dir, "part_a.chiba") == 0 {
        let _ = write_fd(2, "project missing src/part_a.chiba\n", 33)
        3
    } else if level1c_project_has_entry(src_dir, "part_b.chiba") == 0 {
        let _ = write_fd(2, "project missing src/part_b.chiba\n", 33)
        3
    } else if level1c_project_has_entry(src_dir, "use_both.chiba") == 0 {
        let _ = write_fd(2, "project missing src/use_both.chiba\n", 35)
        3
    } else {
        let part_a_path = level1c_path_join_src(root, "part_a.chiba")
        let part_b_path = level1c_path_join_src(root, "part_b.chiba")
        let consumer_path = level1c_path_join_src(root, "use_both.chiba")
        match level1c_project_parse_required(part_a_path) {
            OK(part_a, _) =>
                match level1c_project_parse_required(part_b_path) {
                    OK(part_b, _) =>
                        match level1c_project_parse_required(consumer_path) {
                            OK(consumer, _) =>
                                match namespace_project_check(level1c_target_ast(part_a as AST), level1c_target_ast(part_b as AST), level1c_target_ast(consumer as AST)) {
                                    NamespaceProjectCheckOk => {
                                        let _ = write_fd(1, "check project ok\n", 17)
                                        0
                                    }
                                    NamespaceProjectCheckErr(message) => {
                                        let _ = str_write_to(message, 2)
                                        let _ = write_fd(2, "\n", 1)
                                        3
                                    }
                                }
                            Err(_, _) => {
                                let _ = write_fd(2, "parse failed: use_both.chiba\n", 29)
                                2
                            }
                        }
                    Err(_, _) => {
                        let _ = write_fd(2, "parse failed: part_b.chiba\n", 27)
                        2
                    }
                }
            Err(_, _) => {
                let _ = write_fd(2, "parse failed: part_a.chiba\n", 27)
                2
            }
        }
    }
}

def level1c_run_wat_project(root: Str): i64 = {
    let src_dir = level1c_project_src_dir(root)
    if level1c_project_has_entry(src_dir, "part_a.chiba") == 0 {
        let _ = write_fd(2, "project missing src/part_a.chiba\n", 33)
        3
    } else if level1c_project_has_entry(src_dir, "part_b.chiba") == 0 {
        let _ = write_fd(2, "project missing src/part_b.chiba\n", 33)
        3
    } else if level1c_project_has_entry(src_dir, "use_both.chiba") == 0 {
        let _ = write_fd(2, "project missing src/use_both.chiba\n", 35)
        3
    } else {
        let part_a_path = level1c_path_join_src(root, "part_a.chiba")
        let part_b_path = level1c_path_join_src(root, "part_b.chiba")
        let consumer_path = level1c_path_join_src(root, "use_both.chiba")
        match level1c_project_parse_required(part_a_path) {
            OK(part_a, _) =>
                match level1c_project_parse_required(part_b_path) {
                    OK(part_b, _) =>
                        match level1c_project_parse_required(consumer_path) {
                            OK(consumer, _) =>
                                match namespace_project_check(level1c_target_ast(part_a as AST), level1c_target_ast(part_b as AST), level1c_target_ast(consumer as AST)) {
                                    NamespaceProjectCheckOk => {
                                        let merged = level1c_project_merged_ast(part_a as AST, part_b as AST, consumer as AST)
                                        let core = cir_nanopass_l8(merged)
                                        if wat_module_validated(core) == 0 {
                                            let _ = write_fd(2, "validated Core required for wat emit\n", 37)
                                            2
                                        } else {
                                            let rendered = wat_emit_module(core)
                                            let _ = str_write_to(rendered, 1)
                                            0
                                        }
                                    }
                                    NamespaceProjectCheckErr(message) => {
                                        let _ = str_write_to(message, 2)
                                        let _ = write_fd(2, "\n", 1)
                                        3
                                    }
                                }
                            Err(_, _) => {
                                let _ = write_fd(2, "parse failed: use_both.chiba\n", 29)
                                2
                            }
                        }
                    Err(_, _) => {
                        let _ = write_fd(2, "parse failed: part_b.chiba\n", 27)
                        2
                    }
                }
            Err(_, _) => {
                let _ = write_fd(2, "parse failed: part_a.chiba\n", 27)
                2
            }
        }
    }
}

def level1c_run_cir(path: Str): i64 =
    match level1c_parse_file(path) {
        OK(ast, _) => {
            let l1 = alpha_module(cir_lower_module(level1c_target_ast(ast as AST)))
            let rendered = cir_show_module(l1)
            let _ = str_write_to(rendered, 1)
            0
        }
        Err(_, _) => {
            let _ = write_fd(2, "parse failed\n", 13)
            2
        }
    }

