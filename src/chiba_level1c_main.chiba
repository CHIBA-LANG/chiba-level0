    }

def level1c_run_type_smoke(path: Str): i64 = {
    let out = str_new()
    let tv_user = CirTyVarMeta {
        id: CirTyVarId { id: 0 },
        level: 0,
        scope: 1,
        origin: CirTyOriginUserGeneric(mk_str("T", 1)),
        kind: CirTyKindValue,
        visibility: CirTyVisibleUser,
        rigidity: CirTyRigid
    }
    let tv_param = CirTyVarMeta {
        id: CirTyVarId { id: 1 },
        level: 1,
        scope: 1,
        origin: CirTyOriginImplicitParam(mk_str("value", 5)),
        kind: CirTyKindValue,
        visibility: CirTyVisibleSynthetic,
        rigidity: CirTyFlexible
    }
    let row = CirRowMeta {
        id: CirRowId { id: 7 },
        closed: 0,
        fields: CirRowFieldCons(CirRowField { field_name: mk_str("name", 4), ty: CirTyStr }, CirRowFieldCons(CirRowField { field_name: mk_str("age", 3), ty: CirTyI64 }, CirRowFieldEnd)),
        tail: CirTyVar(CirTyVarId { id: 2 })
    }
    let nominal = CirNominalId { id: 3, module_name: mk_str("semantic.gates", 14), local_name: mk_str("User", 4) }
    let t0 = CirTyVar(CirTyVarId { id: 0 })
    let t1 = CirTyVar(CirTyVarId { id: 1 })
    let fn_ty = CirTyFn(CirTypeCons(CirTyTuple(CirTypeCons(CirTyI64, CirTypeCons(CirTyBool, CirTypeEnd))), CirTypeCons(CirTyRow(CirRowId { id: 7 }), CirTypeEnd)), CirTyNominal(nominal, CirTypeCons(t0, CirTypeEnd)))
    let constraints = CirConstraintCons(CirConstraintEq(t1, CirTyRef(CirTyString)), CirConstraintCons(CirConstraintFieldType(CirTyRow(CirRowId { id: 7 }), mk_str("name", 4), CirTyStr), CirConstraintCons(CirConstraintAbi(CirTyI32, CirExternAbiWasi), CirConstraintEnd)))
    let obligations = CirObligationCons(CirObligationField(CirTyRow(CirRowId { id: 7 }), mk_str("name", 4), CirTyStr), CirObligationCons(CirObligationOperator(mk_str("op_add", 6), t0, CirTypeCons(t0, CirTypeEnd), t0, CirBehaviorDefaultVisible), CirObligationCons(CirObligationMethod(CirTyNominal(nominal, CirTypeEnd), mk_str("len", 3), CirTypeEnd, CirTyUsize, CirBehaviorQualifiedPath(mk_str("semantic.gates.User.len", 23))), CirObligationCons(CirObligationContinuationCapability(CirTyContinuation(CirTyI64, CirTyI64, CirContinuationMultiResume), CirContinuationMultiResume), CirObligationEnd))))
    let substs = CirTypeSubstCons(CirTypeSubst { var: CirTyVarId { id: 1 }, ty: CirTyRef(CirTyString) }, CirTypeSubstEnd)
    let _ = cir_show_line(out, 0, "L2TypeSmoke")
    let _ = cir_show_tyvar_meta(out, 1, tv_user)
    let _ = cir_show_tyvar_meta(out, 1, tv_param)
    let _ = cir_show_row_meta(out, 1, row)
    let _ = cir_show_type(out, 1, fn_ty)
    let _ = cir_show_type(out, 1, CirTyPtr(CirTyAtomic(CirTyUsize)))
    let _ = cir_show_type(out, 1, CirTyContinuation(CirTyI64, CirTyBool, CirContinuationLinear))
    let _ = cir_show_constraint_list(out, 1, constraints)
    let _ = cir_show_obligation_list(out, 1, obligations)
    let _ = cir_show_subst_list(out, 1, substs)
    let _ = str_write_to(out, 1)
    0
}

