namespace e2e.test
use metalstd.mem.*
use metalstd.list.*
use metalstd.str.*
use metalstd.test.*
use metalstd.print.*
use metalstd.option.*
use metalstd.process.*
use metalstd.file.*
use frontend.ast.*
use frontend.parser.*
use frontend.resolve.*
use frontend.typecheck.*
use backend.cir.lower.*
use backend.pass.closure.*
use backend.bir.ir.*
use backend.bir.lower.*
use backend.bir.codegen.amd64.*
use project.*

def mk_source_file(path: i64, src: i64): SourceFile =
    SourceFile(mk_str(path, strlen(path)), parse_program(src, strlen(src)))

def compile_and_run(test_name: i64, src: i64): ProcResult = {
    let files = Cons(mk_source_file("e2e_test.chiba", src), Nil)
    let merged = merge_program(files)
    let resolved = resolve(merged)
    match resolved {
        RErr(_) => {
            ProcResult(1, str_new())
        }
        ROk(module) => {
            let tc_errs = typecheck_program(merged, module)
            if is_nil(tc_errs) == 0 {
                ProcResult(1, str_new())
            } else {
                let cps0 = lower(merged, module)
                let cps = closure_convert(cps0)
                let bir = lower_cps_to_bir(cps)
                let _ = bir_validate_program(bir)
                let asm_text = codegen_amd64(bir)

                let s_path = str_new()
                let _ = str_push_cstr(s_path, "runtime/")
                let _ = append_e2e_path_name(s_path, test_name, 0)
                let _ = str_push_cstr(s_path, ".S")
                let _ = str_null_terminate(s_path)
                let s_path_c = mk_cstr_view(s_path.ptr, s_path.len)

                let out_path = str_new()
                let _ = str_push_cstr(out_path, "runtime/")
                let _ = append_e2e_path_name(out_path, test_name, 0)
                let _ = str_push_cstr(out_path, ".out")
                let _ = str_null_terminate(out_path)
                let out_path_c = mk_cstr_view(out_path.ptr, out_path.len)

                let _ = file_write_file_all(s_path_c, asm_text)

                let cmd = str_new()
                let _ = str_push_cstr(cmd, "PATH=/usr/bin:/bin /usr/bin/gcc -nostdlib -static -no-pie -o ")
                let _ = str_append_raw(cmd, out_path_c.ptr, out_path_c.len)
                let _ = str_push_cstr(cmd, " ")
                let _ = str_append_raw(cmd, s_path_c.ptr, s_path_c.len)
                let _ = str_push_cstr(cmd, " -x assembler-with-cpp src/backend/bir/chiba_rt.s 2>&1")
                let _ = str_null_terminate(cmd)
                let cmd_c = mk_cstr_view(cmd.ptr, cmd.len)
                let compile_res = proc_run_capture(c"/bin/sh", Cons(c"sh", Cons(c"-c", Cons(cmd_c, Nil))))
                if proc_result_status(compile_res) != 0 { compile_res }
                else {
                    proc_run_capture(out_path_c, Cons(out_path_c, Nil))
                }
            }
        }
    }
}

def append_e2e_path_name(s: Str, p: i64, i: i64): i64 = {
    let ch = load8(p, i)
    if ch == 0 { 0 }
    else {
        let _ = str_push(s, if ch == 32 { 95 } else { ch })
        append_e2e_path_name(s, p, i + 1)
    }
}

def expect_e2e(ctx: i64, label: i64, src: i64, expected: i64): i64 = {
    let res = compile_and_run(label, src)
    let _ = assert_eq(ctx, label, proc_result_status(res), 0)
    let out_label = str_new()
    let _ = str_append_cstr(out_label, label)
    let _ = str_push_cstr(out_label, " stdout")
    let _ = str_null_terminate(out_label)
    let _ = assert_true(ctx, out_label.ptr, streq(proc_result_stdout(res), mk_str(expected, strlen(expected))))
    0
}

def test_e2e(ctx: i64): i64 = {
    let _ = write_fd(1, "-- E2E tests --\n", 16)

    let _ = expect_e2e(ctx, "e2e dec literal",
        "namespace e2e\ndef answer(): i64 = 42\n#[entry]\ndef main(argc: i64, argv: i64): i64 = answer()",
        "42\n")

    let _ = expect_e2e(ctx, "e2e hex literal",
        "namespace e2e\ndef answer(): i64 = 0xFF\n#[entry]\ndef main(argc: i64, argv: i64): i64 = answer()",
        "255\n")

    let _ = expect_e2e(ctx, "e2e oct literal",
        "namespace e2e\ndef answer(): i64 = 0o77\n#[entry]\ndef main(argc: i64, argv: i64): i64 = answer()",
        "63\n")

    let _ = expect_e2e(ctx, "e2e bin literal",
        "namespace e2e\ndef answer(): i64 = 0b1010\n#[entry]\ndef main(argc: i64, argv: i64): i64 = answer()",
        "10\n")

    let _ = expect_e2e(ctx, "e2e hex mixed",
        "namespace e2e\ndef answer(): i64 = 0xFF + 1\n#[entry]\ndef main(argc: i64, argv: i64): i64 = answer()",
        "256\n")

    let _ = expect_e2e(ctx, "e2e bool true",
        "namespace e2e\ndef answer(): i64 = true\n#[entry]\ndef main(argc: i64, argv: i64): i64 = answer()",
        "1\n")

    let _ = expect_e2e(ctx, "e2e for break",
        "namespace e2e\ndef run(): i64 = { for { break } 0 }\n#[entry]\ndef main(argc: i64, argv: i64): i64 = run()",
        "0\n")

    let _ = expect_e2e(ctx, "e2e for true break",
        "namespace e2e\ndef run(): i64 = { for true { break } 42 }\n#[entry]\ndef main(argc: i64, argv: i64): i64 = run()",
        "42\n")

    let _ = expect_e2e(ctx, "e2e for cond break",
        "namespace e2e\ndef run(): i64 = { for 1 != 0 { break } 42 }\n#[entry]\ndef main(argc: i64, argv: i64): i64 = run()",
        "42\n")

    0
}