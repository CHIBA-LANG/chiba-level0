        OpGtEq,
        OpRange,
        OpBitAnd,
        OpBitXor,
        OpBitOr,
        OpAnd,
        OpOr,
        OpPipeGt,
    }

    def block_prepend_stmt(stmt: AST, body: AST): AST =
        match body {
            Expr_Block(stmts, tail) => Expr_Block(Stmt_Cons(stmt, stmts), tail)
            _ => Expr_Block(Stmt_Cons(stmt, Stmt_End), TailExpr_None)
        }

    def block_expr_or_stmt(value: AST, rest: AST): AST =
        match rest {
            BlockExprOrStmt_Stmt(body) => block_prepend_stmt(Stmt_Expr(value), body)
            _ => Expr_Block(Stmt_End, TailExpr_Some(value))
        }

    def expr_apply_match_ident_rest(base: AST, rest: AST): AST =
        match rest {
            MatchIdent_Call(args, tail) => expr_apply_match_ident_rest(Expr_Call(base, args), tail)
            MatchIdent_Field(field, tail) => expr_apply_match_ident_rest(Expr_Field(base, field), tail)
            MatchIdent_Index(args, tail) => expr_apply_match_ident_rest(Expr_Index(base, args), tail)
            MatchIdent_Name => base
            _ => base
        }

    def expr_from_match_ident_rest(name: Str, rest: AST): AST =
        expr_apply_match_ident_rest(Expr_Name(name), rest)

    def data_body_from_first(first: Str, rest: AST): AST =
        match rest {
            DataAfterFirst_Record(ty, tail) =>
                DataBody_Record(NominalField_Cons(NominalField(first, ty), tail))
            DataAfterFirst_Variant(args, tail) =>
                DataBody_Variants(AdtVariant_Cons(AdtVariant(first, args), tail))
            _ => DataBody_Variants(AdtVariant_End)
        }

    def data_item_from_body(name: Str, generics: AST, body: AST): AST =
        match body {
            DataBody_Record(fields) => AdtRecordItem(name, generics, fields)
            DataBody_Variants(variants) => AdtItem(name, generics, variants)
            _ => AdtItem(name, generics, AdtVariant_End)
        }
}
