def parse_source(src: Str): LabeledAST = {
    let tokens = source_token_tags(src)
    match parse_rule_4(tokens, 0) {
        MatchOK(ast, pos, recovered) => {
            if pos == vec_len(tokens) && recovered == 0 { OK(ast, token_prefix(tokens, pos)) }
            else { Err(Some(ast), token_prefix(tokens, pos)) }
        }
        MatchFail(fail_pos) => Err(None, token_prefix(tokens, fail_pos))
    }
}

