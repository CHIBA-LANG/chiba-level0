    else { LEX_MODE_CODE() }

def lex_new_ctx(src: i64, src_len: i64): LexerCtx =
    LexerCtx { src: src, src_len: src_len, pos: 0, line: 1, col: 1, mode: LEX_MODE_CODE(), mode_stack: vec_new(), user_stack: vec_new(), emit: vec_new(), error: None }

def lex_ctx_make(src: i64, src_len: i64, pos: i64, line: i64, col: i64, mode: i64, mode_stack: Vec, user_stack: Vec[UserStack], emit: Vec, error: Option[i64]): LexerCtx =
    LexerCtx { src: src, src_len: src_len, pos: pos, line: line, col: col, mode: mode, mode_stack: mode_stack, user_stack: user_stack, emit: emit, error: error }

def lex_push_mode(ctx: LexerCtx, mode: i64): LexerCtx = {
    let stack = ctx.mode_stack
    let _ = vec_push(stack, ctx.mode)
    lex_ctx_make(ctx.src, ctx.src_len, ctx.pos, ctx.line, ctx.col, mode, stack, ctx.user_stack, ctx.emit, ctx.error)
}

def lex_pop_mode(ctx: LexerCtx): LexerCtx =
    if vec_len(ctx.mode_stack) <= 0 { ctx }
    else {
        let stack = ctx.mode_stack
        let mode = vec_pop(stack)
        lex_ctx_make(ctx.src, ctx.src_len, ctx.pos, ctx.line, ctx.col, mode, stack, ctx.user_stack, ctx.emit, ctx.error)
    }

def lex_clear_emit(ctx: LexerCtx): LexerCtx =
    lex_ctx_make(ctx.src, ctx.src_len, ctx.pos, ctx.line, ctx.col, ctx.mode, ctx.mode_stack, ctx.user_stack, vec_new(), ctx.error)

def lex_update_pos(src: i64, from: i64, to: i64, line: i64, col: i64): LexPosInfo =
    if from >= to { LexPosInfo { line: line, col: col } }
    else {
        let b = load8(src, from)
        if b == 10 { lex_update_pos(src, from + 1, to, line + 1, 1) }
        else { lex_update_pos(src, from + 1, to, line, col + 1) }
    }

def lex_ctx_advance(ctx: LexerCtx, by: i64): LexerCtx = {
    let next = ctx.pos + by
    let info = lex_update_pos(ctx.src, ctx.pos, next, ctx.line, ctx.col)
    lex_ctx_make(ctx.src, ctx.src_len, next, info.line, info.col, ctx.mode, ctx.mode_stack, ctx.user_stack, ctx.emit, ctx.error)
}

def lex_ctx_skip(ctx: LexerCtx, by: i64): LexerCtx = {
    let next = lex_ctx_advance(ctx, by)
    lex_ctx_make(next.src, next.src_len, next.pos, next.line, next.col, next.mode, next.mode_stack, next.user_stack, vec_new(), None)
}

def lex_ctx_emit(ctx: LexerCtx, by: i64, tok: Token): LexerCtx = {
    let next = lex_ctx_advance(ctx, by)
    let emit = vec_new()
    let _ = vec_push(emit, tok as i64)
    lex_ctx_make(next.src, next.src_len, next.pos, next.line, next.col, next.mode, next.mode_stack, next.user_stack, emit, None)
}

def lex_flush_emit(out: Vec, emit: Vec, span: Span, i: i64): i64 =
    if i >= vec_len(emit) { 0 }
    else {
        let tok = vec_get(emit, i) as Token
        let _ = vec_push(out, TokenSpan { token: tok, span: span } as i64)
        lex_flush_emit(out, emit, span, i + 1)
    }

def lex_action(rule: i64, ctx: LexerCtx, s: Str, span: Span): LexerCtx =
    if rule == 0 { lex_ctx_emit(ctx, s.len, Newline(s)) }
    else if rule == 1 { lex_ctx_skip(ctx, s.len) }
    else if rule == 2 { lex_ctx_emit(ctx, s.len, LineComment(s)) }
    else if rule == 3 { string_open(ctx, s) }
    else if rule == 4 { lex_ctx_emit(ctx, s.len, KwNamespace) }
    else if rule == 5 { lex_ctx_emit(ctx, s.len, KwDef) }
    else if rule == 6 { lex_ctx_emit(ctx, s.len, KwType) }
    else if rule == 7 { lex_ctx_emit(ctx, s.len, KwData) }
    else if rule == 8 { lex_ctx_emit(ctx, s.len, KwUnion) }
    else if rule == 9 { lex_ctx_emit(ctx, s.len, KwLet) }
    else if rule == 10 { lex_ctx_emit(ctx, s.len, KwIf) }
    else if rule == 11 { lex_ctx_emit(ctx, s.len, KwElse) }
    else if rule == 12 { lex_ctx_emit(ctx, s.len, KwMatch) }
    else if rule == 13 { lex_ctx_emit(ctx, s.len, KwExtern) }
    else if rule == 14 { lex_ctx_emit(ctx, s.len, KwUnsafe) }
    else if rule == 15 { lex_ctx_emit(ctx, s.len, KwReset) }
    else if rule == 16 { lex_ctx_emit(ctx, s.len, KwShift) }
    else if rule == 17 { lex_ctx_emit(ctx, s.len, KwTrue) }
    else if rule == 18 { lex_ctx_emit(ctx, s.len, KwFalse) }
    else if rule == 19 { lex_ctx_emit(ctx, s.len, KwAs) }
    else if rule == 20 { lex_ctx_emit(ctx, s.len, KwUse) }
    else if rule == 21 { lex_ctx_emit(ctx, s.len, KwPrivate) }
    else if rule == 22 { lex_ctx_emit(ctx, s.len, KwAsm) }
    else if rule == 23 { lex_ctx_emit(ctx, s.len, KwFor) }
    else if rule == 24 { lex_ctx_emit(ctx, s.len, KwBreak) }
    else if rule == 25 { lex_ctx_emit(ctx, s.len, KwContinue) }
    else if rule == 26 { lex_ctx_emit(ctx, s.len, KwReturn) }
    else if rule == 27 { lex_ctx_emit(ctx, s.len, KwUnique) }
    else if rule == 28 { lex_ctx_emit(ctx, s.len, KwSend) }
    else if rule == 29 { ident_or_string_open(ctx, s) }
    else if rule == 30 { lex_ctx_emit(ctx, s.len, FloatLit(s)) }
    else if rule == 31 { lex_ctx_emit(ctx, s.len, FloatLit(s)) }
    else if rule == 32 { lex_ctx_emit(ctx, s.len, IntLit(s)) }
    else if rule == 33 { lex_ctx_emit(ctx, s.len, Atom(mk_str(s.ptr + 1, s.len - 1))) }
    else if rule == 34 { lex_ctx_emit(ctx, s.len, FileAttrStart) }
    else if rule == 35 { lex_ctx_emit(ctx, s.len, ItemAttrStart) }
    else if rule == 36 { lex_ctx_emit(ctx, s.len, Hash) }
    else if rule == 37 { lex_ctx_emit(ctx, s.len, PipeGt) }
    else if rule == 38 { lex_ctx_emit(ctx, s.len, ColonEq) }
    else if rule == 39 { lex_ctx_emit(ctx, s.len, DotStar) }
    else if rule == 40 { lex_ctx_emit(ctx, s.len, DotDot) }
    else if rule == 41 { lex_ctx_emit(ctx, s.len, FatArrow) }
    else if rule == 42 { lex_ctx_emit(ctx, s.len, ThinArrow) }
    else if rule == 43 { lex_ctx_emit(ctx, s.len, EqEq) }
    else if rule == 44 { lex_ctx_emit(ctx, s.len, BangEq) }
    else if rule == 45 { lex_ctx_emit(ctx, s.len, LtEq) }
    else if rule == 46 { lex_ctx_emit(ctx, s.len, GtEq) }
    else if rule == 47 { lex_ctx_emit(ctx, s.len, LtLt) }
    else if rule == 48 { lex_ctx_emit(ctx, s.len, GtGt) }
    else if rule == 49 { lex_ctx_emit(ctx, s.len, AmpAmp) }
    else if rule == 50 { lex_ctx_emit(ctx, s.len, PipePipe) }
    else if rule == 51 { lex_ctx_emit(ctx, s.len, Eq) }
    else if rule == 52 { lex_ctx_emit(ctx, s.len, Plus) }
    else if rule == 53 { lex_ctx_emit(ctx, s.len, Minus) }
    else if rule == 54 { lex_ctx_emit(ctx, s.len, Star) }
    else if rule == 55 { lex_ctx_emit(ctx, s.len, Slash) }
    else if rule == 56 { lex_ctx_emit(ctx, s.len, Percent) }
    else if rule == 57 { lex_ctx_emit(ctx, s.len, Lt) }
    else if rule == 58 { lex_ctx_emit(ctx, s.len, Gt) }
    else if rule == 59 { lex_ctx_emit(ctx, s.len, Bang) }
    else if rule == 60 { lex_ctx_emit(ctx, s.len, Amp) }
    else if rule == 61 { lex_ctx_emit(ctx, s.len, Pipe) }
    else if rule == 62 { lex_ctx_emit(ctx, s.len, Caret) }
    else if rule == 63 { lex_ctx_emit(ctx, s.len, Colon) }
    else if rule == 64 { lex_ctx_emit(ctx, s.len, Comma) }
    else if rule == 65 { lex_ctx_emit(ctx, s.len, Dot) }
    else if rule == 66 { lex_ctx_emit(ctx, s.len, Semicolon) }
    else if rule == 67 { lex_ctx_emit(ctx, s.len, At) }
    else if rule == 68 { lex_ctx_emit(ctx, s.len, Underscore) }
    else if rule == 69 { lex_ctx_emit(ctx, s.len, LParen) }
    else if rule == 70 { lex_ctx_emit(ctx, s.len, RParen) }
    else if rule == 71 { code_lbrace(ctx, s) }
    else if rule == 72 { code_rbrace(ctx, s) }
    else if rule == 73 { lex_ctx_emit(ctx, s.len, LBracket) }
    else if rule == 74 { lex_ctx_emit(ctx, s.len, RBracket) }
    else if rule == 75 { string_quote(ctx, s) }
    else if rule == 76 { string_enter_interp(ctx, s) }
    else if rule == 77 { string_chunk(ctx, s) }
    else if rule == 78 { string_chunk(ctx, s) }
    else { ctx }

def lex_find_best(pats: Vec, src: i64, sl: i64, pos: i64, mode: i64, i: i64, best_r: i64, best_e: i64): LexBest =
    if i >= vec_len(pats) { LexBest { rule: best_r, end: best_e } }
    else if lex_rule_mode(i) != mode { lex_find_best(pats, src, sl, pos, mode, i + 1, best_r, best_e) }
    else {
        let pat = vec_get(pats, i) as RegexCompiled
        let end = regex_match_at(pat, src, sl, pos)
        if end > best_e {
            lex_find_best(pats, src, sl, pos, mode, i + 1, i, end)
        } else {
            lex_find_best(pats, src, sl, pos, mode, i + 1, best_r, best_e)
        }
    }

def lex_loop(pats: Vec, src: i64, sl: i64, file: i64, out: Vec, ctx: LexerCtx): i64 =
    if ctx.pos >= sl { 0 }
    else {
        let best = lex_find_best(pats, src, sl, ctx.pos, ctx.mode, 0, 0 - 1, ctx.pos)
        if best.rule < 0 || best.end <= ctx.pos {
            let cp = utf8_decode_char(src, ctx.pos)
            let next = utf8_next_offset(src, ctx.pos)
            let span = Span { file: file, line: ctx.line, col: ctx.col, len: next - ctx.pos }
            let _ = vec_push(out, TokenSpan { token: LexError(cp), span: span } as i64)
            let info = lex_update_pos(src, ctx.pos, next, ctx.line, ctx.col)
            let next_ctx = lex_ctx_make(ctx.src, ctx.src_len, next, info.line, info.col, ctx.mode, ctx.mode_stack, ctx.user_stack, vec_new(), Some(cp))
            lex_loop(pats, src, sl, file, out, next_ctx)
        } else {
            let mlen = best.end - ctx.pos
            let s = mk_str(src + ctx.pos, mlen)
            let span = Span { file: file, line: ctx.line, col: ctx.col, len: mlen }
            let next_ctx = lex_action(best.rule, ctx, s, span)
            let _ = lex_flush_emit(out, next_ctx.emit, span, 0)
            let clear_ctx = lex_clear_emit(next_ctx)
            lex_loop(pats, src, sl, file, out, clear_ctx)
        }
    }

def lex_all(src: i64, src_len: i64, file: i64): Vec = {
    let pats = lex_init_patterns()
    let out = vec_new()
    let ctx = lex_new_ctx(src, src_len)
    let _ = lex_loop(pats, src, src_len, file, out, ctx)
    let _ = vec_push(out, TokenSpan { token: Eof, span: Span { file: file, line: 0, col: 0, len: 0 } } as i64)
    out
}
