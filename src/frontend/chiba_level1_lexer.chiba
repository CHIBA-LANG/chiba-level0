    else if rule == 31 { LEX_MODE_CODE() }
    else if rule == 32 { LEX_MODE_CODE() }
    else if rule == 33 { LEX_MODE_CODE() }
    else if rule == 34 { LEX_MODE_CODE() }
    else if rule == 35 { LEX_MODE_CODE() }
    else if rule == 36 { LEX_MODE_CODE() }
    else if rule == 37 { LEX_MODE_CODE() }
    else if rule == 38 { LEX_MODE_CODE() }
    else if rule == 39 { LEX_MODE_CODE() }
    else if rule == 40 { LEX_MODE_CODE() }
    else if rule == 41 { LEX_MODE_CODE() }
    else if rule == 42 { LEX_MODE_CODE() }
