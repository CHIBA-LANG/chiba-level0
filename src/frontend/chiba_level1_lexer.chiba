    let p64 = mk_str("(?:,(?:[ \\t]*\r?\n([ \\t]*\r?\n)*[ \\t]*)?)", 37)
    let _ = vec_push(pats, lex_compile_pat(p64) as i64)
    // rule 65
    let p65 = mk_str("(?:\\.(?:[ \\t]*\r?\n([ \\t]*\r?\n)*[ \\t]*)?)", 38)
    let _ = vec_push(pats, lex_compile_pat(p65) as i64)
    // rule 66
    let p66 = mk_str("(?:;(?:[ \\t]*\r?\n([ \\t]*\r?\n)*[ \\t]*)?)", 37)
    let _ = vec_push(pats, lex_compile_pat(p66) as i64)
    // rule 67
    let p67 = mk_str("(?:@(?:[ \\t]*\r?\n([ \\t]*\r?\n)*[ \\t]*)?)", 37)
    let _ = vec_push(pats, lex_compile_pat(p67) as i64)
    // rule 68
    let p68 = mk_str("(?:_)", 5)
    let _ = vec_push(pats, lex_compile_pat(p68) as i64)
    // rule 69
    let p69 = mk_str("(?:\\((?:[ \\t]*\r?\n([ \\t]*\r?\n)*[ \\t]*)?)", 38)
    let _ = vec_push(pats, lex_compile_pat(p69) as i64)
    // rule 70
    let p70 = mk_str("(?:(?:[ \\t]*\r?\n([ \\t]*\r?\n)*[ \\t]*)?\\))", 38)
    let _ = vec_push(pats, lex_compile_pat(p70) as i64)
    // rule 71
    let p71 = mk_str("(?:\\{(?:[ \\t]*\r?\n([ \\t]*\r?\n)*[ \\t]*)?)", 38)
    let _ = vec_push(pats, lex_compile_pat(p71) as i64)
    // rule 72
    let p72 = mk_str("(?:(?:[ \\t]*\r?\n([ \\t]*\r?\n)*[ \\t]*)?\\})", 38)
    let _ = vec_push(pats, lex_compile_pat(p72) as i64)
    // rule 73
    let p73 = mk_str("(?:\\[(?:[ \\t]*\r?\n([ \\t]*\r?\n)*[ \\t]*)?)", 38)
    let _ = vec_push(pats, lex_compile_pat(p73) as i64)
    // rule 74
    let p74 = mk_str("(?:(?:[ \\t]*\r?\n([ \\t]*\r?\n)*[ \\t]*)?\\])", 38)
    let _ = vec_push(pats, lex_compile_pat(p74) as i64)
    // rule 75
    let p75 = mk_str("(?:\")", 5)
    let _ = vec_push(pats, lex_compile_pat(p75) as i64)
    // rule 76
    let p76 = mk_str("(?:\\{)", 6)
    let _ = vec_push(pats, lex_compile_pat(p76) as i64)
    // rule 77
    let p77 = mk_str("(?:[^\"{}]+)", 11)
    let _ = vec_push(pats, lex_compile_pat(p77) as i64)
    // rule 78
    let p78 = mk_str(".", 1)
    let _ = vec_push(pats, lex_compile_pat(p78) as i64)
    pats
}

def lex_rule_mode(rule: i64): i64 =
    if rule == 0 { LEX_MODE_CODE() }
    else if rule == 1 { LEX_MODE_CODE() }
    else if rule == 2 { LEX_MODE_CODE() }
    else if rule == 3 { LEX_MODE_CODE() }
    else if rule == 4 { LEX_MODE_CODE() }
