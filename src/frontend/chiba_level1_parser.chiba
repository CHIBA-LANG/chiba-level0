def match_token(tokens: Vec, pos: i64, want: Str): MatchResult =
    if streq(want, mk_str("Eof", 3)) != 0 {
        match_token_Eof(tokens, pos)
    }
    else if streq(want, mk_str("LineComment", 11)) != 0 {
        match_token_LineComment(tokens, pos)
    }
    else if streq(want, mk_str("Newline", 7)) != 0 {
        match_token_Newline(tokens, pos)
    }
    else if streq(want, mk_str("FileAttrStart", 13)) != 0 {
