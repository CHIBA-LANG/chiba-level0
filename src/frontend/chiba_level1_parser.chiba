def match_eof(tokens: Vec, pos: i64): MatchResult =
    if pos >= vec_len(tokens) { MatchOK(0 as i64, pos, 0) }
    else {
        let ts = vec_get(tokens, pos) as TokenSpan
        match ts.token {
            Eof => MatchOK(0 as i64, pos + 1, 0)
            _ => MatchFail(pos)
        }
    }

def token_name_matches_span(ts: TokenSpan, name: Str): i64 =
    if streq(name, mk_str("Eof", 3)) != 0 {
        match ts.token {
            Eof => 1
            _ => 0
        }
    }
    else if streq(name, mk_str("LineComment", 11)) != 0 {
        match ts.token {
            LineComment(_) => 1
            _ => 0
        }
    }
    else if streq(name, mk_str("Newline", 7)) != 0 {
        match ts.token {
            Newline(_) => 1
            _ => 0
        }
