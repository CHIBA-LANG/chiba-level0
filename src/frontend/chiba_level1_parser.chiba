data MatchResult {
    MatchOK(i64, i64, i64),
    MatchFail(i64)
}

data LabeledAST {
    OK(i64, Vec),
    Err(Option[i64], Vec)
}

def token_prefix(tokens: Vec, n: i64): Vec =
    token_prefix_loop(tokens, 0, n, vec_new())

def token_prefix_loop(tokens: Vec, i: i64, n: i64, out: Vec): Vec =
    if i >= n || i >= vec_len(tokens) { out }
    else {
        let _ = vec_push(out, vec_get(tokens, i))
        token_prefix_loop(tokens, i + 1, n, out)
    }

def recover_or(a: i64, b: i64): i64 =
    if a != 0 { 1 }
    else if b != 0 { 1 }
    else { 0 }

def match_token_Eof(tokens: Vec, pos: i64): MatchResult =
    if pos < vec_len(tokens) {
        let ts = vec_get(tokens, pos) as TokenSpan
        match ts.token {
            Eof => MatchOK(0 as i64, pos + 1, 0)
            _ => MatchFail(pos)
        }
    }
    else { MatchFail(pos) }

