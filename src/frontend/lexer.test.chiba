namespace frontend.lexer.test
use metalstd.mem.*
use metalstd.list.*
use metalstd.test.*
use metalstd.print.*
use frontend.ast.*
use frontend.lexer.*

def test_lexer(ctx: i64): i64 = {
    let _ = write_fd(1, "-- Lexer tests --\n", 18)

    // Lex a simple integer
    let t1 = lex("42", 2)
    let _ = assert_eq(ctx, "lex int len", length(t1), 2)
    let tok1 = head(t1)
    let v1 = match tok1 { TokInt(v) => v  _ => 0 - 1 }
    let _ = assert_eq(ctx, "lex int val", v1, 42)

    // Lex an identifier
    let t2 = lex("foo", 3)
    let tok2 = head(t2)
    let is_ident = match tok2 { TokIdent(_) => 1  _ => 0 }
    let _ = assert_eq(ctx, "lex ident", is_ident, 1)

    // Lex keyword "def"
    let t3 = lex("def", 3)
    let tok3 = head(t3)
    let is_def = match tok3 { TokKwDef => 1  _ => 0 }
    let _ = assert_eq(ctx, "lex kw def", is_def, 1)

    // Lex operators
    let t4 = lex("+ - * == =>", 11)
    let _ = assert_eq(ctx, "lex ops len", length(t4), 6)
    let is_plus = match nth(t4, 0) { TokPlus => 1  _ => 0 }
    let _ = assert_eq(ctx, "lex plus", is_plus, 1)
    let is_minus = match nth(t4, 1) { TokMinus => 1  _ => 0 }
    let _ = assert_eq(ctx, "lex minus", is_minus, 1)
    let is_star = match nth(t4, 2) { TokStar => 1  _ => 0 }
    let _ = assert_eq(ctx, "lex star", is_star, 1)
    let is_eqeq = match nth(t4, 3) { TokEqEq => 1  _ => 0 }
    let _ = assert_eq(ctx, "lex eqeq", is_eqeq, 1)
    let is_fat = match nth(t4, 4) { TokFatArrow => 1  _ => 0 }
    let _ = assert_eq(ctx, "lex fat_arrow", is_fat, 1)

    // Lex parens/braces
    let t5 = lex("( ) { } [ ]", 11)
    let _ = assert_eq(ctx, "lex delims len", length(t5), 7)
    let is_lp = match nth(t5, 0) { TokLParen => 1  _ => 0 }
    let _ = assert_eq(ctx, "lex lparen", is_lp, 1)
    let is_rb = match nth(t5, 5) { TokRBracket => 1  _ => 0 }
    let _ = assert_eq(ctx, "lex rbracket", is_rb, 1)

    // Lex string literal
    let t6 = lex("\"hello\"", 7)
    let tok6 = head(t6)
    let is_str = match tok6 { TokStr(_) => 1  _ => 0 }
    let _ = assert_eq(ctx, "lex string", is_str, 1)

    // Lex UTF-8 string literal and preserve byte length
    let utf8_src = "\"你好\""
    let t6b = lex(utf8_src, strlen(utf8_src))
    let tok6b = head(t6b)
    let utf8_len = match tok6b { TokStr(s) => s.len  _ => 0 - 1 }
    let _ = assert_eq(ctx, "lex utf8 string byte len", utf8_len, 6)
    let utf8_is_str = match tok6b { TokStr(_) => 1  _ => 0 }
    let _ = assert_eq(ctx, "lex utf8 string", utf8_is_str, 1)

    // Lex c-string literal
    let t6c = lex("c\"hello\"", 8)
    let tok6c = head(t6c)
    let is_cstr = match tok6c { TokCStr(_) => 1  _ => 0 }
    let _ = assert_eq(ctx, "lex cstring", is_cstr, 1)
    let cstr_len = match tok6c { TokCStr(s) => s.len  _ => 0 - 1 }
    let _ = assert_eq(ctx, "lex cstring byte len", cstr_len, 5)

    // Lex UTF-8 c-string literal and preserve byte length
    let utf8_csrc = "c\"你好\""
    let t6d = lex(utf8_csrc, strlen(utf8_csrc))
    let tok6d = head(t6d)
    let utf8_clen = match tok6d { TokCStr(s) => s.len  _ => 0 - 1 }
    let _ = assert_eq(ctx, "lex utf8 cstring byte len", utf8_clen, 6)
    let utf8_is_cstr = match tok6d { TokCStr(_) => 1  _ => 0 }
    let _ = assert_eq(ctx, "lex utf8 cstring", utf8_is_cstr, 1)

    // Lex bitwise operators
    let t7 = lex("& | ^", 5)
    let _ = assert_eq(ctx, "lex bitwise len", length(t7), 4)
    let is_amp = match nth(t7, 0) { TokAmp => 1  _ => 0 }
    let _ = assert_eq(ctx, "lex bitand token", is_amp, 1)
    let is_pipe = match nth(t7, 1) { TokPipe => 1  _ => 0 }
    let _ = assert_eq(ctx, "lex bitor token", is_pipe, 1)
    let is_caret = match nth(t7, 2) { TokCaret => 1  _ => 0 }
    let _ = assert_eq(ctx, "lex bitxor token", is_caret, 1)

    // Lex shifts individually to isolate failures
    let t8 = lex("<<", 2)
    let _ = assert_eq(ctx, "lex shl len", length(t8), 2)
    let is_ltl = match nth(t8, 0) { TokLtLt => 1  _ => 0 }
    let _ = assert_eq(ctx, "lex shl token", is_ltl, 1)

    let t9 = lex(">>", 2)
    let _ = assert_eq(ctx, "lex shr len", length(t9), 2)
    let is_gtg = match nth(t9, 0) { TokGtGt => 1  _ => 0 }
    let _ = assert_eq(ctx, "lex shr token", is_gtg, 1)

    // && and || should still lex as logical operators
    let t10 = lex("&& ||", 5)
    let is_ampamp = match nth(t10, 0) { TokAmpAmp => 1  _ => 0 }
    let _ = assert_eq(ctx, "lex logical and token", is_ampamp, 1)
    let is_pipepipe = match nth(t10, 1) { TokPipePipe => 1  _ => 0 }
    let _ = assert_eq(ctx, "lex logical or token", is_pipepipe, 1)

    0
}
