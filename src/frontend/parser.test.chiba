namespace frontend.parser.test
use metalstd.mem.*
use metalstd.list.*
use metalstd.str.*
use metalstd.test.*
use metalstd.print.*
use frontend.ast.*
use frontend.parser.*

def test_parser_expr(ctx: i64): i64 = {
    let _ = write_fd(1, "-- Parser expr tests --\n", 23)

    // Parse integer literal
    let e1 = parse_expr("42", 2)
    let v1 = match e1 { EInt(v) => v  _ => 0 - 1 }
    let _ = assert_eq(ctx, "parse int", v1, 42)

    // Parse addition
    let e1b = parse_expr("c\"hello\"", 8)
    let is_cstr = match e1b { ECStr(_) => 1  _ => 0 }
    let _ = assert_eq(ctx, "parse cstr literal", is_cstr, 1)
    let cstr_len = match e1b { ECStr(s) => s.len  _ => 0 - 1 }
    let _ = assert_eq(ctx, "parse cstr literal len", cstr_len, 5)

    // Parse addition
    let e2 = parse_expr("1 + 2", 5)
    let is_binop = match e2 { EBinOp(_, _, _) => 1  _ => 0 }
    let _ = assert_eq(ctx, "parse add binop", is_binop, 1)
    let (op2, l2, r2) = match e2 {
        EBinOp(op, l, r) => (op, l, r)
        _ => (OpAdd, EUnit, EUnit)
    }
    let is_add = match op2 { OpAdd => 1  _ => 0 }
    let _ = assert_eq(ctx, "parse add op", is_add, 1)
    let lv = match l2 { EInt(v) => v  _ => 0 - 1 }
    let _ = assert_eq(ctx, "parse add lhs", lv, 1)
    let rv = match r2 { EInt(v) => v  _ => 0 - 1 }
    let _ = assert_eq(ctx, "parse add rhs", rv, 2)

    // Precedence: 1 + 2 * 3  =>  +(1, *(2,3))
    let e3 = parse_expr("1 + 2 * 3", 9)
    let r3 = match e3 {
        EBinOp(_, _, rhs) =>
            match rhs { EBinOp(op, _, _) => match op { OpMul => 1  _ => 0 }  _ => 0 }
        _ => 0
    }
    let _ = assert_eq(ctx, "parse prec mul", r3, 1)

    // Parse variable
    let e4 = parse_expr("foo", 3)
    let is_var = match e4 { EVar(_) => 1  _ => 0 }
    let _ = assert_eq(ctx, "parse var", is_var, 1)

    // Parse call: f(1, 2)
    let e5 = parse_expr("f(1, 2)", 7)
    let is_call = match e5 { ECall(_, _) => 1  _ => 0 }
    let _ = assert_eq(ctx, "parse call", is_call, 1)
    let nargs = match e5 { ECall(_, args) => length(args)  _ => 0 }
    let _ = assert_eq(ctx, "parse call nargs", nargs, 2)

    // Parse if expression
    let e6 = parse_expr("if 1 { 2 } else { 3 }", 22)
    let is_if = match e6 { EIf(_, _, _) => 1  _ => 0 }
    let _ = assert_eq(ctx, "parse if", is_if, 1)

    // Parse match expression
    let e7 = parse_expr("match x { 1 => 10  _ => 20 }", 29)
    let is_match = match e7 { EMatch(_, _) => 1  _ => 0 }
    let _ = assert_eq(ctx, "parse match", is_match, 1)
    let n_arms = match e7 { EMatch(_, arms) => length(arms)  _ => 0 }
    let _ = assert_eq(ctx, "parse match arms", n_arms, 2)

    // Parse block: { let x = 1  x + 2 }
    let e8 = parse_expr("{ let x = 1  x + 2 }", 21)
    let is_block = match e8 { EBlock(_, _) => 1  _ => 0 }
    let _ = assert_eq(ctx, "parse block", is_block, 1)
    let n_stmts = match e8 { EBlock(stmts, _) => length(stmts)  _ => 0 }
    let _ = assert_eq(ctx, "parse block stmts", n_stmts, 1)

    // Parse subtraction: a - 1 (use var so lexer doesn't greedily parse -1)
    let e9 = parse_expr("a - 1", 5)
    let is_sub = match e9 {
        EBinOp(OpSub, _, _) => 1
        _ => 0
    }
    let _ = assert_eq(ctx, "parse sub", is_sub, 1)

    // Parse tuple
    let e10 = parse_expr("(1, 2, 3)", 9)
    let is_tuple = match e10 { ETuple(_) => 1  _ => 0 }
    let _ = assert_eq(ctx, "parse tuple", is_tuple, 1)
    let tup_len = match e10 { ETuple(es) => length(es)  _ => 0 }
    let _ = assert_eq(ctx, "parse tuple len", tup_len, 3)

    // Parse slice literals
    let e10b = parse_expr("[]", 2)
    let is_empty_slice = match e10b { ESliceLit(_) => 1  _ => 0 }
    let _ = assert_eq(ctx, "parse empty slice", is_empty_slice, 1)
    let empty_slice_len = match e10b { ESliceLit(es) => length(es)  _ => 0 - 1 }
    let _ = assert_eq(ctx, "parse empty slice len", empty_slice_len, 0)

    let e10c = parse_expr("[1, 2, 3]", 9)
    let is_slice = match e10c { ESliceLit(_) => 1  _ => 0 }
    let _ = assert_eq(ctx, "parse slice", is_slice, 1)
    let slice_len = match e10c { ESliceLit(es) => length(es)  _ => 0 - 1 }
    let _ = assert_eq(ctx, "parse slice len", slice_len, 3)

    let e10d = parse_expr("[x, y, z]", 9)
    let is_var_slice = match e10d { ESliceLit(_) => 1  _ => 0 }
    let _ = assert_eq(ctx, "parse var slice", is_var_slice, 1)
    let var_slice_len = match e10d { ESliceLit(es) => length(es)  _ => 0 - 1 }
    let _ = assert_eq(ctx, "parse var slice len", var_slice_len, 3)

    // Parse record literal
    let e11 = parse_expr("Point { x: 1, y: 2 }", 20)
    let is_record_lit = match e11 { ERecordLit(_, _) => 1  _ => 0 }
    let _ = assert_eq(ctx, "parse record lit", is_record_lit, 1)
    let field_count = match e11 { ERecordLit(_, fields) => length(fields)  _ => 0 }
    let _ = assert_eq(ctx, "parse record lit fields", field_count, 2)

    // Parse lambda with one parameter
    let e12 = parse_expr("(x: i64): i64 => x", 19)
    let is_lambda = match e12 { ELambda(_, _, _) => 1  _ => 0 }
    let _ = assert_eq(ctx, "parse lambda", is_lambda, 1)
    let lambda_arity = match e12 { ELambda(params, _, _) => length(params)  _ => 0 }
    let _ = assert_eq(ctx, "parse lambda arity", lambda_arity, 1)

    // Parse inline asm
    let e13 = parse_expr("asm (1: rax) : (rax) => { \"syscall\" }", 37)
    let is_asm = match e13 { EAsm(_, _, _) => 1  _ => 0 }
    let _ = assert_eq(ctx, "parse asm", is_asm, 1)

    // Parse else if
    let e15 = parse_expr("if 1 { 2 } else if 3 { 4 } else { 5 }", 39)
    let is_else_if = match e15 {
        EIf(_, _, else_) => match else_ { EIf(_, _, _) => 1  _ => 0 }
        _ => 0
    }
    let _ = assert_eq(ctx, "parse else if", is_else_if, 1)

    // Parse else if let
    let e16 = parse_expr("if 1 { 2 } else if let Some(x) = y { x } else { 0 }", 54)
    let is_else_if_let = match e16 {
        EIf(_, _, else_) => match else_ { EIfLet(_, _, _, _) => 1  _ => 0 }
        _ => 0
    }
    let _ = assert_eq(ctx, "parse else if let", is_else_if_let, 1)

    // Parse record update { e | field: val }
    let e14 = parse_expr("{ v | x: 1 }", 13)
    let is_upd = match e14 { EBlock(_, inner) => match inner { ERecordUpd(_, _) => 1  _ => 0 }  _ => 0 }
    let _ = assert_eq(ctx, "parse record update", is_upd, 1)

    // Parse bitwise and
    let src17 = "1 & 2"
    let e17 = parse_expr(src17, strlen(src17))
    let is_bitand = match e17 { EBinOp(OpBitAnd, _, _) => 1  _ => 0 }
    let _ = assert_eq(ctx, "parse bitand", is_bitand, 1)

    // Parse bitwise or
    let src18 = "1 | 2"
    let e18 = parse_expr(src18, strlen(src18))
    let is_bitor = match e18 { EBinOp(OpBitOr, _, _) => 1  _ => 0 }
    let _ = assert_eq(ctx, "parse bitor", is_bitor, 1)

    // Parse bitwise xor
    let src19 = "1 ^ 2"
    let e19 = parse_expr(src19, strlen(src19))
    let is_bitxor = match e19 { EBinOp(OpBitXor, _, _) => 1  _ => 0 }
    let _ = assert_eq(ctx, "parse bitxor", is_bitxor, 1)

    // Parse shift left
    let src20 = "1 << 2"
    let e20 = parse_expr(src20, strlen(src20))
    let is_shl = match e20 { EBinOp(OpShl, _, _) => 1  _ => 0 }
    let _ = assert_eq(ctx, "parse shl", is_shl, 1)

    // Parse shift right
    let src21 = "8 >> 1"
    let e21 = parse_expr(src21, strlen(src21))
    let is_shr = match e21 { EBinOp(OpShr, _, _) => 1  _ => 0 }
    let _ = assert_eq(ctx, "parse shr", is_shr, 1)

    // Precedence: shift binds tighter than add
    let src22 = "1 + 2 << 3"
    let e22 = parse_expr(src22, strlen(src22))
    let shift_inside_add = match e22 {
        EBinOp(OpAdd, _, rhs) => match rhs { EBinOp(OpShl, _, _) => 1  _ => 0 }
        _ => 0
    }
    let _ = assert_eq(ctx, "parse shift precedence", shift_inside_add, 1)

    // Precedence: bitand binds tighter than bitor
    let src23 = "1 | 2 & 3"
    let e23 = parse_expr(src23, strlen(src23))
    let bitand_inside_bitor = match e23 {
        EBinOp(OpBitOr, _, rhs) => match rhs { EBinOp(OpBitAnd, _, _) => 1  _ => 0 }
        _ => 0
    }
    let _ = assert_eq(ctx, "parse bit precedence", bitand_inside_bitor, 1)

    // Record update must still win inside braces
    let src24 = "{ v | y: zz }"
    let e24 = parse_expr(src24, strlen(src24))
    let is_upd2 = match e24 { EBlock(_, inner) => match inner { ERecordUpd(_, _) => 1  _ => 0 }  _ => 0 }
    let _ = assert_eq(ctx, "parse record update vs bitor", is_upd2, 1)

    0
}

def test_parser_item(ctx: i64): i64 = {
    let _ = write_fd(1, "-- Parser item tests --\n", 23)

    // Parse a function definition
    let items = parse_program_items("def foo(x: i64): i64 = x + 1", 29)
    let _ = assert_eq(ctx, "parse def items", length(items), 1)
    let item0 = head(items)
    let is_fun = match item0 { FunDef(_, _, _, _, _, _, _) => 1  _ => 0 }
    let _ = assert_eq(ctx, "parse def is_fun", is_fun, 1)
    let nparams = match item0 { FunDef(_, _, _, params, _, _, _) => length(params)  _ => 0 }
    let _ = assert_eq(ctx, "parse def nparams", nparams, 1)

    // Parse compile_if attribute body without dropping boolean expression text
    let attr_src = "#[compile_if(all(backend = \"c\", not(target = \"wasm32-unknown-wasm\")))]\ndef cfg(): i64 = 1"
    let attr_items = parse_program_items(attr_src, strlen(attr_src))
    let attr_item = head(attr_items)
    let attr_text = match attr_item { FunDef(_, _, _, _, _, _, attrs) => head(attrs)  _ => str_empty() }
    let expected_attr = "compile_if(all(backend = \"c\", not(target = \"wasm32-unknown-wasm\")))"
    let _ = assert_eq(ctx, "parse compile_if attrs", streq(attr_text, mk_str(expected_attr, strlen(expected_attr))), 1)

    // Parse a data definition
    let items2 = parse_program_items("data Color { Red, Green, Blue }", 31)
    let _ = assert_eq(ctx, "parse data items", length(items2), 1)
    let item1 = head(items2)
    let is_data = match item1 { DataDef(_, _, _, _) => 1  _ => 0 }
    let _ = assert_eq(ctx, "parse data is_data", is_data, 1)
    let nvariants = match item1 { DataDef(_, _, _, vs) => length(vs)  _ => 0 }
    let _ = assert_eq(ctx, "parse data nvars", nvariants, 3)

    // Parse a type definition
    let items3 = parse_program_items("type Point { x: i64  y: i64 }", 30)
    let _ = assert_eq(ctx, "parse type items", length(items3), 1)
    let item2 = head(items3)
    let is_typedef = match item2 { TypeDef(_, _, _, _) => 1  _ => 0 }
    let _ = assert_eq(ctx, "parse type is_type", is_typedef, 1)
    let nfields = match item2 { TypeDef(_, _, _, fs) => length(fs)  _ => 0 }
    let _ = assert_eq(ctx, "parse type nfields", nfields, 2)

    // Parse extern declaration
    let items4 = parse_program_items("def malloc(size: usize): *u8 = extern \"c\" \"malloc\"", 50)
    let _ = assert_eq(ctx, "parse extern items", length(items4), 1)
    let ext = head(items4)
    let is_extern = match ext { ExternDecl(_, _, _, _, _, _, _) => 1  _ => 0 }
    let _ = assert_eq(ctx, "parse extern", is_extern, 1)

    // Parse union definition
    let items5 = parse_program_items("union Val { tag: i64  val: i64 }", 33)
    let _ = assert_eq(ctx, "parse union items", length(items5), 1)
    let un = head(items5)
    let is_union = match un { UnionDef(_, _, _) => 1  _ => 0 }
    let _ = assert_eq(ctx, "parse union", is_union, 1)
    let un_fields = match un { UnionDef(_, _, fs) => length(fs)  _ => 0 }
    let _ = assert_eq(ctx, "parse union nfields", un_fields, 2)

    // Parse private def
    let items6 = parse_program_items("private def bar(): i64 = 0", 26)
    let _ = assert_eq(ctx, "parse private items", length(items6), 1)
    let priv_fun = head(items6)
    let priv_flag = match priv_fun { FunDef(_, p, _, _, _, _, _) => p  _ => 0 - 1 }
    let _ = assert_eq(ctx, "parse private flag", priv_flag, 1)

    // Parse type params on data
    let items7 = parse_program_items("data Maybe[T] { Nothing, Just(T) }", 34)
    let _ = assert_eq(ctx, "parse tparam items", length(items7), 1)
    let tp_data = head(items7)
    let tp_len = match tp_data { DataDef(_, _, tps, _) => length(tps)  _ => 0 }
    let _ = assert_eq(ctx, "parse tparam len", tp_len, 1)

    // Parse use declarations via parse_program
    let prog = parse_program("namespace test\nuse a.b.*\nuse x.y.z\ndef f(): i64 = 0", 52)
    let _ = assert_eq(ctx, "parse uses len", length(prog.uses), 2)
    let _ = assert_true(ctx, "parse ns", streq(prog.ns, mk_str("test", 4)))
    let _ = assert_eq(ctx, "parse prog items", length(prog.items), 1)

    // Parse built-in `str` type syntax
    let items8 = parse_program_items("def s(x: str): str = x", 22)
    let _ = assert_eq(ctx, "parse str items", length(items8), 1)
    let str_fun = head(items8)
    let str_param_is_builtin = match str_fun {
        FunDef(_, _, _, params, ret, _, _) =>
            match head(params) {
                Param(_, TyStr) => 1
                _ => 0
            }
        _ => 0
    }
    let _ = assert_eq(ctx, "parse str param", str_param_is_builtin, 1)
    let str_ret_is_builtin = match str_fun {
        FunDef(_, _, _, _, TyStr, _, _) => 1
        _ => 0
    }
    let _ = assert_eq(ctx, "parse str ret", str_ret_is_builtin, 1)

    // Parse built-in `cstr` type syntax
    let items9 = parse_program_items("def s(x: cstr): cstr = x", 24)
    let _ = assert_eq(ctx, "parse cstr items", length(items9), 1)
    let cstr_fun = head(items9)
    let cstr_param_is_builtin = match cstr_fun {
        FunDef(_, _, _, params, ret, _, _) =>
            match head(params) {
                Param(_, TyCStr) => 1
                _ => 0
            }
        _ => 0
    }
    let _ = assert_eq(ctx, "parse cstr param", cstr_param_is_builtin, 1)
    let cstr_ret_is_builtin = match cstr_fun {
        FunDef(_, _, _, _, TyCStr, _, _) => 1
        _ => 0
    }
    let _ = assert_eq(ctx, "parse cstr ret", cstr_ret_is_builtin, 1)

    // Parse `String` type syntax
    let items10 = parse_program_items("def s(x: String): String = x", 28)
    let _ = assert_eq(ctx, "parse String items", length(items10), 1)
    let string_fun = head(items10)
    let string_param_is_named = match string_fun {
        FunDef(_, _, _, params, ret, _, _) =>
            match head(params) {
                Param(_, TyNamed(name, args)) =>
                    if streq(name, mk_str("String", 6)) != 0 { is_nil(args) }
                    else { 0 }
                _ => 0
            }
        _ => 0
    }
    let _ = assert_eq(ctx, "parse String param", string_param_is_named, 1)
    let string_ret_is_named = match string_fun {
        FunDef(_, _, _, _, TyNamed(name, args), _, _) =>
            if streq(name, mk_str("String", 6)) != 0 { is_nil(args) }
            else { 0 }
        _ => 0
    }
    let _ = assert_eq(ctx, "parse String ret", string_ret_is_named, 1)

    // Parse `slice[T]` type syntax
    let items10 = parse_program_items("def s(x: slice[i64]): slice[i64] = x", 38)
    let _ = assert_eq(ctx, "parse slice items", length(items10), 1)
    let slice_fun = head(items10)
    let slice_param_is_named = match slice_fun {
        FunDef(_, _, _, params, _, _, _) =>
            match head(params) {
                Param(_, TyNamed(name, args)) =>
                    if streq(name, mk_str("slice", 5)) {
                        match args {
                            Cons(TyI64, Nil) => 1
                            _ => 0
                        }
                    } else { 0 }
                _ => 0
            }
        _ => 0
    }
    let _ = assert_eq(ctx, "parse slice param", slice_param_is_named, 1)
    let slice_ret_is_named = match slice_fun {
        FunDef(_, _, _, _, TyNamed(name, args), _, _) =>
            if streq(name, mk_str("slice", 5)) {
                match args {
                    Cons(TyI64, Nil) => 1
                    _ => 0
                }
            } else { 0 }
        _ => 0
    }
    let _ = assert_eq(ctx, "parse slice ret", slice_ret_is_named, 1)

    // Parse `Vector[T]` type syntax
    let items11 = parse_program_items("def s(x: Vector[i64]): Vector[i64] = x", 40)
    let _ = assert_eq(ctx, "parse Vector items", length(items11), 1)
    let vector_fun = head(items11)
    let vector_param_is_named = match vector_fun {
        FunDef(_, _, _, params, _, _, _) =>
            match head(params) {
                Param(_, TyNamed(name, args)) =>
                    if streq(name, mk_str("Vector", 6)) {
                        match args {
                            Cons(TyI64, Nil) => 1
                            _ => 0
                        }
                    } else { 0 }
                _ => 0
            }
        _ => 0
    }
    let _ = assert_eq(ctx, "parse Vector param", vector_param_is_named, 1)
    let vector_ret_is_named = match vector_fun {
        FunDef(_, _, _, _, TyNamed(name, args), _, _) =>
            if streq(name, mk_str("Vector", 6)) {
                match args {
                    Cons(TyI64, Nil) => 1
                    _ => 0
                }
            } else { 0 }
        _ => 0
    }
    let _ = assert_eq(ctx, "parse Vector ret", vector_ret_is_named, 1)

    0
}
