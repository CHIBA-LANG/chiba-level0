namespace frontend.resolve.test
use metalstd.mem.*
use metalstd.list.*
use metalstd.str.*
use metalstd.map.*
use metalstd.test.*
use metalstd.print.*
use frontend.ast.*
use frontend.parser.*
use frontend.resolve.*

// ── Resolve helpers ─────────────────────────────────────────────────────────

def resolve_ok(r: ResolveResult): i64 =
    match r { ROk(_) => 1  RErr(_) => 0 }

def resolve_errs(r: ResolveResult): List[Str] =
    match r { ROk(_) => Nil  RErr(es) => es }

def resolve_module(r: ResolveResult): Module =
    match r { ROk(m) => m  RErr(_) => 0 as Module }

def str_match_at(h_ptr: i64, n_ptr: i64, n_len: i64, i: i64): i64 =
    if i >= n_len { 1 }
    else {
        if load8(h_ptr + i, 0) == load8(n_ptr + i, 0) {
            str_match_at(h_ptr, n_ptr, n_len, i + 1)
        } else { 0 }
    }

def str_contains_loop(h_ptr: i64, h_len: i64, n_ptr: i64, n_len: i64, pos: i64): i64 =
    if pos + n_len > h_len { 0 }
    else {
        if str_match_at(h_ptr + pos, n_ptr, n_len, 0) != 0 { 1 }
        else { str_contains_loop(h_ptr, h_len, n_ptr, n_len, pos + 1) }
    }

def str_contains(haystack: Str, needle: Str): i64 =
    if needle.len == 0 { 1 }
    else { str_contains_loop(haystack.ptr, haystack.len, needle.ptr, needle.len, 0) }

def consinfo_tag(ci: ConsInfo): i64 =
    match ci { ConsInfo(_, t, _) => t }

def consinfo_arity(ci: ConsInfo): i64 =
    match ci { ConsInfo(_, _, a) => a }

def datainfo_is_rec(di: DataInfo): i64 =
    match di { DataInfo(_, _, _, r) => r }

// ── Resolve tests ───────────────────────────────────────────────────────────

def test_resolve(ctx: i64): i64 = {
    let _ = write_fd(1, "-- Resolve tests --\n", 20)

    // 1. Simple OK
    let r1 = resolve_items(parse_program_items("def foo(x: i64): i64 = x", 24))
    let _ = assert_eq(ctx, "resolve simple ok", resolve_ok(r1), 1)

    // 2. Data constructor registration
    let r2 = resolve_items(parse_program_items("data List { Nil, Cons(i64, List) }\ndef head(xs: List): i64 = 0", 61))
    let _ = assert_eq(ctx, "resolve data ok", resolve_ok(r2), 1)
    let m2 = resolve_module(r2)
    let _ = assert_eq(ctx, "cons Nil has", strlist_has(m2.cons, mk_str("Nil", 3)), 1)
    let ci_nil: ConsInfo = strlist_get_unwrap(m2.cons, mk_str("Nil", 3))
    let _ = assert_eq(ctx, "cons Nil tag", consinfo_tag(ci_nil), 0)
    let _ = assert_eq(ctx, "cons Nil arity", consinfo_arity(ci_nil), 0)
    let ci_cons: ConsInfo = strlist_get_unwrap(m2.cons, mk_str("Cons", 4))
    let _ = assert_eq(ctx, "cons Cons tag", consinfo_tag(ci_cons), 1)
    let _ = assert_eq(ctx, "cons Cons arity", consinfo_arity(ci_cons), 2)

    // 3. Recursive data detection (direct self-ref)
    let r3 = resolve_items(parse_program_items("data List { Nil, Cons(i64, List) }", 34))
    let m3 = resolve_module(r3)
    let di_list: DataInfo = strlist_get_unwrap(m3.datas, mk_str("List", 4))
    let _ = assert_eq(ctx, "List is recursive", datainfo_is_rec(di_list), 1)

    // 4. Non-recursive data
    let r4 = resolve_items(parse_program_items("data Color { Red, Green, Blue }", 31))
    let m4 = resolve_module(r4)
    let di_color: DataInfo = strlist_get_unwrap(m4.datas, mk_str("Color", 5))
    let _ = assert_eq(ctx, "Color not rec", datainfo_is_rec(di_color), 0)

    // 5. Mutual recursion
    let r5 = resolve_items(parse_program_items("data A { Leaf, NodeA(B) }\ndata B { Leaf2, NodeB(A) }", 51))
    let m5 = resolve_module(r5)
    let di_a: DataInfo = strlist_get_unwrap(m5.datas, mk_str("A", 1))
    let di_b: DataInfo = strlist_get_unwrap(m5.datas, mk_str("B", 1))
    let _ = assert_eq(ctx, "A is recursive", datainfo_is_rec(di_a), 1)
    let _ = assert_eq(ctx, "B is recursive", datainfo_is_rec(di_b), 1)

    // 6. Pointing to recursive but not part of cycle
    let r6 = resolve_items(parse_program_items("data List { Nil, Cons(i64, List) }\ndata Wrapper { Wrap(List) }", 62))
    let m6 = resolve_module(r6)
    let di_l: DataInfo = strlist_get_unwrap(m6.datas, mk_str("List", 4))
    let di_w: DataInfo = strlist_get_unwrap(m6.datas, mk_str("Wrapper", 7))
    let _ = assert_eq(ctx, "List rec2", datainfo_is_rec(di_l), 1)
    let _ = assert_eq(ctx, "Wrapper not rec", datainfo_is_rec(di_w), 0)

    // 7. Duplicate function error
    let r7 = resolve_items(parse_program_items("def foo(x: i64): i64 = x\ndef foo(y: i64): i64 = y", 50))
    let _ = assert_eq(ctx, "dup fun err", resolve_ok(r7), 0)
    let e7 = resolve_errs(r7)
    let _ = assert_true(ctx, "dup fun msg", str_contains(head(e7), mk_str("duplicate function", 18)))

    // 8. Duplicate type error
    let r8 = resolve_items(parse_program_items("type Buf { x: i64 }\ntype Buf { y: i64 }", 39))
    let _ = assert_eq(ctx, "dup type err", resolve_ok(r8), 0)
    let e8 = resolve_errs(r8)
    let _ = assert_true(ctx, "dup type msg", str_contains(head(e8), mk_str("duplicate type", 14)))

    // 9. Duplicate constructor error
    let r9 = resolve_items(parse_program_items("data A { Foo }\ndata B { Foo }", 28))
    let _ = assert_eq(ctx, "dup cons err", resolve_ok(r9), 0)
    let e9 = resolve_errs(r9)
    let _ = assert_true(ctx, "dup cons msg", str_contains(head(e9), mk_str("duplicate constructor", 21)))

    // 10. Undefined variable error
    let r10 = resolve_items(parse_program_items("def foo(x: i64): i64 = y", 24))
    let _ = assert_eq(ctx, "undef var err", resolve_ok(r10), 0)
    let e10 = resolve_errs(r10)
    let _ = assert_true(ctx, "undef var msg", str_contains(head(e10), mk_str("undefined name", 14)))

    // 11. Arity mismatch function
    let r11 = resolve_items(parse_program_items("def foo(x: i64): i64 = x\ndef bar(y: i64): i64 = foo(1, 2)", 56))
    let _ = assert_eq(ctx, "fn arity err", resolve_ok(r11), 0)
    let e11 = resolve_errs(r11)
    let _ = assert_true(ctx, "fn arity msg", str_contains(head(e11), mk_str("expects 1 arg", 13)))

    // 12. Let binding scope OK
    let r12 = resolve_items(parse_program_items("def foo(x: i64): i64 = { let y = x\n y + 1 }", 44))
    let _ = assert_eq(ctx, "let scope ok", resolve_ok(r12), 1)

    // 13. Shift k bound in body OK
    let r13 = resolve_items(parse_program_items("def foo(x: i64): i64 = reset 0 { shift 0 k { k } }", 51))
    let _ = assert_eq(ctx, "shift k ok", resolve_ok(r13), 1)

    // 14. Shift k not bound outside
    let r14 = resolve_items(parse_program_items("def foo(x: i64): i64 = { let y = k\n y }", 40))
    let _ = assert_eq(ctx, "k undef err", resolve_ok(r14), 0)
    let e14 = resolve_errs(r14)
    let _ = assert_true(ctx, "k undef msg", str_contains(head(e14), mk_str("undefined name", 14)))

    // 15. Record literal resolves
    let r15 = resolve_items(parse_program_items("type Buf { x: i64 }\ndef mk(): Buf = Buf { x: 1 }", 48))
    let _ = assert_eq(ctx, "record lit ok", resolve_ok(r15), 1)

    // 16. Record literal field expr resolves like normal expr
    let r16 = resolve_items(parse_program_items("type Buf { x: i64 }\ndef mk(y: i64): Buf = Buf { x: y }", 55))
    let _ = assert_eq(ctx, "record lit field expr ok", resolve_ok(r16), 1)


    // Union: basic resolve
    let r_u1 = resolve_items(parse_program_items("union Val { tag: i64  payload: i64 }", 36))
    let _ = assert_eq(ctx, "union resolve ok", resolve_ok(r_u1), 1)
    let _ = if resolve_ok(r_u1) != 0 {
        let m_u1 = resolve_module(r_u1)
        assert_eq(ctx, "union in types", strlist_has(m_u1.types, mk_str("Val", 3)), 1)
    } else { 0 }

    // Union: field access
    let r_u2 = resolve_items(parse_program_items("union Val { tag: i64  payload: i64 }\ndef get_tag(v: Val): i64 = v.tag", 69))
    let _ = assert_eq(ctx, "union field ok", resolve_ok(r_u2), 1)

    // Union: dup with type
    let r_u3 = resolve_items(parse_program_items("type Foo { x: i64 }\nunion Foo { y: i64 }", 40))
    let _ = assert_eq(ctx, "union dup type err", resolve_ok(r_u3), 0)

    0
}
