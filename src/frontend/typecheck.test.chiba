namespace frontend.typecheck.test
use metalstd.mem.*
use metalstd.list.*
use metalstd.str.*
use metalstd.test.*
use metalstd.print.*
use frontend.parser.*
use frontend.resolve.*
use frontend.typecheck.*
use frontend.resolve.test.*

// ── Typecheck helpers ───────────────────────────────────────────────────────

def tc_ok(src: i64, src_len: i64): i64 = {
    let items = parse_program_items(src, src_len)
    let r = resolve_items(items)
    match r {
        ROk(m) => {
            let errs = typecheck_items(items, m)
            is_nil(errs)
        }
        RErr(_) => 0
    }
}

def tc_errs(src: i64, src_len: i64): List[Str] = {
    let items = parse_program_items(src, src_len)
    let r = resolve_items(items)
    match r {
        ROk(m) => typecheck_items(items, m)
        RErr(_) => Nil
    }
}

// ── Typecheck tests ─────────────────────────────────────────────────────────

def test_typecheck(ctx: i64): i64 = {
    let _ = write_fd(1, "-- Typecheck tests --\n", 22)

    // 1. Simple arith OK
    let _ = assert_eq(ctx, "tc arith ok", tc_ok("def foo(x: i64): i64 = x + 1", 29), 1)

    // 2. If same type OK
    let _ = assert_eq(ctx, "tc if ok", tc_ok("def foo(n: i64): i64 = if n == 0 { 0 } else { 1 }", 51), 1)

    // 3. If branch type mismatch
    let e3 = tc_errs("def foo(n: i64): i64 = if n == 0 { 0 } else { true }", 53)
    let _ = assert_eq(ctx, "tc if mismatch", is_nil(e3), 0)
    let _ = assert_true(ctx, "tc if msg", str_contains(head(e3), mk_str("incompatible", 12)))

    // 4. Bool in arithmetic
    let e4 = tc_errs("def foo(n: i64): i64 = true + 1", 31)
    let _ = assert_eq(ctx, "tc arith bool", is_nil(e4), 0)
    let _ = assert_true(ctx, "tc arith msg", str_contains(head(e4), mk_str("integer operand", 15)))

    // 5. Reset tag must be integer
    let e5 = tc_errs("def foo(n: i64): i64 = reset true { n }", 39)
    let _ = assert_eq(ctx, "tc reset tag", is_nil(e5), 0)
    let _ = assert_true(ctx, "tc reset msg", str_contains(head(e5), mk_str("tag must be an integer", 22)))

    // 6. Return type mismatch
    let e6 = tc_errs("def foo(n: i64): i64 = n == 0", 29)
    let _ = assert_eq(ctx, "tc ret mismatch", is_nil(e6), 0)
    let _ = assert_true(ctx, "tc ret msg", str_contains(head(e6), mk_str("return type", 11)))

    // 7. Full program OK
    let _ = assert_eq(ctx, "tc full ok", tc_ok("data List { Nil, Cons(i64, List) }\ndef sum(n: i64): i64 = if n == 0 { 0 } else { n + sum(n - 1) }", 96), 1)

    // 8. if let constructor-bound record field access
    let _ = assert_eq(ctx, "tc iflet ctor field", tc_ok("type Point { x: i64 }\ndata Opt { None, Some(Point) }\ndef foo(o: Opt): i64 = if let Some(p) = o { p.x } else { 0 }", 113), 1)

    // 9. match constructor-bound record field access
    let _ = assert_eq(ctx, "tc match ctor field", tc_ok("type Point { x: i64 }\ndata Opt { None, Some(Point) }\ndef foo(o: Opt): i64 = match o { Some(p) => p.x _ => 0 }", 109), 1)

    // 10. string literal now types as lowercase `str`
    let src10 = "def foo(): str = \"hello\""
    let _ = assert_eq(ctx, "tc str literal type", tc_ok(src10, strlen(src10)), 1)

    // 11. lowercase `str` parameter / return type syntax typechecks
    let src11 = "def id(x: str): str = x"
    let _ = assert_eq(ctx, "tc str type syntax", tc_ok(src11, strlen(src11)), 1)

    // 12. built-in `cstr` parameter / return type syntax typechecks
    let src12 = "def id(x: cstr): cstr = x"
    let _ = assert_eq(ctx, "tc cstr type syntax", tc_ok(src12, strlen(src12)), 1)

    // 13. string literal should not typecheck directly as built-in `cstr`
    let src13 = "def foo(): cstr = \"hello\""
    let _ = assert_eq(ctx, "tc cstr literal mismatch", tc_ok(src13, strlen(src13)), 0)

    // 14. c-string literal should typecheck directly as built-in `cstr`
    let src14 = "def foo(): cstr = c\"hello\""
    let _ = assert_eq(ctx, "tc cstr literal type", tc_ok(src14, strlen(src14)), 1)

    // 15. c-string literal should not typecheck directly as built-in `str`
    let src15 = "def foo(): str = c\"hello\""
    let _ = assert_eq(ctx, "tc str from cstr literal mismatch", tc_ok(src15, strlen(src15)), 0)

    // 16. slice literal with i64 elements
    let src16 = "def foo(): slice[i64] = [1, 2, 3]"
    let _ = assert_eq(ctx, "tc slice literal i64", tc_ok(src16, strlen(src16)), 1)

    // 17. bool slice literal
    let src17 = "def foo(): slice[bool] = [true, false]"
    let _ = assert_eq(ctx, "tc slice literal bool", tc_ok(src17, strlen(src17)), 1)

    // 18. mixed element slice literal should fail typecheck
    let src18 = "def foo(): slice[i64] = [1, true]"
    let _ = assert_eq(ctx, "tc slice literal mixed mismatch", tc_ok(src18, strlen(src18)), 0)

    // 19. empty slice literal (no element to infer from, but return type matches)
    let src19 = "def foo(): slice[i64] = []"
    let _ = assert_eq(ctx, "tc empty slice literal unresolved", tc_ok(src19, strlen(src19)), 1)

    // 20. slice field access and indexing
    let src20 = "def foo(xs: slice[i64]): i64 = xs.len"
    let _ = assert_eq(ctx, "tc slice len staged", tc_ok(src20, strlen(src20)), 1)

    let src21 = "def foo(xs: slice[i64]): i64 = xs.ptr"
    let _ = assert_eq(ctx, "tc slice ptr staged", tc_ok(src21, strlen(src21)), 1)

    let src22 = "def foo(xs: slice[i64]): i64 = xs[0]"
    let _ = assert_eq(ctx, "tc slice index staged", tc_ok(src22, strlen(src22)), 1)

    0
}
