namespace metalstd.file.test
use metalstd.mem.*
use metalstd.str.*
use metalstd.test.*
use metalstd.file.*

// ── File syscall tests ─────────────────────────────────────────────────────

def file_test_streq(a: Str, b: Str): i64 =
    if a.len != b.len { 0 } else { file_test_streq_loop(a.ptr, b.ptr, a.len, 0) }

def file_test_streq_loop(a_ptr: i64, b_ptr: i64, len: i64, i: i64): i64 =
    if i >= len { 1 }
    else {
        if load8(a_ptr, i) != load8(b_ptr, i) { 0 }
        else { file_test_streq_loop(a_ptr, b_ptr, len, i + 1) }
    }

def test_file(ctx: i64): i64 = {
    let _ = write_fd(1, "-- metalstd.file tests --\n", 26)

    let path = "runtime/chiba_level0_file_test.txt"
    let content = mk_str("hello-file\n", strlen("hello-file\n"))
    let write_res = file_write_file_all(path, content)
    let _ = assert_true(ctx, "file write non-negative", write_res >= 0)

    let read_back = file_read_file_all(path)
    let _ = assert_eq(ctx, "file read len", read_back.len, content.len)
    let _ = assert_true(ctx, "file read content", file_test_streq(read_back, content))

    0
}
