namespace metalstd.list.test
use metalstd.mem.*
use metalstd.list.*
use metalstd.test.*
use metalstd.print.*

def test_list(ctx: i64): i64 = {
    let _ = write_fd(1, "-- List[T] tests --\n", 20)

    // Nil / Cons
    let xs: List[i64] = Nil
    let _ = assert_eq(ctx, "nil is_nil", is_nil(xs), 1)

    let ys = Cons(10, Cons(20, Cons(30, Nil)))
    let _ = assert_eq(ctx, "cons is_nil", is_nil(ys), 0)
    let _ = assert_eq(ctx, "head", head(ys), 10)
    let _ = assert_eq(ctx, "length", length(ys), 3)

    // nth
    let _ = assert_eq(ctx, "nth 0", nth(ys, 0), 10)
    let _ = assert_eq(ctx, "nth 1", nth(ys, 1), 20)
    let _ = assert_eq(ctx, "nth 2", nth(ys, 2), 30)

    // rev
    let r = rev(ys)
    let _ = assert_eq(ctx, "rev head", head(r), 30)
    let _ = assert_eq(ctx, "rev nth 2", nth(r, 2), 10)

    // append
    let zs = append(Cons(1, Cons(2, Nil)), Cons(3, Cons(4, Nil)))
    let _ = assert_eq(ctx, "append len", length(zs), 4)
    let _ = assert_eq(ctx, "append nth 0", nth(zs, 0), 1)
    let _ = assert_eq(ctx, "append nth 3", nth(zs, 3), 4)

    // snoc
    let ss = snoc(Cons(1, Nil), 2)
    let _ = assert_eq(ctx, "snoc len", length(ss), 2)
    let _ = assert_eq(ctx, "snoc last", nth(ss, 1), 2)

    // range
    let rng = range(0, 5)
    let _ = assert_eq(ctx, "range len", length(rng), 5)
    let _ = assert_eq(ctx, "range 0", nth(rng, 0), 0)
    let _ = assert_eq(ctx, "range 4", nth(rng, 4), 4)

    // index_of
    let _ = assert_eq(ctx, "index_of found", index_of(ys, 20), 1)
    let _ = assert_eq(ctx, "index_of miss", index_of(ys, 99), 0 - 1)

    0
}
