namespace metalstd.process.test
use metalstd.mem.*
use metalstd.list.*
use metalstd.str.*
use metalstd.test.*
use metalstd.process.*

// ── Process syscall tests ──────────────────────────────────────────────────

def proc_test_streq(a: Str, b: Str): i64 =
    if a.len != b.len { 0 } else { proc_test_streq_loop(a.ptr, b.ptr, a.len, 0) }

def proc_test_streq_loop(a_ptr: i64, b_ptr: i64, len: i64, i: i64): i64 =
    if i >= len { 1 }
    else {
        if load8(a_ptr, i) != load8(b_ptr, i) { 0 }
        else { proc_test_streq_loop(a_ptr, b_ptr, len, i + 1) }
    }

def test_process(ctx: i64): i64 = {
    let _ = write_fd(1, "-- metalstd.process tests --\n", 29)

    let res = proc_run_capture(
        c"/bin/echo",
        Cons(c"echo", Cons(c"chiba-proc", Nil)))
    let out = proc_result_stdout(res)
    let expected = mk_str("chiba-proc\n", strlen("chiba-proc\n"))

    let _ = assert_eq(ctx, "process exit status", proc_result_status(res), 0)
    let _ = assert_true(ctx, "process stdout", proc_test_streq(out, expected))

    let stdin_expected = mk_str("chiba-stdin\n", strlen("chiba-stdin\n"))
    let stdin_res = proc_run_capture_input(
        c"/bin/cat",
        Cons(c"cat", Nil),
        stdin_expected)
    let stdin_out = proc_result_stdout(stdin_res)

    let _ = assert_eq(ctx, "process stdin exit status", proc_result_status(stdin_res), 0)
    let _ = assert_true(ctx, "process stdin stdout", proc_test_streq(stdin_out, stdin_expected))

    0
}
