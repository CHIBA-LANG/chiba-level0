namespace metalstd.str.test
use metalstd.mem.*
use metalstd.str.*
use metalstd.test.*
use metalstd.print.*

def test_str(ctx: i64): i64 = {
    let _ = write_fd(1, "-- Str tests --\n", 16)

    let b = str_new()
    let _ = assert_eq(ctx, "str empty len", b.len, 0)

    let _ = str_push(b, 72)
    let _ = str_push(b, 105)
    let _ = assert_eq(ctx, "str push len", b.len, 2)

    let _ = str_append_cstr(b, "!")
    let _ = assert_eq(ctx, "str append len", b.len, 3)

    let b2 = str_new()
    let _ = str_push_i64(b2, 0 - 42)
    let _ = assert_eq(ctx, "str i64 len", b2.len, 3)

    let b3 = str_new()
    let _ = str_push_hex(b3, 255)
    let _ = assert_eq(ctx, "str hex len", b3.len, 2)

    let b4 = str_new()
    let _ = str_push_bool(b4, 1)
    let _ = assert_eq(ctx, "str bool true len", b4.len, 4)

    let b5 = str_new()
    let _ = str_push_bool(b5, 0)
    let _ = assert_eq(ctx, "str bool false len", b5.len, 5)

    0
}
