namespace project.test
use metalstd.mem.*
use metalstd.list.*
use metalstd.str.*
use metalstd.map.*
use metalstd.test.*
use metalstd.print.*
use frontend.ast.*
use frontend.parser.*
use frontend.resolve.*
use frontend.typecheck.*
use project.*

def test_path_is_source_file(ctx: i64): i64 = {
    let path_buf = str_new()
    let _ = str_push_cstr(path_buf, "tmp/example.chiba")
    let _ = str_null_terminate(path_buf)
    let path_c = mk_cstr_view(path_buf.ptr, path_buf.len)
    let _ = assert_eq(ctx, "path_is_source_file .chiba", path_is_source_file(path_c), 1)

    let iface_buf = str_new()
    let _ = str_push_cstr(iface_buf, "tmp/example.cbi")
    let _ = str_null_terminate(iface_buf)
    let iface_c = mk_cstr_view(iface_buf.ptr, iface_buf.len)
    let _ = assert_eq(ctx, "path_is_source_file .cbi", path_is_source_file(iface_c), 1)

    let txt_buf = str_new()
    let _ = str_push_cstr(txt_buf, "tmp/example.txt")
    let _ = str_null_terminate(txt_buf)
    let txt_c = mk_cstr_view(txt_buf.ptr, txt_buf.len)
    assert_eq(ctx, "path_is_source_file .txt", path_is_source_file(txt_c), 0)
}

def parse_program_cstr(src: i64): Program = parse_program(src, strlen(src))

def mk_source_file(path: i64, src: i64): SourceFile =
    SourceFile(mk_str(path, strlen(path)), parse_program_cstr(src))

def resolve_ok(r: ResolveResult): i64 =
    match r { ROk(_) => 1  RErr(_) => 0 }

def resolve_module(r: ResolveResult): Module =
    match r { ROk(m) => m  RErr(_) => 0 as Module }

def compile_filter_ok(r: CompileFilterResult): i64 =
    match r { CompileFilterOk(_) => 1  CompileFilterErr(_) => 0 }

def compile_filter_files(r: CompileFilterResult): List[SourceFile] =
    match r { CompileFilterOk(files) => files  CompileFilterErr(_) => Nil }

def compile_filter_errs(r: CompileFilterResult): List[Str] =
    match r { CompileFilterOk(_) => Nil  CompileFilterErr(errs) => errs }

def project_str_match_at(h_ptr: i64, n_ptr: i64, n_len: i64, i: i64): i64 =
    if i >= n_len { 1 }
    else {
        if load8(h_ptr + i, 0) == load8(n_ptr + i, 0) {
            project_str_match_at(h_ptr, n_ptr, n_len, i + 1)
        } else { 0 }
    }

def project_str_contains_loop(h_ptr: i64, h_len: i64, n_ptr: i64, n_len: i64, pos: i64): i64 =
    if pos + n_len > h_len { 0 }
    else {
        if project_str_match_at(h_ptr + pos, n_ptr, n_len, 0) != 0 { 1 }
        else { project_str_contains_loop(h_ptr, h_len, n_ptr, n_len, pos + 1) }
    }

def project_str_contains(haystack: Str, needle: Str): i64 =
    if needle.len == 0 { 1 }
    else { project_str_contains_loop(haystack.ptr, haystack.len, needle.ptr, needle.len, 0) }

def test_project(ctx: i64): i64 = {
    let _ = write_fd(1, "-- Project tests --\n", 20)
    let _ = test_path_is_source_file(ctx)

    let files1 = Cons(
        mk_source_file("a.chiba", "namespace a\ntype LowerCtx { x: i64 }\ndef mk(x: i64): LowerCtx = LowerCtx { x: x }"),
        Cons(
            mk_source_file("b.chiba", "namespace b\ntype LowerCtx { y: i64 }\ndef mk(y: i64): LowerCtx = LowerCtx { y: y }"),
            Nil))
    let merged1 = merge_program(files1)
    let r1 = resolve(merged1)
    let _ = assert_eq(ctx, "project ns collision ok", resolve_ok(r1), 1)
    let m1 = resolve_module(r1)
    let _ = assert_eq(ctx, "project type a visible", strlist_has(m1.types, mk_str("a.LowerCtx", 10)), 1)
    let _ = assert_eq(ctx, "project type b visible", strlist_has(m1.types, mk_str("b.LowerCtx", 10)), 1)

    let files2 = Cons(
        mk_source_file("math.chiba", "namespace math\ndef add(x: i64, y: i64): i64 = x + y"),
        Cons(
            mk_source_file("main.chiba", "namespace main\nuse math.*\ndef run(x: i64): i64 = add(x, 1)"),
            Nil))
    let merged2 = merge_program(files2)
    let r2 = resolve(merged2)
    let _ = assert_eq(ctx, "project use glob resolve", resolve_ok(r2), 1)
    let m2 = resolve_module(r2)
    let _ = assert_eq(ctx, "project renamed math fun", strlist_has(m2.funs, mk_str("math.add", 8)), 1)
    let _ = assert_eq(ctx, "project renamed main fun", strlist_has(m2.funs, mk_str("main.run", 8)), 1)
    let tc2 = typecheck_program(merged2, m2)
    let _ = assert_eq(ctx, "project use glob typecheck", is_nil(tc2), 1)

    let files3 = Cons(
        mk_source_file("opt.chiba", "namespace opt\ndata Opt { None, Some(i64) }"),
        Cons(
            mk_source_file("use.chiba", "namespace app\nuse opt.*\ndef run(x: i64): i64 = match Some(x) { Some(y) => y  None => 0 }"),
            Nil))
    let merged3 = merge_program(files3)
    let r3 = resolve(merged3)
    let _ = assert_eq(ctx, "project ctor import resolve", resolve_ok(r3), 1)
    let m3 = resolve_module(r3)
    let tc3 = typecheck_program(merged3, m3)
    let _ = assert_eq(ctx, "project ctor import typecheck", is_nil(tc3), 1)


    // Union e2e: parse + resolve
    let uf1 = mk_source_file("u.chiba", "union UV { a: i64  b: i64 }")
    let uf2 = mk_source_file("m.chiba", "use u.*\ndef uget(v: UV): i64 = v.a")
    let um = merge_program(Cons(uf1, Cons(uf2, Nil)))
    let ru = resolve(um)
    let _ = assert_eq(ctx, "union e2e resolve", resolve_ok(ru), 1)

    let cfg_chiba = compile_config_default()
    let cfg_c = compile_config_for_backend(mk_str("c", 1))

    let _ = assert_eq(ctx, "compile_if cfg backend c mismatch", streq(mk_str("c", 1), cfg_chiba.backend), 0)
    let _ = assert_eq(ctx, "compile_if cfg backend chiba match", streq(mk_str("chiba", 5), cfg_chiba.backend), 1)

    let parse_c = compile_if_parse_str(mk_str("\"c\"", 3), 0)
    let parse_c_ok = match parse_c { CompileIfStrOk(v, _) => streq(v, mk_str("c", 1))  _ => 0 }
    let _ = assert_eq(ctx, "compile_if parse string c", parse_c_ok, 1)
    let parse_name = compile_if_parse_ident(mk_str("compile_if(backend = \"c\")", 25), 0)
    let parse_name_ok = match parse_name { CompileIfIdentOk(name, _) => streq(name, mk_str("compile_if", 10))  _ => 0 }
    let _ = assert_eq(ctx, "compile_if parse name", parse_name_ok, 1)
    let attr_is = compile_if_attr_is_compile_if(mk_str("compile_if(backend = \"c\")", 25))
    let _ = assert_eq(ctx, "compile_if attr recognized", attr_is, 1)
    let kv_c = compile_if_eval_key_value(cfg_chiba, mk_str("backend = \"c\"", 13), mk_str("backend", 7), 7)
    let kv_c_val = match kv_c { CompileIfBoolOk(v, _) => v  _ => 0 - 1 }
    let _ = assert_eq(ctx, "compile_if kv backend c false", kv_c_val, 0)
    let cond_c = compile_if_parse_cond(cfg_chiba, mk_str("compile_if(backend = \"c\")", 25), 11)
    let cond_c_val = match cond_c { CompileIfBoolOk(v, _) => v  _ => 0 - 1 }
    let _ = assert_eq(ctx, "compile_if cond backend c false", cond_c_val, 0)
    let bool_drop = compile_if_eval_bool(0)
    let bool_drop_val = match bool_drop { CompileIfDrop => 0  CompileIfKeep => 1  CompileIfEvalErr(_) => 2 }
    let _ = assert_eq(ctx, "compile_if bool zero drops", bool_drop_val, 0)

    let ev_true = compile_if_eval_attr(cfg_chiba, mk_str("compile_if(backend = \"chiba\")", 29))
    let ev_true_val = match ev_true { CompileIfKeep => 1  _ => 0 }
    let _ = assert_eq(ctx, "compile_if eval backend true", ev_true_val, 1)
    let ev_false = compile_if_eval_attr(cfg_chiba, mk_str("compile_if(backend = \"c\")", 25))
    let ev_false_val = match ev_false { CompileIfDrop => 0  CompileIfKeep => 1  CompileIfEvalErr(_) => 2 }
    let _ = assert_eq(ctx, "compile_if eval backend false", ev_false_val, 0)
    let ev_any = compile_if_eval_attr(cfg_chiba, mk_str("compile_if(any(backend = \"c\", target = \"wasm32-unknown-wasm\"))", 62))
    let ev_any_val = match ev_any { CompileIfDrop => 0  CompileIfKeep => 1  CompileIfEvalErr(_) => 2 }
    let _ = assert_eq(ctx, "compile_if eval any false", ev_any_val, 0)

    // compile_if parser/evaluator: all/any/not select one same-name function
    let cf_src1 = "#[compile_if(all(backend = \"chiba\", target = \"amd64-unknown-linux\"))]\ndef pick(): i64 = 11\n#[compile_if(any(backend = \"c\", target = \"wasm32-unknown-wasm\"))]\ndef pick(): i64 = 12\n#[compile_if(not(backend = \"c\"))]\ndef kept(): i64 = 13"
    let cf_files1 = Cons(mk_source_file("cfg.chiba", cf_src1), Nil)
    let cf_filter1 = compile_filter_source_files(cfg_chiba, cf_files1)
    let _ = assert_eq(ctx, "compile_if bool filter ok", compile_filter_ok(cf_filter1), 1)
    let cf_merged1 = merge_program(compile_filter_files(cf_filter1))
    let _ = assert_eq(ctx, "compile_if bool item count", length(cf_merged1.items), 2)
    let cf_resolved1 = resolve(cf_merged1)
    let _ = assert_eq(ctx, "compile_if bool resolve", resolve_ok(cf_resolved1), 1)

    // Same-name backend-specific implementations do not conflict before filtering
    let cf_src2 = "#[compile_if(backend = \"c\")]\ndef print(): i64 = missing_platform_symbol\n#[compile_if(backend = \"chiba\")]\ndef print(): i64 = 7\ndef run(): i64 = print()"
    let cf_files2 = Cons(mk_source_file("print.chiba", cf_src2), Nil)
    let cf_filter2 = compile_filter_source_files(cfg_chiba, cf_files2)
    let _ = assert_eq(ctx, "compile_if same-name filter ok", compile_filter_ok(cf_filter2), 1)
    let cf_merged2 = merge_program(compile_filter_files(cf_filter2))
    let cf_resolved2 = resolve(cf_merged2)
    let _ = assert_eq(ctx, "compile_if same-name resolve", resolve_ok(cf_resolved2), 1)
    let cf_m2 = resolve_module(cf_resolved2)
    let cf_tc2 = typecheck_program(cf_merged2, cf_m2)
    let _ = assert_eq(ctx, "compile_if filtered bad body skipped", is_nil(cf_tc2), 1)

    // After filtering, duplicate survivors are still duplicate definitions
    let cf_src3 = "#[compile_if(backend = \"chiba\")]\ndef dup(): i64 = 1\n#[compile_if(not(backend = \"c\"))]\ndef dup(): i64 = 2"
    let cf_filter3 = compile_filter_source_files(cfg_chiba, Cons(mk_source_file("dup.chiba", cf_src3), Nil))
    let cf_merged3 = merge_program(compile_filter_files(cf_filter3))
    let cf_resolved3 = resolve(cf_merged3)
    let _ = assert_eq(ctx, "compile_if duplicate after filter", resolve_ok(cf_resolved3), 0)

    // If all implementations are filtered out, normal undefined reference diagnostics remain
    let cf_src4 = "#[compile_if(backend = \"c\")]\ndef only_c(): i64 = 1\ndef run(): i64 = only_c()"
    let cf_filter4 = compile_filter_source_files(cfg_chiba, Cons(mk_source_file("undef.chiba", cf_src4), Nil))
    let cf_merged4 = merge_program(compile_filter_files(cf_filter4))
    let cf_resolved4 = resolve(cf_merged4)
    let _ = assert_eq(ctx, "compile_if undefined after filter", resolve_ok(cf_resolved4), 0)

    // Diagnostics for boolean arity and empty all/any
    let cf_src5 = "#[compile_if(not(backend = \"chiba\", target = \"amd64-unknown-linux\"))]\ndef bad(): i64 = 1"
    let cf_filter5 = compile_filter_source_files(cfg_chiba, Cons(mk_source_file("bad_not.chiba", cf_src5), Nil))
    let _ = assert_eq(ctx, "compile_if not arity err", compile_filter_ok(cf_filter5), 0)

    let cf_src6 = "#[compile_if(any())]\ndef bad(): i64 = 1"
    let cf_filter6 = compile_filter_source_files(cfg_c, Cons(mk_source_file("bad_any.chiba", cf_src6), Nil))
    let _ = assert_eq(ctx, "compile_if empty any err", compile_filter_ok(cf_filter6), 0)

    0
}
