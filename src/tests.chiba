data Pair {
    MkPair(i64, i64)
}

def test_data_adt(ctx: i64): i64 = {
    let _ = write_fd(1, "-- Data ADT tests --\n", 21)

    let n: Option[i64] = None
    let j = Some(42)
    let _ = assert_eq(ctx, "nothing", unwrap_or(n, 0), 0)
    let _ = assert_eq(ctx, "just", unwrap_or(j, 0), 42)

    let p = MkPair(10, 20)
    let s = match p { MkPair(a, b) => a + b  }
    let _ = assert_eq(ctx, "pair sum", s, 30)

    let xs: List[Option[i64]] = Cons(Some(1), Cons(None, Cons(Some(3), Nil)))
    let first_val = match head(xs) { Some(v) => v  None => 0 - 1 }
    let _ = assert_eq(ctx, "nested match", first_val, 1)

    0
}


union TestVal { val_a: i64  val_b: i64 }

def test_union(ctx: i64): i64 = {
    let _ = write_fd(1, "-- Union tests --\n", 18)
    let v1 = TestVal { val_a: 42, val_b: 0 }
    let _ = assert_eq(ctx, "union field val_a", v1.val_a, 42)
    let v2 = { v1 | val_b: 99 }
    let _ = assert_eq(ctx, "union update val_b", v2.val_b, 99)
    let _ = assert_eq(ctx, "union update keeps val_a", v2.val_a, 42)
    let v3 = TestVal { val_a: 123, val_b: 456 }
    let _ = assert_eq(ctx, "union both fields", v3.val_a, 123)
    let _ = assert_eq(ctx, "union both fields 2", v3.val_b, 456)
    0
}
def ensure_test_runtime_dirs(): i64 = {
    let _ = proc_run_capture(c"/bin/mkdir",
        Cons(c"mkdir",
        Cons(c"-p",
        Cons(c"runtime", Nil))))
    0
}

def run_all_tests(): i64 = {
    let ctx = test_init()
    let _ = write_fd(1, "=== chiba-level0 tests ===\n", 27)
    let _ = ensure_test_runtime_dirs()

    let _ = test_mem(ctx)
    let _ = test_list(ctx)
    let _ = test_map(ctx)
    let _ = test_str(ctx)
    let _ = test_vec(ctx)
    let _ = test_file(ctx)
    let _ = test_dir(ctx)
    let _ = test_process(ctx)
    let _ = test_data_adt(ctx)
    let _ = test_union(ctx)
    let _ = test_lexer(ctx)
    let _ = test_parser_expr(ctx)
    let _ = test_parser_item(ctx)
    let _ = test_resolve(ctx)
    let _ = test_typecheck(ctx)
    let _ = test_to_string(ctx)
    let _ = test_ir(ctx)
    let _ = test_bir_ir(ctx)
    let _ = test_bir_lower(ctx)
    let _ = test_bir_codegen_amd64(ctx)
    let _ = test_usage(ctx)
    let _ = test_escape(ctx)
    let _ = test_closure(ctx)
    let _ = test_project(ctx)
    let _ = test_e2e(ctx)

    let failures = test_summary(ctx)
    if failures > 0 { 1 } else { 0 }
}
