namespace semantic.gates.memory.invalid

def bad_global_ref: Ref[i64] = Ref.new(0)
def bad_atomic_record: Atomic[Record] = Atomic.new(new_record())

def bad_load(a: Atomic[i64]): i64 = Atomic.load(a, Release)
def bad_store(a: Atomic[i64]): i64 = Atomic.store(a, 1, Acquire)

def bad_array_cell(xs: Ref[Array[i64]]): i64 = {
    xs[0] := 1
    0
}
